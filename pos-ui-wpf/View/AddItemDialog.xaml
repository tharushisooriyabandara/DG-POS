<view:OptimizedDialogBase x:Class="POS_UI.View.AddItemDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:local="clr-namespace:POS_UI.ViewModels"
    xmlns:conv="clr-namespace:POS_UI.Converters"
    xmlns:view="clr-namespace:POS_UI.View"
    MinHeight="{Binding DialogHeight}" 
    Width="350">
    <view:OptimizedDialogBase.Resources>
        <conv:ModifierButtonTextConverter x:Key="ModifierButtonTextConverter" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:StringToColorConverter x:Key="StringToColorConverter" />
        <conv:StringToForegroundConverter x:Key="StringToForegroundConverter" />
    </view:OptimizedDialogBase.Resources>
    <materialDesign:DialogHost x:Name="ModifiersDialogHost" Identifier="ModifiersDialogHost" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
        <Border Background="White" CornerRadius="16" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Header -->
                <DockPanel Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="35"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ProductName}" FontWeight="Bold" FontSize="20" Margin="6,0,0,0" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="1" Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-8,-8,0" Style="{StaticResource MaterialDesignToolButton}" Command="{Binding CloseCommand}" ToolTip="Close">
                            <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                        </Button>
                    </Grid>
                </DockPanel>
                <!-- Add/Edit Modifiers Button -->
                
                <!-- Quantity -->
                <StackPanel Grid.Row="2" Margin="0,12,0,0">
                    <TextBlock Text="Qty" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                        <Button
                                Width="45" 
                                Height="35" 
                                FontSize="20" 
                                Command="{Binding DecrementQtyCommand}" 
                                Background="#F8F7F7" 
                                Foreground="Black" 
                                BorderBrush="Transparent" 
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center">
                            <materialDesign:PackIcon Kind="Minus" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <TextBlock Text="{Binding Quantity}" FontSize="16" FontWeight="Bold" Width="40" TextAlignment="Center" VerticalAlignment="Center"/>
                        <Button Width="45" FontSize="20" Height="35" Command="{Binding IncrementQtyCommand}"  Background="#F8F7F7" Foreground="Black" BorderBrush="Transparent" HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center">
                            <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
                <!-- Quick Discount -->
                <StackPanel Grid.Row="3" Margin="0,10,0,0">
                    <TextBlock Text="Quick Discount" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                        <ItemsControl ItemsSource="{Binding DiscountPresets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Label}" Width="62" Height="28" Margin="0,0,8,0"
                                            Command="{Binding DataContext.SelectPresetDiscountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Value}"
                                            Background="{Binding IsSelectedString, Converter={StaticResource StringToColorConverter}, ConverterParameter=True}"
                                            Foreground="{Binding IsSelectedString, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=True}"
                                            BorderBrush="Transparent"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
                <!-- Note -->
                <StackPanel Grid.Row="4" Margin="0,8,0,3" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Book" Width="20" Height="20" Margin="10"/>
                    <TextBox Text="{Binding Note}" MaxLength="50" materialDesign:HintAssist.Hint="Enter Note Here" Margin="2,8,15,7" Height="28" BorderBrush="Transparent"/>
                </StackPanel>

                <!-- Price Summary -->
                <ScrollViewer Grid.Row="5" Margin="0,0,0,0" VerticalScrollBarVisibility="Auto" CanContentScroll="True">
                    <StackPanel>
                    <!-- Debug: Show count of selected modifiers
                    <TextBlock Text="{Binding SelectedModifiers.Count}" Foreground="Red" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>  -->
                    
                    <StackPanel Visibility="{Binding HasSelectedModifiers, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBox Text="Selected Modifiers" 
                                 FontWeight="Bold" 
                                 BorderBrush="Transparent"
                                 Visibility="{Binding HasSelectedModifiers, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <ItemsControl ItemsSource="{Binding StructuredModifierDetails}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding Indentation}" 
                                                   Foreground="Transparent"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding ModifierName}" 
                                                   Foreground="Gray" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="13"
                                                   TextAlignment="Left"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding Price, Converter={StaticResource CurrencyFormatConverter}}" 
                                                   Foreground="Gray" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="13"
                                                   TextAlignment="Right"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,3,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    
                    <Grid Margin="0,6,0,6" Background="#FFF4F4F4" VerticalAlignment="Center" Width="Auto">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Item Name and Label -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" Margin="11,10,0,10" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ProductName}" FontWeight="Bold" FontSize="14" Height="22"/>
                            <StackPanel Visibility="{Binding HasSelectedModifiers, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Modifier Price" FontWeight="Bold" FontSize="14" Height="22"/>
                            </StackPanel>
                            <TextBlock Text="Sub Total" FontWeight="Bold" FontSize="14" Height="22"/>
                            <TextBlock Text="Discount" FontWeight="Bold" FontSize="14" Height="22"/>
                            <TextBlock Text="Final Price" Foreground="#53BD90" FontWeight="Bold" FontSize="14" Height="22"/>
                        </StackPanel>
                        <!-- Prices -->
                        <StackPanel Grid.Column="1" Orientation="Vertical" Margin="0,10,11,10" VerticalAlignment="Center">
                            <TextBlock Text="{Binding BasePrice, Converter={StaticResource CurrencyFormatConverter}}" FontWeight="Bold" TextAlignment="Right" FontSize="14" Height="22" HorizontalAlignment="Right"/>
                            <StackPanel Visibility="{Binding HasSelectedModifiers, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{Binding TotalModifierPrice, Converter={StaticResource CurrencyFormatConverter}}" FontWeight="Bold" TextAlignment="Right" FontSize="14" Height="22" HorizontalAlignment="Right"/>
                            </StackPanel>
                            <TextBlock Text="{Binding ItemSubTotal, Converter={StaticResource CurrencyFormatConverter}}" FontWeight="Bold" TextAlignment="Right" FontSize="14" Height="22" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding DiscountAmount, Converter={StaticResource CurrencyFormatConverter}}" FontWeight="Bold" TextAlignment="Right" FontSize="14" Height="22" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding FinalPrice, Converter={StaticResource CurrencyFormatConverter}}" Foreground="#53BD90" FontWeight="Bold" FontSize="14" Height="22" TextAlignment="Right" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Add Item Button -->
                <StackPanel Grid.Row="6" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Margin="0,5,0,0">
                    <Button Content="{Binding SelectedModifiersMultiple, Converter={StaticResource ModifierButtonTextConverter}}" 
						Width="123" 
                        Height="36"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontSize="14"
                        Command="{Binding OpenModifiersDialogCommand}"
                        Margin="0,0,10,0"
                        Visibility="{Binding HasModifiers, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="{Binding ActionButtonText}" 
                        Width="123" 
                        Height="36"
                        Background="#1976D2"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        Command="{Binding AddItemCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </materialDesign:DialogHost>
</view:OptimizedDialogBase> 