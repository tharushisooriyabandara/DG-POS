<UserControl x:Class="POS_UI.View.EndShiftDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:services="clr-namespace:POS_UI.Services"
             MinWidth="420" MinHeight="220">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="End Shift" FontWeight="Bold" FontSize="19"/>
        <Button DockPanel.Dock="Right" Width="32" Height="32"  Margin="0,-10,-10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource MaterialDesignToolButton}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" ToolTip="Close" Background="Transparent" BorderBrush="Transparent">
            <materialDesign:PackIcon Kind="Close" Width="25" Height="25"/>
        </Button>

        <StackPanel Grid.Row="1" Margin="0,25,0,0">
            <TextBlock Text="Cash Amount" Margin="0,0,0,6" FontSize="14" FontWeight="SemiBold"/>
            <Border Background="#FFF" Width="400" HorizontalAlignment="Left" CornerRadius="8" Padding="5" BorderBrush="#E5E7EB" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Source={x:Static services:GlobalDataService.Instance}, Path=ShopDetails.Currency, FallbackValue='£', TargetNullValue='£'}"
                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#374151"
                               Margin="10,0,8,0" MinWidth="28"/>
                    <TextBox x:Name="CashAmountTextBox" Grid.Column="1" Height="40" BorderBrush="Transparent"
                     materialDesign:HintAssist.Hint="Enter cash amount" FontSize="14"
                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden" Margin="0,0,4,0"
                     VerticalContentAlignment="Center" BorderThickness="0"/>
                </Grid>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Cancel" Height="36" Margin="0,0,8,0" Background="White" Foreground="#FF2196F3" BorderBrush="#FF2196F3"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"/>
            <Button Content="End Shift" Height="36" Width="120"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="EndShift_Click"/>
        </StackPanel>
    </Grid>
</UserControl>

