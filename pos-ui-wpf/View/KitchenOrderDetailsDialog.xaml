<view:OptimizedDialogBase x:Class="POS_UI.View.KitchenOrderDetailsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:local="clr-namespace:POS_UI.View"
    xmlns:models="clr-namespace:POS_UI.Models"
    xmlns:vm="clr-namespace:POS_UI.ViewModels"
    xmlns:converters="clr-namespace:POS_UI.Converters"
    xmlns:controls="clr-namespace:POS_UI.View.Controls"
    xmlns:view="clr-namespace:POS_UI.View"
    Width="410" MinHeight="620">
    <view:OptimizedDialogBase.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:StripStatusTagConverter x:Key="StripStatusTagConverter"/>
        <converters:DecimalToVisibilityConverter x:Key="DecimalToVisibilityConverter"/>
        <converters:DiscountLineAmountConverter x:Key="DiscountLineAmountConverter"/>
    </view:OptimizedDialogBase.Resources>
     <!--<ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600" Margin="0,0,0,0">
        <ScrollViewer.Resources>
             Apply thicker scrollbar style defined in Stylesxaml.xaml 
            <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
        </ScrollViewer.Resources>-->
        <Border Background="White" CornerRadius="20" Padding="10">
       
            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="154*"/>
                    <ColumnDefinition Width="41*"/>
                </Grid.ColumnDefinitions>
                <!-- Loading State -->
                <!--<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" 
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ProgressBar IsIndeterminate="True" Width="80" Height="80" 
                             Style="{StaticResource MaterialDesignCircularProgressBar}"/>
                <TextBlock Text="Loading order details..." Margin="0,10,0,0" 
                           FontSize="16" Foreground="Gray" HorizontalAlignment="Center"/>
            </StackPanel>-->

                <!-- Content -->
                <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" Grid.ColumnSpan="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top Section (Header, Order Type, Customer Info, Items, Note/Coupon Buttons) -->
                    <StackPanel Grid.Row="0">
                        <!-- Header -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Hamburger Menu and Order Number -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,10,2">
                            <!-- Hamburger Menu -->
                            <Button x:Name="HamburgerMenuButton" Style="{StaticResource MaterialDesignOutlinedButton}"
                                          Margin="0,-5,8,0" Padding="0,1,0,2" HorizontalAlignment="Center" BorderThickness="0"
                                          Background="Transparent" Foreground="Black" BorderBrush="Black" Height="36" Width="30"
                                          Click="HamburgerMenuButton_Click"
                                          Visibility="{Binding ShowHamburgerMenu, Converter={StaticResource BooleanToVisibilityConverter}}"
                                         >
                                <materialDesign:PackIcon Kind="Menu" Width="30" Height="35"/>
                                <Button.Resources>
                                    <Style TargetType="ContextMenu">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContextMenu">
                                                    <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="5" Margin="5,0,5,0"
                                                                BorderBrush="Gray" Width="150" Height="Auto"
                                                                BorderThickness="1"
                                                                SnapsToDevicePixels="True">
                                                        <StackPanel IsItemsHost="True"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Background" Value="White"/>
                                    </Style>
                                </Button.Resources>
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="HamburgerContextMenu">
                                        <MenuItem Header="Refund Order" FontSize="14" FontWeight="SemiBold" Height="40" Width="150" HorizontalContentAlignment="Center"
                                                          VerticalContentAlignment="Center" 
                                                    Command="{Binding RefundOrderCommand}"
                                                    Visibility="{Binding ShowRefundMenuItem, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                         </MenuItem>
                                        <MenuItem Header="Cancel Order" FontSize="14" FontWeight="SemiBold" Height="40" Width="150" HorizontalContentAlignment="Center"
                                                          VerticalContentAlignment="Center"
                                                         Command="{Binding CancelOrderCommand}" 
                                                         Visibility="{Binding ShowCancelMenuItem, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                         </MenuItem>
                                         <MenuItem Header="Transactions" FontSize="14" FontWeight="SemiBold" Height="40" Width="150" HorizontalContentAlignment="Center"
                                                          VerticalContentAlignment="Center"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Visibility="{Binding ShowTransactions, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                          Command="{Binding OpenTransactionsCommand}">
                                         </MenuItem>
                                        
                                    
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <!-- Order Number -->
                            <StackPanel Orientation="Vertical">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,10,0">
                                    <TextBlock Text="Order " FontWeight="Bold" FontSize="19"/>
                                    <TextBlock Text="{Binding Order.OrderNumber}" FontWeight="Bold" FontSize="19"/>
                                </StackPanel>
                                <TextBlock FontSize="11" Foreground="#666" Margin="0,-5,0,8"
                                           Text="{Binding Order.OrderSessionId, StringFormat=Session # {0}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Order.OrderSessionId}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Order.OrderSessionId}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Margin="0,-10,0,0"  Grid.ColumnSpan="3">
                            <TextBlock  Text="{Binding Order.CustomerName}" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="{Binding CustomerPhone, StringFormat=Phone : {0}}" FontSize="12" Foreground="#555"
                                     Visibility="{Binding ShowCustomerPhone, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding AddressDisplay, StringFormat=Address : {0}}" FontSize="12" Foreground="#555" TextWrapping="Wrap" TextAlignment="Left" MaxHeight="37"
                                    Visibility="{Binding ShowAddress, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                       
                            <!-- Print and Table Buttons -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,0">
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                      Margin="0,0,8,0" Padding="10,6"
                                      Command="{Binding PrintCommand}" Background="#FFF3E0" Foreground="Black" BorderBrush="Black" Height="36">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Printer" Width="20" Height="20" Margin="0,0,5,0"/>
                                        <TextBlock Text="Print" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}" 
                                       Height="37" Width="105" Padding="5">
                                    <TextBlock Text="{Binding TableButtonText}" />
                                </Button>
                            </StackPanel>

                            <!-- Close Button -->
                            <Button Grid.Column="2" Style="{StaticResource MaterialDesignToolButton}"
                                 Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                                 VerticalAlignment="Top" Margin="0,0,2,0"
                                 ToolTip="Close">
                                <materialDesign:PackIcon Kind="Close" Width="24" Height="24"/>
                            </Button>
                        </Grid>

                        <!-- Platform + Payment Status + Shipping Method Badges -->
                        <Grid Margin="0,6,0,0" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <!-- Shipping Method: Yellow background, black foreground -->
                            <Border Grid.Column="0" Background="#FFFFA600" CornerRadius="6" Padding="8,4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ShippingMethodText}" Foreground="Black"  FontWeight="Bold" TextAlignment="Center" />
                            </Border>
                            <Border Grid.Column="1" CornerRadius="6" Margin="5,0,5,0" Background="#FFE6E6E6" Padding="8,4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DeliveryPlatformName}"  Foreground="Black"  FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Badges -->

                            <!-- Platform Logo (if available) -->
                            <Image Grid.Column="3" Height="32" Stretch="Uniform" Width="50" Margin="0,0,8,0"
                                   Source="{Binding PlatformLogo}" HorizontalAlignment="Right"
                                   Visibility="{Binding PlatformLogo, Converter={StaticResource StringToVisibilityConverter}}"/>
                            <!-- Payment Status: Red background, white foreground; hide when empty -->
                            <Border Grid.Column="2" Background="Red" CornerRadius="6" Padding="8,4" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right"
                                Visibility="{Binding PaymentStatus, Converter={StaticResource StringToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding PaymentStatus}" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding PaymentMode, StringFormat=' - {0}'}" 
                                               Foreground="White" FontWeight="Bold"
                                               Visibility="{Binding PaymentStatus, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=PAID|PAID -}"/>
                                </StackPanel>
                            </Border>


                        </Grid>

                        <!--<Border Background="#1976D2" CornerRadius="8" Margin="0,5,0,0" Padding="8">
                         <TextBlock Text="{Binding Order.OrderType}" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                     </Border>-->
                        <!-- Customer Info
                      <Border Background="#F5F5F5" CornerRadius="8" Margin="0,16,0,0" Padding="0,0,0,0">
                         <StackPanel>
                             <StackPanel Orientation="Horizontal">
                                 <StackPanel>
                                     <TextBlock Text="{Binding Order.CustomerName}" FontWeight="Bold" FontSize="16" Height="31" Width="173"/>
                                     <TextBlock Text="{Binding Order.CustomerPhone}" FontSize="12"/>
                                     <TextBlock Text="Contact Code : {Binding Order.Id}" FontSize="12"/>
                                 </StackPanel>
                                 <Button Margin="20,0,0,0" Width="57" Height="36" Background="Transparent" Foreground="Black" BorderBrush="Transparent" Click="Button_Click">
                                     <materialDesign:PackIcon Kind="Phone" Width="20" Height="20"/>
                                 </Button>
                             </StackPanel>
                             <StackPanel Background="#FF9800" Orientation="Horizontal" Margin="0,8,0,0">
                                 <Border  CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                     <TextBlock Text="Driver Arriving In" Foreground="Black" FontWeight="Bold" FontSize="14" Height="22" Width="221"/>

                                 </Border>
                                 <TextBlock Text="  5 mins" FontWeight="Bold" FontSize="14" Foreground="Black" VerticalAlignment="Center" Margin="8,0,0,0"/>
                             </StackPanel>
                         </StackPanel>
                     </Border>-->
                        <!-- Customer Info -->
                        <!-- Deprecated single phone panel; phone now shown under name -->
                        <!--<Border Background="#F5F5F5" CornerRadius="8" Margin="0,16,0,0" Padding="12" 
                             Visibility="{Binding HasCustomerPhone, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding CustomerPhone}" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>-->

                    </StackPanel>

                    <!-- Items List (fills remaining space) -->
                    <Grid Grid.Row="1">
                        <ScrollViewer x:Name="OrderItemsScrollViewer"
                                      VerticalScrollBarVisibility="Hidden" PanningMode="None" Margin="0,5,0,0">
                            <ItemsControl ItemsSource="{Binding Order.Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Margin="0,0,0,8" Padding="8">
                                            <StackPanel>
                                                <Grid Margin="-6,0,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name, Converter={StaticResource StripStatusTagConverter}}" FontWeight="Bold" FontSize="15" TextWrapping="Wrap" TextTrimming="None"/>
                                                    <TextBlock Grid.Column="0" Text="{Binding Quantity, StringFormat='{}{0}  X '}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding ApiItemPrice, Converter={StaticResource CurrencyFormatConverter}}" FontWeight="Bold" FontSize="15" HorizontalAlignment="Right"/>
                                                </Grid>

                                                <Grid Margin="35,0,0,2"
                                                      Visibility="{Binding DiscountAmount, Converter={StaticResource DecimalToVisibilityConverter}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="Discount"
                                                               FontSize="12"
                                                               Foreground="#888"
                                                               Margin="0,0,8,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               FontSize="12"
                                                               Foreground="#FF5A5F"
                                                               HorizontalAlignment="Right">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource DiscountLineAmountConverter}">
                                                                <Binding Path="DiscountAmount"/>
                                                                <Binding Path="Quantity"/>
                                                                <Binding Path="Product"/>
                                                                <Binding Path="DataContext.Order.PlatformId" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                <Binding Path="DataContext.Order.PlatformName" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Grid>

                                                <StackPanel Margin="35,0,0,2"
                                                            Visibility="{Binding Note, Converter={StaticResource StringToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding Note, Converter={StaticResource StripStatusTagConverter}}" Foreground="#666" TextWrapping="Wrap" FontSize="12"/>
                                                </StackPanel>

                                                <ItemsControl ItemsSource="{Binding ModifierDetailsForDisplay}" Margin="0,0,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,2,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="35"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="1" Text="{Binding DisplayText}" FontSize="12" Foreground="#333"/>
                                                                <TextBlock Grid.Column="0" Text="" FontSize="12" Foreground="#333"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding Price, Converter={StaticResource CurrencyFormatConverter}}" FontSize="12" FontWeight="SemiBold" Foreground="#666" HorizontalAlignment="Right"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Border x:Name="ItemsFadeOverlay" VerticalAlignment="Bottom" Height="60" IsHitTestVisible="False" Opacity="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                                    <GradientStop Color="#FFFFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <!-- Bottom Section (Totals and Primary Action Button) -->
                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                        <!-- Note Display -->
                        <Border Background="#F5F5F5" CornerRadius="8" Margin="0,2,0,0" Padding="2"
                              Visibility="{Binding HasNote, Converter={StaticResource BooleanToVisibilityConverter}}" Height="80">
                            <StackPanel>
                                <TextBlock Text="Note" FontWeight="Bold" FontSize="13" Margin="0,0,0,0"/>
                                <ScrollViewer Height="72" VerticalScrollBarVisibility="Auto" MaxWidth="350">
                                    <ScrollViewer.Resources>
                                        <!-- Apply thicker scrollbar style defined in Stylesxaml.xaml -->
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                                    </ScrollViewer.Resources>
                                    <TextBlock Text="{Binding OrderNote}" TextWrapping="Wrap" FontSize="12"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                        <!-- Totals Section -->
                        <Border Padding="5" Background="#EEEEEE" CornerRadius="8" Margin="0,5,0,5">
                            <StackPanel>
                                <!-- Sub Total -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Sub Total" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Grid.Column="1" Text="" FontSize="16"/>
                                    <TextBlock Grid.Column="2" Text="{Binding SubTotal, Converter={StaticResource CurrencyFormatConverter}}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Discount -->
                                <Grid Margin="0,0,0,4" 
                                    Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DiscountDescription}" Foreground="#FF5A5F" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="" FontSize="14"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DiscountAmount, Converter={StaticResource CurrencyFormatConverter}}" Foreground="#FF5A5F" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Voucher -->
                                <Grid Margin="0,0,0,4" 
                                    Visibility="{Binding HasVoucher, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding VoucherDescription}" Foreground="#FF5A5F" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="" FontSize="14"/>
                                    <TextBlock Grid.Column="2" Text="{Binding VoucherAmount, Converter={StaticResource CurrencyFormatConverter}}" Foreground="#FF5A5F" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Shop Fees -->
                                <ItemsControl ItemsSource="{Binding ShopFeeRows}" 
                                          Visibility="{Binding HasShopFees, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          Margin="0,0,0,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#666" FontWeight="Bold" FontSize="14"/>
                                                <TextBlock Grid.Column="1" Text="" FontSize="14"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Amount, Converter={StaticResource CurrencyFormatConverter}}" Foreground="#666" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Delivery Charges Row (for Webshop and others) -->
                                <Grid Margin="0,0,0,4" Visibility="{Binding HasDeliveryCharges, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Delivery Charges" Foreground="#666" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="" FontSize="14"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DeliveryCharges, Converter={StaticResource CurrencyFormatConverter}}" Foreground="#666" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Tax Details from API order_taxes -->
                                <ItemsControl Margin="0,4,0,4" ItemsSource="{Binding OrderTaxesFromApi}" 
                                              Visibility="{Binding HasOrderTaxesFromApi, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding TaxCode}" Foreground="#666" FontSize="14" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding TaxableAmount, Converter={StaticResource CurrencyFormatConverter}}" 
                                                           Foreground="#666" FontSize="14" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding TaxAmount, Converter={StaticResource CurrencyFormatConverter}}" 
                                                           Foreground="#666" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Tax Summary -->
                              <!--  <Grid Margin="0,4,0,8" Visibility="{Binding HasOrderTaxSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Tax Summary" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                                    <ItemsControl Grid.Row="1" Grid.ColumnSpan="3" ItemsSource="{Binding OrderTaxSummaryRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding TaxCode}" FontWeight="Bold"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding TaxableAmount, Converter={StaticResource CurrencyFormatConverter}}" HorizontalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding TaxAmount, Converter={StaticResource CurrencyFormatConverter}}" HorizontalAlignment="Right" FontWeight="Bold"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid> -->

                                <!-- Separator -->
                                <Separator Margin="0,8,0,8" Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <!-- Total -->
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Total" FontWeight="Bold" FontSize="18"/>
                                    <TextBlock Grid.Column="1" Text="" FontSize="18"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Total, Converter={StaticResource CurrencyFormatConverter}}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Kitchen Mode: Buttons (dynamic) -->
                        <StackPanel HorizontalAlignment="Center"
                                Visibility="{Binding IsKitchenMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <!-- First Row: Primary Action, Update Order, and Delay Order buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Height="40" Background="Black" Foreground="White" FontWeight="Bold" FontSize="16" BorderBrush="Transparent"
                                         Content="{Binding PrimaryActionText}" Padding="10,5" VerticalAlignment="Center"
                                         Command="{Binding PrimaryActionCommand}" Width="180" Margin="0,0,10,0"/>
                                </StackPanel>
                                <!-- Update Order button only for Dine In orders -->
                                <Button Height="40" Background="#2196F3" Foreground="White" FontWeight="Bold" FontSize="16" BorderBrush="Transparent"
                                     Content="Update Order" Command="{Binding UpdateOrderCommand}" VerticalAlignment="Center"
                                     Margin="0,0,10,0"
                                     Visibility="{Binding ShowKitchenUpdateOrderButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <!-- Delay Order button only for accepted Uber Eats orders -->
                                <Button Height="40" Background="#1976D2" Foreground="White" FontWeight="Bold" FontSize="16" BorderBrush="Transparent"
                                     Content="Delay Order" Command="{Binding DelayOrderCommand}" VerticalAlignment="Center"
                                     Width="120" Margin="0,0,0,0"
                                     Visibility="{Binding ShowDelayOrderButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowDelayOrderButton}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FFB74D"/>
                                                    <Setter Property="Foreground" Value="Black"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- Second Row: Move to Preparing button (PrimaryActionText) -->
                            <!--<Button Height="40" Background="#FFD32F2F" Foreground="White" FontWeight="Bold" FontSize="16" BorderBrush="Transparent"
                                Content="Cancel Order" Padding="10,5"
                                Command="{Binding CancelOrderCommand}"
                                Width="120" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanCancel}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFFB9090"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>-->
                        </StackPanel>

                        <!-- Tables Mode: Finish + Update (Update hidden for Table Orders) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding IsTablesMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button Content="Finish Order" Height="40" Background="#FF5722" Foreground="White" FontWeight="Bold" FontSize="16" 
                                 BorderBrush="Transparent" Command="{Binding FinishOrderCommand}" Padding="10,5"
                                 Width="160" Margin="0,0,8,0"/>
                            <Button Content="Update Order" Height="40" Background="#2196F3" Foreground="White" FontWeight="Bold" FontSize="16" 
                                 BorderBrush="Transparent" Command="{Binding UpdateOrderCommand}" Padding="10,5"
                                 Width="160" Margin="0,0,0,0"
                                 Visibility="{Binding ShowTablesUpdateOrderButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- View Only Mode: Refund Order button only -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                Visibility="{Binding IsViewOnlyMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Height="40" Background="#1976D2" Foreground="White" FontWeight="Bold" FontSize="16" BorderBrush="Transparent"
                                    Content="Refund Order" Command="{Binding RefundOrderCommand}" Padding="10,5"
                                    Width="160"
                                    Visibility="{Binding IsPaidForRefund, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- Live Orders Mode: Complete (when paid) or Payment (when unpaid) for PlatformId 9 only -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0"
                                Visibility="{Binding IsLiveOrdersMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Content="Ready" Height="40" Background="#FFBF00" Foreground="White" FontWeight="Bold" FontSize="16"
                                        BorderBrush="Transparent" Command="{Binding ReadyOrderLiveOrdersCommand}" Padding="10,5"
                                        Width="140" Margin="0,0,8,0"
                                        Visibility="{Binding ShowreadyButtonLiveOrders, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <Button Content="Complete" Height="40" Background="#1EA41E" Foreground="White" FontWeight="Bold" FontSize="16"
                                        BorderBrush="Transparent" Command="{Binding PaymentOrderLiveOrdersCommand}" Padding="10,5"
                                        Width="140" Margin="0,0,8,0"
                                        Visibility="{Binding ShowCompleteButtonLiveOrders, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <!-- Update Order button only for Dine In orders -->
                            <Button Height="40" Background="#2196F3" Foreground="White" FontWeight="Bold" FontSize="16" BorderBrush="Transparent"
                                    Content="Update Order" Command="{Binding UpdateOrderCommand}" VerticalAlignment="Center"
                                    Margin="0,0,10,0"
                                    Visibility="{Binding LiveOrdersUpdateOrderButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <Button Content="Pay &amp; Complete" Height="40" Background="#D32F2F" Foreground="White" FontWeight="Bold" FontSize="16"
                                        BorderBrush="Transparent" Command="{Binding PaymentOrderLiveOrdersCommand}" Padding="10,5"
                                        Width="145" Margin="0,0,0,0"
                                        Visibility="{Binding ShowPaymentButtonLiveOrders, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Loading Overlay -->
                <Grid Grid.ColumnSpan="2" 
                  Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" 
                  Background="Transparent">
                    <controls:LoadingIndicator HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" 
                                           ProgressRingSize="70"/>
                </Grid>

                 <!-- Dimming Overlay for Kitchen Order Details Dialog -->
            <Grid Grid.ColumnSpan="2" Margin="-10"
                      Visibility="{Binding IsDimmed, Converter={StaticResource BooleanToVisibilityConverter}}" 
                      Background="#80000000">
                <!-- Semi-transparent black overlay -->
            </Grid>

        </Grid>
        
    </Border>
    <!--</ScrollViewer>-->
</view:OptimizedDialogBase> 