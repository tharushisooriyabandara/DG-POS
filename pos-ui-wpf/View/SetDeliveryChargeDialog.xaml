<UserControl x:Class="POS_UI.View.SetDeliveryChargeDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400">
    <Border Background="White" CornerRadius="16" Padding="32" MinWidth="400">
        <StackPanel>
            <TextBlock Text="Set Delivery Charge" FontWeight="Bold" FontSize="26" Margin="0,0,0,16"/>
            <TextBlock Text="Quick Amount" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,16">
                <Button Content="2.00" Width="90" Height="35" Margin="0,0,8,0" FontSize="16" Tag="2" Click="QuickAmount_Click"/>
                <Button Content="5.00" Width="90" Height="35" Margin="0,0,8,0" FontSize="16" Tag="5" Click="QuickAmount_Click"/>
                <Button Content="10.00" Width="90" Height="35" FontSize="16" Tag="10" Click="QuickAmount_Click"/>
            </StackPanel>
            <TextBox x:Name="CustomAmountTextBox" Width="320" Height="40" FontSize="16" VerticalAlignment="Center" 
                     materialDesign:HintAssist.Hint="Custom Delivery Charge"
                     Padding="8,8,0,0"
                     BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,0,24"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="CancelButton" Content="Cancel" Width="100" Height="36" Style="{StaticResource MaterialDesignOutlinedButton}" Click="CancelButton_Click" Margin="0,0,10,0"/>
                <Button x:Name="SaveButton" Content="Save" Width="100" Height="36" Background="#1976D2" Foreground="White" FontWeight="Bold" Click="SaveButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl> 