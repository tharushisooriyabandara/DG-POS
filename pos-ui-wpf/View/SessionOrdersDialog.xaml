<UserControl x:Class="POS_UI.View.SessionOrdersDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:POS_UI.Converters"
             xmlns:controls="clr-namespace:POS_UI.View.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="450">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Border Background="White" CornerRadius="10" Padding="5" Width="430">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Close Button -->
            <Button Grid.Row="0" 
                    Command="{Binding CloseCommand}" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Style="{StaticResource MaterialDesignToolButton}" 
                    Background="Transparent" 
                    BorderBrush="Transparent" 
                    Width="30" Height="30" 
                    Margin="0,0,0,-10">
                <materialDesign:PackIcon Kind="Close" Width="24" Height="24"/>
            </Button>

            <!-- Title -->
            <TextBlock Grid.Row="1" 
                       Text="Order Details" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>

            <!-- Order Status, Payment Status, Session Status -->
            <StackPanel Grid.Row="2" Margin="0,0,0,15" HorizontalAlignment="Center">
                <TextBlock Margin="0,0,0,5">
                    <Run Text="Order: " FontWeight="Normal" FontSize="13"/>
                    <Run Text="{Binding OrderStatus}" FontWeight="Bold" FontSize="13"/>
                </TextBlock>
                <TextBlock Margin="0,5,0,5">
                    <Run Text="Payment: " FontWeight="Normal" FontSize="13"/>
                    <Run Text="{Binding PaymentStatus}" FontWeight="Bold" FontSize="13"/>
                </TextBlock>
                <TextBlock Margin="0,5,0,0">
                    <Run Text="Session: " FontWeight="Normal" FontSize="13"/>
                    <Run Text="{Binding SessionStatus}" FontWeight="Bold" FontSize="13"/>
                </TextBlock>
            </StackPanel>

            <!-- Order Items List -->
            <ScrollViewer Grid.Row="3" 
                         VerticalScrollBarVisibility="Auto" 
                         MaxHeight="250" 
                         Margin="0,0,0,10">
                <ItemsControl ItemsSource="{Binding OrderDetails}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0" 
                                   BorderThickness="0,0,0,1" 
                                   Padding="0,8,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    
                                        <TextBlock Text="{Binding DisplayOrderId}" Grid.Column="0"
                                                  FontWeight="SemiBold" Margin="20,0,0,0"
                                                  FontSize="15"/>
                                        <TextBlock Text="{Binding Status}" Grid.Column="1"
                                                  FontSize="14" 
                                                  Margin="0,0,20,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="Orange"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Ready for pickup">
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Ready For Pickup">
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="COMPLETED">
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="ACCEPTED">
                                                            <Setter Property="Foreground" Value="Orange"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Accepted">
                                                            <Setter Property="Foreground" Value="Orange"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Preparing">
                                                            <Setter Property="Foreground" Value="Orange"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="PREPARING">
                                                            <Setter Property="Foreground" Value="Orange"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    
                                    
                                    <!--<Button Grid.Column="1" 
                                           Style="{StaticResource MaterialDesignIconButton}" 
                                           Width="32" 
                                           Height="32" 
                                           Margin="10,0,0,0"
                                           Background="#4CAF50"
                                           Foreground="White"
                                           Padding="0">
                                        <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20"/>
                                    </Button>-->
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Total Amount -->
            <Border Grid.Row="4" 
                   Background="#F5F5F5" 
                   CornerRadius="8" 
                   Padding="10" 
                   Margin="10,0,10,0">
                <Grid
                    Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" 
                              Text="Total Amount:" 
                              FontSize="16" 
                              FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" 
                              FontSize="18" 
                              FontWeight="Bold" 
                              Foreground="#4CAF50">
                        
                        <Run Text="{Binding TotalAmount,Converter={StaticResource CurrencyFormatConverter}}"/>
                    </TextBlock>
                </Grid>
            </Border>


            <!-- Next Button -->
            <StackPanel Grid.Row="5">
                <!-- Warning Message -->
                <TextBlock Text="Some items are not yet ready for pickup."
                           Foreground="Red" Margin="0,5,0,5"
                           FontSize="11" FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Visibility="{Binding ShowWarningMessage, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <Button  
                           Content="{Binding NextButtonText}" 
                           Height="45" 
                           Background="#4CAF50" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           BorderThickness="0"
                           Margin="10,5,10,5"
                           Command="{Binding NextCommand}"
                           HorizontalAlignment="Stretch"/>  
            </StackPanel>
            

            <!-- Loading Overlay -->
            <!--<Grid Grid.RowSpan="6" 
                  Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" 
                  Background="#80000000">
                <controls:LoadingIndicator HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" 
                                           ProgressRingSize="50"/>
            </Grid>-->
        </Grid>
    </Border>
</UserControl>

