<view:OptimizedDialogBase x:Class="POS_UI.View.EditCustomerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:POS_UI.Converters"
             xmlns:controls="clr-namespace:POS_UI.View.Controls"
             xmlns:view="clr-namespace:POS_UI.View"
             mc:Ignorable="d"
              d:DesignHeight="800" d:DesignWidth="600"
              MinWidth="580" MinHeight="600">
    
    <view:OptimizedDialogBase.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertBooleanConverter x:Key="InvertBooleanConverter"/>
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
    </view:OptimizedDialogBase.Resources>

    <materialDesign:DialogHost Identifier="EditCustomerDialogHost" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
    <Grid Background="White" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1976D2" CornerRadius="8,8,0,0" Padding="20,15">
            <DockPanel>
                <TextBlock Text="Edit Customer" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <Button DockPanel.Dock="Right" Width="32" Height="32" HorizontalAlignment="Right" Foreground="Black" VerticalAlignment="Center" Style="{StaticResource MaterialDesignToolButton}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" ToolTip="Close" >
                    <materialDesign:PackIcon Kind="Close" Width="25" Height="25" Foreground="Black" FontWeight="Bold"/>
                </Button>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <!-- Loading Overlay -->
            <controls:LoadingIndicator HorizontalAlignment="Center" 
                          VerticalAlignment="Center" 
                          ProgressRingSize="70"
                          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                <ScrollViewer.Resources>
                    <!-- Apply thicker scrollbar style defined in Stylesxaml.xaml -->
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                </ScrollViewer.Resources>
                <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" HorizontalAlignment="Left" Margin="20">
                
                    <StackPanel>
                        <!-- Basic Information -->
                        <TextBlock Text="Basic Information" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1976D2"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- First Name -->
                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,10,0" >
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="First Name" FontWeight="SemiBold" Margin="0,0,0,5"  FontSize="13"/>
                                    <TextBlock Text=" *" Foreground="Red"/>
                                </StackPanel>
                                <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="13"
                                 materialDesign:HintAssist.Hint="Enter first name"/>
                            </StackPanel>

                            <!-- Last Name -->
                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Last Name" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="13"/>
                                    <TextBlock Text=" *" Foreground="Red"/>
                                </StackPanel>
                                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="13"
                                 materialDesign:HintAssist.Hint="Enter last name"/>
                            </StackPanel>

                            <!-- Country Code -->
                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,10,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Country Code" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="13"/>
                                    <TextBlock Text=" *" Foreground="Red"/>
                                </StackPanel>
                                <TextBox Text="{Binding CountryCode, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="13"
                                 materialDesign:HintAssist.Hint="+94"/>
                            </StackPanel>

                            <!-- Phone -->
                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="10,10,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Phone Number" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="13"/>
                                    <TextBlock Text=" *" Foreground="Red"/>
                                </StackPanel>
                                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="13"
                                 materialDesign:HintAssist.Hint="Enter phone number"/>
                            </StackPanel>
                        </Grid>

                        <!-- Addresses -->
                        <TextBlock Text="Addresses" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1976D2"/>

                        <!-- Show Add button if no addresses -->


                        <ItemsControl ItemsSource="{Binding Addresses}"
                                      Visibility="{Binding HasAnyAddress, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15" Padding="10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Address Header -->
                                            <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="Address" FontWeight="Bold" FontSize="14"/>

                                                <Button Grid.Column="2" 
                                                Command="{Binding DataContext.RemoveAddressCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                FontSize="12" BorderBrush="Transparent"
                                                Background="White">
                                                    <materialDesign:PackIcon Kind="Bin" Foreground="Red" Height="24" Width="24"/>
                                                </Button>
                                            </Grid>

                                            <!-- Label -->
                                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,10,0">
                                                <TextBlock Text="Label" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 materialDesign:HintAssist.Hint="Home, Work, etc."/>
                                            </StackPanel>

                                            <!-- Flat No -->
                                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="10,0,0,0">
                                                <TextBlock Text="Flat No" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding FlatNo, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 materialDesign:HintAssist.Hint="Flat number"/>
                                            </StackPanel>

                                            <!-- Address Line 1 -->
                                            <StackPanel Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Address Line 1" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                                    <TextBlock Text=" *" Foreground="Red"/>
                                                </StackPanel>
                                                <TextBox Text="{Binding AddressLine1, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 materialDesign:HintAssist.Hint="Street address"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Add New Address Section -->
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,20" Padding="10"
                                Visibility="{Binding ShowNewAddressForm, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- New Address Header -->
                                <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="Add New Address" FontWeight="Bold" FontSize="16" Foreground="#1976D2"/>
                                    
                                </Grid>

                                <!-- Label -->
                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Label" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <TextBlock Text=" *" Foreground="Red" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding NewAddress.Label, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Home, Work, etc."/>
                                </StackPanel>

                                <!-- Flat No -->
                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="10,0,0,0">
                                    <TextBlock Text="Flat No" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding NewAddress.FlatNo, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Flat number"/>
                                </StackPanel>

                                <!-- Address Line 1 with Google Places autocomplete -->
                                <Grid Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                                        <TextBlock Text="Address Line 1" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <TextBlock Text=" *" Foreground="Red" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBox x:Name="NewAddressSearchBox" Grid.Row="0"
                                                 Text="{Binding PlaceSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="32" VerticalContentAlignment="Center" FontSize="13"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" Background="White"
                                                 materialDesign:HintAssist.Hint="Type at least 3 characters to search"
                                                 materialDesign:HintAssist.Foreground="#757575"
                                                 materialDesign:HintAssist.IsFloating="False"/>
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"
                                                Command="{Binding ClearPlaceSearchCommand}"
                                                Visibility="{Binding PlaceSearchText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"
                                                Style="{StaticResource MaterialDesignToolButton}"
                                                Background="Transparent" BorderBrush="Transparent" Width="26" Height="26">
                                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14" Foreground="#666"/>
                                        </Button>
                                    </Grid>
                                    <Popup PlacementTarget="{Binding ElementName=NewAddressSearchBox}"
                                           Placement="Bottom"
                                           StaysOpen="False"
                                           IsOpen="{Binding ArePredictionsVisible, Mode=OneWay}">
                                        <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4"
                                                Width="{Binding ElementName=NewAddressSearchBox, Path=ActualWidth}">
                                            <ListBox ItemsSource="{Binding PlacePredictions}"
                                                     SelectedItem="{Binding SelectedPrediction, Mode=TwoWay}"
                                                     MaxHeight="240">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Padding="8,6" TextWrapping="Wrap"/>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <Button Grid.Column="1" Content="Save Address" Grid.Row="3" HorizontalAlignment="Right"
                                Command="{Binding SaveNewAddressCommand}"
                                Background="#4CAF50" Foreground="White" VerticalAlignment="Center"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Padding="15,8" BorderBrush="Transparent" Margin="0,10,0,0"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBooleanConverter}}"/>
                            </Grid>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10"
                                Visibility="{Binding HasAnyAddress, Converter={StaticResource InvertBooleanConverter}, ConverterParameter=ToVisibility}">
                            <Button Content="Add New Address" Foreground="#4CAF50" BorderBrush="#4CAF50" BorderThickness="2"
                                        Command="{Binding AddAddressCommand}" FontWeight="SemiBold" FontSize="14"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
            
        </Grid>
        <!-- Footer -->
        <Border Grid.Row="2"  CornerRadius="0,0,8,8" Padding="5,0">
            <Grid HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancel" 
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,10,0"
                        Padding="20,8"/>

                <Button Grid.Column="1" Content="Update Customer" 
                        Command="{Binding UpdateCustomerCommand}"
                        Background="#1976D2" Foreground="White"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Padding="20,5" 
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBooleanConverter}}"/>
            </Grid>
        </Border>
    </Grid>
    </materialDesign:DialogHost>
</view:OptimizedDialogBase>
