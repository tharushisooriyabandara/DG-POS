<Window x:Class="POS_UI.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Settings" 
        Height="434" 
        Width="406"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Grid Margin="20,10,20,-3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="272"/>
            <RowDefinition Height="Auto"  />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Configuration Settings" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Configure your system settings" 
                       FontSize="12" 
                       Foreground="#666" 
                       HorizontalAlignment="Center" 
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Settings Fields -->
        <StackPanel Grid.Row="1" Margin="0,10,0,0" Height="266" VerticalAlignment="Top" Grid.RowSpan="2">
            <TextBlock Text="Tenant Code" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,5" Height="22"/>
            <TextBox x:Name="TenantCodeTextBox" 
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="Enter tenant code"
                     Margin="0,0,0,15"
                     Height="50"
                     Foreground="Black"
                     Background="White"
                     IsEnabled="True"
                     Focusable="True"/>

            <TextBlock Text="Outlet Code" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,5" Height="22"/>
            <TextBox x:Name="OutletCodeTextBox" 
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="Enter outlet code"
                     Margin="0,0,0,15"
                     Height="51"
                     Foreground="Black"
                     Background="White"
                     IsEnabled="True"
                     Focusable="True"/>

            <TextBlock Text="Brand ID" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,5"/>
            <TextBox x:Name="BrandIdTextBox" 
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="Enter brand ID"
                     Margin="0,0,0,0"
                     Height="51"
                     Foreground="Black"
                     Background="White"
                     IsEnabled="True"
                     Focusable="True"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Margin="0,0,0,51" Width="170">
            <Button x:Name="CancelButton" 
                    Content="Cancel" 
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="80" 
                    Height="35" 
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" 
                    Content="Save" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Width="80" 
                    Height="35"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window> 