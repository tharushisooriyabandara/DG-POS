<view:OptimizedDialogBase x:Class="POS_UI.View.DraftsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:POS_UI.Converters"
             xmlns:view="clr-namespace:POS_UI.View"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <view:OptimizedDialogBase.Resources>
        <Style x:Key="DraftCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="Gray" Direction="270" ShadowDepth="2" BlurRadius="5" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </view:OptimizedDialogBase.Resources>
    <Border Background="White" BorderBrush="Transparent" BorderThickness="2" CornerRadius="20" Padding="16,16,16,16" MinHeight="140" MinWidth="470">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0">
                        <TextBlock Text="Drafts" FontWeight="Bold" FontSize="24" Margin="0,0,0,8"/>
                        <Button DockPanel.Dock="Right" Width="32" Height="38" HorizontalAlignment="Right" VerticalAlignment="Top"  Background="Transparent" BorderBrush="Transparent" Style="{StaticResource MaterialDesignToolButton}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}">
                            <materialDesign:PackIcon Kind="close" Width="26" Height="26" Foreground="Black"/>
                        </Button>
                    </DockPanel>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" CanContentScroll="False" Padding="16,16,16,16">
                <ScrollViewer.Resources>
                    <!-- Apply thicker scrollbar style defined in Stylesxaml.xaml -->
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                </ScrollViewer.Resources>
                <StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <!-- Tickets Section -->
                        <TextBlock Text="{Binding TicketsDrafts.Count, StringFormat='Tickets ({0})'}" FontWeight="Bold" FontSize="16" Margin="10,0,0,8" 
                           Visibility="{Binding HasTicketsDrafts, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <ItemsControl ItemsSource="{Binding TicketsDrafts}" Margin="0,0,0,16"
                             Visibility="{Binding HasTicketsDrafts, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True" HorizontalAlignment="Left"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8">
                                        <!-- Card -->
                                        <Grid>
                                            <Border Style="{StaticResource DraftCardStyle}" Width="195" Height="77" 
                                            MouseLeftButtonDown="Border_MouseLeftButtonDown"
                                            ToolTip="Click to load this draft order">
                                                <Grid Margin="10,5,10,5" VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Vertical" Grid.Column="0">
                                                        <TextBlock Text="{Binding CustomerName}" FontWeight="Bold" FontSize="15" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding ElapsedTimeText}" FontSize="11" Foreground="Gray" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Amount, Converter={StaticResource CurrencyFormatConverter}}" FontWeight="Bold" FontSize="15" Grid.Column="1" VerticalAlignment="Top" Margin="8,0,0,0"/>
                                                </Grid>
                                            </Border>
                                            <!-- Transparent button overlay for better click handling -->
                                            <Button Background="Transparent" BorderBrush="Transparent" 
                                            Command="{Binding DataContext.LoadDraftCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            />
                                        </Grid>
                                        <!-- Floating Delete Button -->
                                        <Button Width="28" Height="25" Background="Red" BorderBrush="Transparent" Cursor="Hand" ToolTip="Remove"
                                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0"
                                        Command="{Binding DataContext.DeleteDraftCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                            <Button.Resources>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="14.5">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Resources>
                                            <materialDesign:PackIcon Kind="Minus" Width="20" Height="20" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Tables Section -->
                        <TextBlock Text="{Binding TablesDrafts.Count, StringFormat='Tables ({0})'}" FontWeight="Bold" FontSize="16" Margin="10,0,0,8"
                           Visibility="{Binding HasTablesDrafts, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <ItemsControl ItemsSource="{Binding TablesDrafts}"
                             Visibility="{Binding HasTablesDrafts, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True" HorizontalAlignment="Left"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8">
                                        <!-- Card -->
                                        <Grid>
                                            <Border Style="{StaticResource DraftCardStyle}" Width="195" Height="77" 
                                            MouseLeftButtonDown="Border_MouseLeftButtonDown"
                                            ToolTip="Click to load this draft order">
                                                <Grid Margin="10,5,10,5" VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Text="{Binding CustomerName}" Grid.Column="0" FontWeight="Bold" FontSize="15" TextWrapping="Wrap"/>
                                                        <Grid Margin="0,2,0,0" Grid.Row="1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding ElapsedTimeText}" FontSize="11" Foreground="Gray" Grid.Column="0"/>
                                                            <TextBlock Text="{Binding DisplayTableLabel, StringFormat='Table {0}'}" FontSize="12" Foreground="Black" Grid.Column="1" Visibility="{Binding DisplayTableLabel, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                        </Grid>

                                                    <TextBlock Grid.Row="0" Text="{Binding Amount, Converter={StaticResource CurrencyFormatConverter}}" FontWeight="Bold" FontSize="15" Grid.Column="1" VerticalAlignment="Top" Margin="8,0,0,0"/>
                                                </Grid>
                                            </Border>
                                            <!-- Transparent button overlay for better click handling -->
                                            <Button Background="Transparent" BorderBrush="Transparent" 
                                            Command="{Binding DataContext.LoadDraftCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            />
                                        </Grid>
                                        <!-- Floating Delete Button -->
                                        <Button Width="28" Height="25" Background="Red" BorderBrush="Transparent" Cursor="Hand" ToolTip="Remove"
                                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0"
                                        Command="{Binding DataContext.DeleteDraftCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                            <Button.Resources>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="14.5">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Resources>
                                            <materialDesign:PackIcon Kind="Minus" Width="20" Height="20" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Spacer to avoid content being flush with the bottom when scrolled -->
                        <Border Height="8" Background="Transparent"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            
            <!-- No Drafts Message -->
            <TextBlock Text="No draft orders available" Grid.Row="1"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       FontSize="17" 
                       Foreground="Gray" Margin="0,0,0,0"
                       Visibility="{Binding HasDrafts, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=False}"/>
        </Grid>
    </Border>
</view:OptimizedDialogBase>
