<UserControl x:Class="POS_UI.View.SplitPaymentDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:POS_UI.ViewModels"
             xmlns:converters="clr-namespace:POS_UI.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="510" d:DesignWidth="450">
    <UserControl.Resources>
        <converters:PaymentMethodDisplayConverter x:Key="PaymentMethodDisplayConverter" />
        <converters:InvertBooleanConverter x:Key="InvertBooleanConverter" />
        <converters:BooleanToStringConverter x:Key="BooleanToStringConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Border Background="White" CornerRadius="12" Padding="10,20" MinWidth="420" MaxWidth="420">
        <StackPanel>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Split Payment" FontWeight="Bold" FontSize="22" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Command="{Binding CancelCommand}" Style="{StaticResource MaterialDesignToolButton}" Margin="-20,-10,0,0"
                        Background="Transparent" BorderBrush="Transparent" ToolTip="Close">
                    <materialDesign:PackIcon Kind="Close" Width="25" Height="25" Foreground="#666"/>
                </Button>
            </Grid>
            <TextBlock Text="{Binding TotalFormatted, StringFormat='Total: {0}'}" FontSize="16" FontWeight="SemiBold" Foreground="#1976D2" Margin="0,0,0,5"/>
            <TextBlock Text="{Binding BalanceMessage}" FontWeight="Medium" Foreground="#424242" Margin="0,3,0,0" FontSize="13"
                       x:Name="BalanceText"/>
            <Border Visibility="{Binding HasExistingTempPayments, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="#E8F4FD" BorderBrush="#90CAF9" BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Already recorded" FontWeight="SemiBold" Foreground="#1565C0" Margin="0,0,0,6" FontSize="13"/>
                    <ItemsControl ItemsSource="{Binding ExistingTempPayments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ExistingTempPaymentLine}">
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding PaymentMode}" FontWeight="Medium" Foreground="#424242" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding AmountFormatted}" FontWeight="SemiBold" Foreground="#1976D2" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            <Border CornerRadius="5" BorderBrush="Red" BorderThickness="1"
                    Visibility="{Binding ShowSplitPaymentEditor, Converter={StaticResource BooleanToVisibilityConverter},ConverterParameter=False}"
                    Padding="5" Margin="0,0,0,10">
                <TextBlock Text="All payments are complete. Click 'Confirm' to place the order." FontSize="14" FontWeight="SemiBold" Foreground="Red"/>
            </Border>
            <StackPanel Visibility="{Binding ShowSplitPaymentEditor, Converter={StaticResource BooleanToVisibilityConverter}}">
                <!-- +/- Payments control -->
                <Border Background="Transparent" CornerRadius="8" Padding="16,2" Margin="0,0,0,12" HorizontalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding DecreaseSplitsCommand}" Width="55" Height="40" Padding="5"
                                Style="{StaticResource MaterialDesignRaisedButton}" Background="#1976D2" Foreground="White"
                                ToolTip="Decrease number of payments" Margin="0,0,40,0">
                            <materialDesign:PackIcon Kind="Minus" Width="24" Height="24"/>
                        </Button>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SplitCount}" FontSize="29" FontWeight="SemiBold" Foreground="Black" HorizontalAlignment="Center"/>
                            <TextBlock Text="Payments" FontSize="14" Foreground="Black" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="2" Command="{Binding IncreaseSplitsCommand}" Width="55" Height="40" Padding="5"
                                Style="{StaticResource MaterialDesignRaisedButton}" Background="#1976D2" Foreground="White"
                                ToolTip="Increase number of payments" Margin="40,0,0,0">
                            <materialDesign:PackIcon Kind="Plus" Width="24" Height="24"/>
                        </Button>
                    </Grid>
                </Border>
                <TextBlock Text="Payment splits" FontWeight="Medium" Foreground="#424242" Margin="0,0,0,6" FontSize="13"/>
                <ScrollViewer MaxHeight="270" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                    <ItemsControl ItemsSource="{Binding Splits}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SplitPaymentRowViewModel}">
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="5,10" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Command="{Binding DataContext.RemoveSplitCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" Style="{StaticResource MaterialDesignToolButton}" Margin="0,0,10,0"
                                                Background="Transparent" BorderBrush="Transparent" Foreground="#D32F2F" ToolTip="Remove split"
                                                IsEnabled="{Binding IsCharged, Converter={StaticResource InvertBooleanConverter}}">
                                            <materialDesign:PackIcon Kind="Delete" Width="25" Height="25"/>
                                        </Button>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding DataContext.PaymentMethodOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding PaymentMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Margin="0,0,8,0" Height="36" VerticalContentAlignment="Center"
                                                IsEnabled="{Binding IsCharged, Converter={StaticResource InvertBooleanConverter}}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource PaymentMethodDisplayConverter}}" FontSize="13"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBox Grid.Column="2" Text="{Binding AmountString, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" Padding="6,4" Height="36" FontSize="14"
                                                 VerticalContentAlignment="Center" FontWeight="SemiBold" Margin="0,0,6,0"
                                                 IsEnabled="{Binding IsCharged, Converter={StaticResource InvertBooleanConverter}}"/>
                                        <Button Grid.Column="3" Command="{Binding DataContext.ChargeSplitCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" Content="{Binding IsCharged, Converter={StaticResource BooleanToStringConverter}, ConverterParameter=✔ Paid|Charge}"
                                                Height="36" MinWidth="85" Padding="10,0" ToolTip="Store this payment">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCharged}" Value="True">
                                                            <Setter Property="Background" Value="White"/>
                                                            <Setter Property="Foreground" Value="#FF18AC1F"/>
                                                            <Setter Property="BorderBrush" Value="#FF18AC1F"/>
                                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"
                        Width="100" Height="40" Margin="0,0,10,0"/>
                <Button Content="Confirm" Command="{Binding ConfirmCommand}" Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#1976D2" Foreground="White" Width="100" Height="40"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
