<UserControl x:Class="POS_UI.View.CashDrawerAccessDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:POS_UI.View.Controls"
             xmlns:local="clr-namespace:POS_UI.Converters"
             mc:Ignorable="d" Width="400" Height="580"
             MinHeight="480">
    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </UserControl.Resources>
    <Border Background="White" BorderBrush="Transparent" BorderThickness="2" CornerRadius="12" Padding="10,10,10,0">
        <StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Cash Drawer Access" FontSize="20" FontWeight="Bold" Foreground="#1976D2"/>
                <Button Grid.Column="1" DockPanel.Dock="Right" Width="32" Height="32"  Margin="0,-10,-10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource MaterialDesignToolButton}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" ToolTip="Close" Background="Transparent" BorderBrush="Transparent">
                    <materialDesign:PackIcon Kind="Close" Width="25" Height="25"/>
                </Button>
            </Grid>
            
            <!-- User Selection (only visible for cashier) -->
            <TextBlock Text="Select Admin User" 
                      Margin="0,10,0,8" 
                      FontWeight="SemiBold" 
                      FontSize="14" 
                      Foreground="#333"
                      Visibility="{Binding ShowUserSelection, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Grid Height="50" Margin="0,0,0,0" Visibility="{Binding ShowUserSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <!-- Loading Indicator -->
                <controls:LoadingIndicator HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" 
                                           ProgressRingSize="40" 
                                           Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <!-- User ComboBox -->
                <ComboBox x:Name="UserComboBox" 
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                          Background="White" 
                          BorderBrush="#E9ECEF"
                          BorderThickness="1"
                          Height="48" 
                          Width="330"
                          Padding="12,4,8,4"
                          VerticalContentAlignment="Center"
                          MaxDropDownHeight="260"
                          PreviewMouseDown="UserComboBox_PreviewMouseDown"
                          DropDownOpened="UserComboBox_DropDownOpened"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="False"
                          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=False}">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignComboBox}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBox">
                                        <Grid>
                                            <Border x:Name="border" 
                                                    Background="#F8F9FA"
                                                    BorderBrush="#E9ECEF"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter x:Name="contentPresenter"
                                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                                      Margin="0"
                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      IsHitTestVisible="False"/>
                                                    <ToggleButton x:Name="toggleButton"
                                                                  Grid.Column="1"
                                                                  Width="32" Height="32"
                                                                  Margin="0"
                                                                  VerticalAlignment="Center"
                                                                  Background="Transparent"
                                                                  BorderBrush="Transparent"
                                                                  BorderThickness="0"
                                                                  FocusVisualStyle="{x:Null}"
                                                                  IsTabStop="False"
                                                                  Panel.ZIndex="10"
                                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                  ClickMode="Press"
                                                                  Cursor="Hand">
                                                        <ToggleButton.Template>
                                                            <ControlTemplate TargetType="ToggleButton">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </ControlTemplate>
                                                        </ToggleButton.Template>
                                                        <materialDesign:PackIcon Kind="ChevronDown" Width="22" Height="22" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    </ToggleButton>
                                                </Grid>
                                            </Border>
                                            <Popup x:Name="PART_Popup"
                                                   AllowsTransparency="True"
                                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                                   Placement="Bottom"
                                                   PopupAnimation="Slide">
                                                <Border x:Name="dropDownBorder"
                                                        Background="White"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="0"
                                                        CornerRadius="8"
                                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                        MinWidth="{TemplateBinding ActualWidth}">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="Black" 
                                                                         Opacity="0.1" 
                                                                         BlurRadius="8" 
                                                                         ShadowDepth="2" 
                                                                         Direction="270"/>
                                                    </Border.Effect>
                                                    <Grid>
                                                        <ScrollViewer x:Name="ItemsScrollViewer"
                                                                      Margin="4,6,4,6" 
                                                                      SnapsToDevicePixels="True"
                                                                      VerticalScrollBarVisibility="Auto"
                                                                      HorizontalScrollBarVisibility="Disabled"
                                                                      CanContentScroll="False">
                                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                                        </ScrollViewer>
                                                        <Border x:Name="EmptyPlaceholder" Visibility="Collapsed" Margin="8" Background="#FFF" CornerRadius="6" BorderThickness="0">
                                                            <TextBlock Text="No admin users found" Foreground="#666" FontWeight="SemiBold" Padding="8"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="HasItems" Value="False">
                                                <Setter TargetName="ItemsScrollViewer" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="EmptyPlaceholder" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.Style>
                    <ComboBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel IsVirtualizing="True"
                                                    VirtualizationMode="Recycling"
                                                    ScrollUnit="Pixel"/>
                        </ItemsPanelTemplate>
                    </ComboBox.ItemsPanel>
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="False"/>
                            <Setter Property="Stylus.IsTapFeedbackEnabled" Value="False"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                                <Grid Width="40" Height="40" VerticalAlignment="Center">
                                    <Ellipse Fill="#90CAF9"/>
                                    <TextBlock Text="{Binding Initials}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontWeight="Bold"
                                               FontSize="18"
                                               Foreground="White"
                                               TextAlignment="Center"/>
                                </Grid>
                                <StackPanel Margin="8,0,0,0" Width="220">
                                    <TextBlock Text="{Binding FullName}" 
                                               FontWeight="Bold" 
                                               FontSize="16"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                    <TextBlock Text="{Binding Role}" 
                                               FontSize="12" 
                                               Foreground="#888"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <TextBlock Text="Enter your PIN " 
                          Margin="0,10,0,2" 
                          FontWeight="SemiBold" 
                          FontSize="14" 
                          Foreground="#333"
                          Visibility="{Binding ShowUserSelection, Converter={StaticResource BooleanToVisibilityConverter},ConverterParameter=false}"/>
            <!-- PIN Input Field -->
            <ItemsControl ItemsSource="{Binding PinBoxes}" Margin="0,10,0,8" HorizontalAlignment="Center" Width="Auto">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBox Style="{StaticResource PinTextBoxStyle}" 
                                 Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="1"
                                 PreviewTextInput="NumberValidationTextBox"
                                 materialDesign:HintAssist.Hint="*" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <!-- Error Message -->
            <Border Background="Red" CornerRadius="4" Padding="8,4" Margin="0,0,0,0" Width="300"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Grid.Column="0"
                               Foreground="White" 
                               FontWeight="Bold"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button Grid.Column="1"
                            Width="30" Height="20"
                            Margin="8,0,0,0" Padding="0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Command="{Binding ClearErrorCommand}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="20" Height="15" Foreground="White" Margin="0,0,0,0"/>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Number Pad -->
            <UniformGrid Rows="4" Columns="3" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Button Content="1" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="1"/>
                <Button Content="2" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="2"/>
                <Button Content="3" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="3"/>
                <Button Content="4" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="4"/>
                <Button Content="5" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="5"/>
                <Button Content="6" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="6"/>
                <Button Content="7" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="7"/>
                <Button Content="8" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="8"/>
                <Button Content="9" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="9"/>
                <Button Content="" Style="{StaticResource KeypadButtonStyle}" IsEnabled="False"/>
                <Button Content="0" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="0"/>
                <Button Style="{StaticResource KeypadButtonStyle}" Command="{Binding DeleteLastDigitCommand}">
                    <materialDesign:PackIcon Kind="BackspaceOutline" Width="24" Height="24"/>
                </Button>
            </UniformGrid>
            
            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,0">
                <Button Content="Cancel" 
                       Height="38" 
                       Width="125" 
                       Margin="0,0,16,0" 
                       Background="#6B7280" 
                       BorderBrush="#6B7280" 
                       Foreground="White" 
                       FontWeight="Bold" 
                       FontSize="14"
                       Command="{Binding CancelCommand}"/>
                <Button Content="Get Access" 
                       Height="38" 
                       Width="125" 
                       Background="#1976D2" 
                       Foreground="White" 
                       FontWeight="Bold" 
                       FontSize="14"
                       Command="{Binding GetAccessCommand}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
