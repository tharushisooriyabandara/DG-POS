<Page x:Class="POS_UI.View.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:POS_UI.View"
      xmlns:converters="clr-namespace:POS_UI.Converters"
      xmlns:vm="clr-namespace:POS_UI.ViewModels"
      xmlns:controls="clr-namespace:POS_UI.View.Controls"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      mc:Ignorable="d" 
      xmlns:local2="clr-namespace:POS_UI"
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="History Page">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:CollectionToVisibilityConverter x:Key="CollectionToVisibilityConverter"/>
        <converters:InvertCollectionToVisibilityConverter x:Key="InvertCollectionToVisibilityConverter"/>
        <converters:CountryBasedDateConverter x:Key="CountryBasedDateConverter"/>
        <converters:CountryBasedDateTimeConverter2 x:Key="CountryBasedDateTimeConverter2"/>
        <converters:CountryToLanguageConverter x:Key="CountryToLanguageConverter"/>
        <converters:CurrencyFormatConverter x:Key="CurrencyFormatConverter"/>
    </Page.Resources>

    <Page.DataContext>
        <vm:HistoryViewModel/>
    </Page.DataContext>

    <materialDesign:DialogHost Identifier="RootDialog" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="351*"/>
                <ColumnDefinition Width="719*"/>
            </Grid.ColumnDefinitions>
            <!-- Sidebar Placeholder -->
            <local2:Sidebar x:Name="SidebarControl" Grid.Column="0"/>
            <Grid Grid.Column="1" Background="#F5F5F5" Grid.ColumnSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="Transparent" Padding="10,0,20,0" Margin="0,5,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                <Border Background="#2196F3" Width="15" Height="60" CornerRadius="5"/>
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Text="Order History" FontSize="22" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <TextBlock Text="Manage Order History" FontSize="15"/>
                                    <!--<Button Content="Refresh" Command="{Binding RefreshTablesCommand}" Width="80" Height="24" Margin="20,0,0,0" Background="#1976D2" Foreground="White" FontWeight="Bold"/>-->
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!--<Button Grid.Column="1" Content="Refresh" 
                            Command="{Binding LoadOrdersCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#2196F3" Foreground="White"
                            Padding="15,8" Margin="0,0,10,0"/>-->
                    </Grid>
                </Border>

                <!-- Main Content -->
                <Grid Grid.Row="1" Margin="10,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Filters Bar -->
                    <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="10" Margin="0,-43,0,8" HorizontalAlignment="Right">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <DatePicker SelectedDate="{Binding FromDate}" 
                                            DisplayDateEnd="{x:Static sys:DateTime.Today}"
                                            Language="{converters:CountryToLanguageExtension}"> 
                                </DatePicker>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <DatePicker SelectedDate="{Binding ToDate}"
                                            DisplayDateEnd="{x:Static sys:DateTime.Today}"
                                            Language="{converters:CountryToLanguageExtension}">
                                </DatePicker>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Show" Command="{Binding ShowCommand}" VerticalContentAlignment="Center"
                                Background="#1976D2" Foreground="White" Padding="14,5" Margin="0,0,12,0" Width="95"/>
                            <Button Grid.Column="3" Content="Clear" Command="{Binding ClearDatesCommand}" VerticalContentAlignment="Center"
                                Background="#EEEEEE" Foreground="#333" Padding="14,5" Margin="0,0,12,0" Width="95"/>
                            <Button Grid.Column="4" Content="Export" Command="{Binding ExportCommand}" VerticalContentAlignment="Center"
                                Background="#4CAF50" Foreground="White" Padding="14,5" Width="95" BorderBrush="#4CAF50"/>

                            <!-- Optional search on right -->
                            <DockPanel Grid.Column="5" LastChildFill="True" Margin="3,0,0,0" VerticalAlignment="Center">
                                <Border Background="#FFFFFF" CornerRadius="8" Width="280" BorderBrush="#E5E7EB" BorderThickness="1" Padding="6" Margin="0,0,0,0" HorizontalAlignment="Right">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="400"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Foreground="#6B7280" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" BorderThickness="0" Background="Transparent"  FontSize="14"
                                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                                 materialDesign:HintAssist.Hint="Search Orders..."/>
                                    </Grid>
                                </Border>
                            </DockPanel>
                        </Grid>
                    </Border>

                    <!-- Orders Table -->
                    <Border Grid.Row="1" Background="White" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Loading Indicator -->
                            <controls:LoadingIndicator Grid.Row="0" Grid.RowSpan="2"
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center" 
                                          ProgressRingSize="70"
                                          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <!-- Table Header -->
                            <Grid Grid.Row="1" Grid.IsSharedSizeScope="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Table Header -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" SharedSizeGroup="OrderIdColumn"/>
                                        <ColumnDefinition Width="60" SharedSizeGroup="PlatformIconColumn"/>
                                        <ColumnDefinition Width="120" SharedSizeGroup="PlatformNameColumn"/>
                                        <ColumnDefinition Width="140" SharedSizeGroup="OrderStatusColumn"/>
                                        <ColumnDefinition Width="130" SharedSizeGroup="OrderTypeColumn"/>
                                        <ColumnDefinition Width="130" SharedSizeGroup="TotalColumn"/>
                                        <ColumnDefinition Width="175" SharedSizeGroup="DateTimeColumn"/>
                                        <ColumnDefinition Width="100" SharedSizeGroup="UserShiftColumn"/>
                                        <ColumnDefinition Width="120" SharedSizeGroup="ActionsColumn"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Order ID" FontWeight="Bold" Foreground="#1976D2" 
                                         TextAlignment="Center" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="10,10,10,5"/>
                                    <TextBlock Grid.Column="1" Text="" FontWeight="Bold" Foreground="#1976D2" 
                                         TextAlignment="Center" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="10,10,10,5"/>
                                    <TextBlock Grid.Column="2" Text="Platform" FontWeight="Bold" Foreground="#1976D2" 
                                         TextAlignment="Center" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="10,10,10,5"/>
                                    <TextBlock Grid.Column="3" Text="Order Status" FontWeight="Bold" Foreground="#1976D2" 
                                         TextAlignment="Center" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="10,10,10,5"/>
                                    <TextBlock Grid.Column="4" Text="Order Type" FontWeight="Bold" Foreground="#1976D2" Margin="0"
                                         TextAlignment="Center" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="10,10,10,5"/>
                                    <TextBlock Grid.Column="5" Text="Total" FontWeight="Bold" Foreground="#1976D2" Margin="0"
                                         TextAlignment="Center" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="10,10,10,5"/>
                                    <TextBlock Grid.Column="6" Text="Date &amp; Time" FontWeight="Bold" Foreground="#1976D2" 
                                         TextAlignment="Center" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="10,10,10,5"/>
                                    <TextBlock Grid.Column="7" Text="Shift ID" FontWeight="Bold" Foreground="#1976D2" 
                                         TextAlignment="Center" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="10,10,10,5"/>
                                    <TextBlock Grid.Column="8" Text="Actions" FontWeight="Bold" Foreground="#1976D2" HorizontalAlignment="Center"
                                         TextAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="10,10,10,5"/>
                                </Grid>

                                <!-- Orders List -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ScrollViewer.Resources>
                                        <!-- Apply thicker scrollbar style defined in Stylesxaml.xaml -->
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                                    </ScrollViewer.Resources>
                                    <ItemsControl ItemsSource="{Binding PaginatedOrders}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="110" SharedSizeGroup="OrderIdColumn"/>
                                                            <ColumnDefinition Width="60" SharedSizeGroup="PlatformIconColumn"/>
                                                            <ColumnDefinition Width="120" SharedSizeGroup="PlatformNameColumn"/>
                                                            <ColumnDefinition Width="140" SharedSizeGroup="OrderStatusColumn"/>
                                                            <ColumnDefinition Width="130" SharedSizeGroup="OrderTypeColumn"/>
                                                            <ColumnDefinition Width="130" SharedSizeGroup="TotalColumn"/>
                                                            <ColumnDefinition Width="175" SharedSizeGroup="DateTimeColumn"/>
                                                            <ColumnDefinition Width="100" SharedSizeGroup="UserShiftColumn"/>
                                                            <ColumnDefinition Width="120" SharedSizeGroup="ActionsColumn"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Order ID -->
                                                        <TextBlock Grid.Column="0" Text="{Binding DisplayOrderId}" 
                                                           FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Padding="10,10"/>

                                                        <!-- Platform Logo -->
                                                        <Border Grid.Column="1" Width="45" Height="40" 
                                                           Background="#F0F0F0" CornerRadius="8"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Image Source="{Binding PlatformLogo, FallbackValue={x:Null}, TargetNullValue={x:Null}}" 
                                                               Stretch="Uniform" Margin="8,8,8,8" HorizontalAlignment="Center"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Border>

                                                        <!-- Platform Name -->
                                                        <TextBlock Grid.Column="2" Text="{Binding PlatformName}" 
                                                           FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Padding="10,10"/>

                                                        <!-- Order Status -->
                                                        <TextBlock Grid.Column="3" Text="{Binding ApiStatus}" 
                                                             FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                                             VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Padding="10,10"/>
                                                        <!-- Shipping Method -->
                                                        <TextBlock Grid.Column="4" Text="{Binding ShippingMethod}" 
                                                             FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                                             VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Padding="10,10"/>
                                                        <!-- Total Amount -->
                                                        <TextBlock Grid.Column="5" Text="{Binding DisplayTotal, Converter={StaticResource CurrencyFormatConverter}}" 
                                                             FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                                             VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Padding="10,10"/>
                                                        <!-- Date & Time -->
                                                        <TextBlock Grid.Column="6" Text="{Binding CreatedAtActual, Converter={StaticResource CountryBasedDateTimeConverter2}}" 
                                                             FontSize="14" FontWeight="SemiBold" Foreground="#333" TextAlignment="Center"
                                                             VerticalAlignment="Center" HorizontalAlignment="Center" Padding="10,10"/>
                                                        <!-- Cash Drawer Session ID -->
                                                        <TextBlock Grid.Column="7" Text="{Binding CashDrawerSessionId}" 
                                                             FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                                             VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Padding="10,10"/>
                                                        <!-- View Button -->
                                                        <Button Grid.Column="8" Content="View" BorderBrush="Transparent"
                                                        Background="#1976D2" Foreground="White" Margin="0"
                                                        Padding="10,6" FontSize="14" Width="80" Height="38"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Click="ViewOrder_Click"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Empty State: visible only when not loading AND no orders -->
                                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsLoading}" Value="False"/>
                                                        <Condition Binding="{Binding PaginatedOrders.Count}" Value="0"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                <!--<materialDesign:PackIcon Kind="PackageVariantClosed" Width="64" Height="64" 
                                                       Foreground="#CCC" Margin="0,0,0,20"/>-->
                                <TextBlock Text="No orders found" FontSize="18" Foreground="#666" 
                                         HorizontalAlignment="Center"/>
                                <TextBlock Text="Try adjusting your search criteria" FontSize="14" 
                                         Foreground="#999" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Pagination Footer -->
                <Border Grid.Row="2" Background="Transparent" Padding="10,10,10,5" Margin="20,0,20,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="First" Command="{Binding FirstPageCommand}" 
                            Margin="0,0,8,0" Padding="10,6" BorderBrush="Transparent" 
                            Background="#2196F3" Foreground="White"/>
                        <Button Command="{Binding PrevPageCommand}" Margin="0,0,8,0" 
                            Padding="10,6" BorderBrush="Transparent" 
                            Background="#2196F3" Foreground="White">
                            <materialDesign:PackIcon Kind="NavigateBefore" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </Button>

                        <TextBlock Text="{Binding PageInfoText}" VerticalAlignment="Center" 
                             Margin="0,0,8,0" FontSize="14" Foreground="#666"/>

                        <Button Command="{Binding NextPageCommand}" Margin="0,0,8,0" 
                            Padding="10,6" BorderBrush="Transparent" 
                            Background="#2196F3" Foreground="White">
                            <materialDesign:PackIcon Kind="NavigateNext" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </Button>
                        <Button Content="Last" Command="{Binding LastPageCommand}" 
                            Padding="10,6" BorderBrush="Transparent" 
                            Background="#2196F3" Foreground="White"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</Page>
