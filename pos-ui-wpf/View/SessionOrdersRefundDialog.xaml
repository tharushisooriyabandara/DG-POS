<UserControl x:Class="POS_UI.View.SessionOrdersRefundDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:converters="clr-namespace:POS_UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="450">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>
    <Border Background="White" CornerRadius="10" Padding="5" Width="430">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    Command="{Binding CloseCommand}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Style="{StaticResource MaterialDesignToolButton}"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Width="30"
                    Height="30"
                    Margin="0,0,0,-10">
                <materialDesign:PackIcon Kind="Close" Width="24" Height="24"/>
            </Button>

            <TextBlock Grid.Row="1"
                       Text="Order Details"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <StackPanel Grid.Row="2" Margin="0,0,0,15" HorizontalAlignment="Center">
                <Border Grid.Column="2" Background="White" CornerRadius="6" Padding="8,4" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right"
                        Visibility="{Binding PaymentStatus, Converter={StaticResource StringToVisibilityConverter}}" BorderBrush="#068A03" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding PaymentStatus}" Foreground="#068A03" FontWeight="Bold"/>
                        <TextBlock Text="{Binding PaymentMode, StringFormat=' - {0}'}" 
                                Foreground="#068A03" FontWeight="Bold"
                                Visibility="{Binding PaymentStatus, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=PAID|PAID -}"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="250"
                          Margin="0,0,0,10">
                <ItemsControl ItemsSource="{Binding OrderDetails}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,8,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayOrderId}"
                                               FontWeight="SemiBold"
                                               Margin="20,0,0,0"
                                               FontSize="15"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Status}"
                                               FontSize="14"
                                               Margin="0,0,12,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="Orange"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Ready for pickup">
                                                        <Setter Property="Foreground" Value="Green"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Ready For Pickup">
                                                        <Setter Property="Foreground" Value="Green"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="COMPLETED">
                                                        <Setter Property="Foreground" Value="Green"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Foreground" Value="Green"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="ACCEPTED">
                                                        <Setter Property="Foreground" Value="Orange"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Accepted">
                                                        <Setter Property="Foreground" Value="Orange"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Preparing">
                                                        <Setter Property="Foreground" Value="Orange"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="PREPARING">
                                                        <Setter Property="Foreground" Value="Orange"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="4" Background="#F5F5F5" CornerRadius="8" Padding="10" Margin="10,0,10,0">
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Total Amount:" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" FontSize="18" FontWeight="Bold" Foreground="#16A34A">
                        <Run Text="{Binding TotalAmount, Converter={StaticResource CurrencyFormatConverter}}"/>
                    </TextBlock>
                </Grid>
            </Border>

            <Button Grid.Row="5"
                    Content="Refund"
                    Height="45"
                    Background="#068A03"
                    Foreground="White"
                    FontSize="18"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Margin="10,10,10,5"
                    HorizontalAlignment="Stretch"
                    Command="{Binding RefundCommand}"/>
        </Grid>
    </Border>
</UserControl>
