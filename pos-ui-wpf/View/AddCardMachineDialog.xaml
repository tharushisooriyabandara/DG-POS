<Window x:Class="POS_UI.View.AddCardMachineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:POS_UI.ViewModels"
        Title="Add Card Machine" 
        Height="500" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FAFAFA">
    

    
    <materialDesign:DialogHost Identifier="AddCardMachineDialogHost" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{Binding DialogTitle}" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#1976D2"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Configure payment terminal settings" 
                       FontSize="14" 
                       Foreground="#6B7280"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0"/>
        </StackPanel>
        
        <!-- Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Device Name -->
                <StackPanel Orientation="Horizontal">
                <TextBlock Text="Device Name " 
                           FontWeight="SemiBold" 
                           FontSize="14" 
                           Margin="0,0,0,8"/>
                <TextBlock Text="*" FontSize="14" FontWeight="SemiBold" Foreground="Red"/>
                </StackPanel>
                <TextBox Text="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Enter device name"
                         Margin="0,0,0,16"/>
                
                <!-- Device Type -->
                <StackPanel Orientation="Horizontal">
                <TextBlock Text="Device Type " 
                           FontWeight="SemiBold" 
                           FontSize="14" 
                           Margin="0,0,0,8"/>
                <TextBlock Text="*" FontSize="14" FontWeight="SemiBold" Foreground="Red"/>
                </StackPanel>
                <ComboBox ItemsSource="{Binding DeviceTypes}"
                          SelectedItem="{Binding SelectedDeviceType}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          materialDesign:HintAssist.Hint="Select device type"
                          Margin="0,0,0,16"/>
                
                <!-- IP Address -->
                <StackPanel Orientation="Horizontal">
                <TextBlock Text="IP Address " 
                           FontWeight="SemiBold" 
                           FontSize="14" 
                           Margin="0,0,0,8"/>
                <TextBlock Text="*" FontSize="14" FontWeight="SemiBold" Foreground="Red"/>
                </StackPanel>
                <TextBox Text="{Binding IPAddress, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Enter IP address (e.g., 192.168.1.100)"
                         Margin="0,0,0,16"/>
                
                <!-- Port -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Port " 
                           FontWeight="SemiBold" 
                           FontSize="14" 
                           Margin="0,0,0,8"/>
                    <TextBlock Text="*" FontSize="14" FontWeight="SemiBold" Foreground="Red"/>
                </StackPanel>
                <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Enter port number (e.g., 8080)"
                         Margin="0,0,0,16"/>
                
                <!-- Device ID -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Device ID " 
                           FontWeight="SemiBold" 
                           FontSize="14" 
                           Margin="0,0,0,8"/>
                    <TextBlock Text="*" FontSize="14" FontWeight="SemiBold" Foreground="Red"/>
                </StackPanel>
                <TextBox Text="{Binding DeviceId, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Enter device ID"
                         Margin="0,0,0,16"/>
                
                <!-- Pairing Code -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Pairing Code " 
                           FontWeight="SemiBold" 
                           FontSize="14" 
                           Margin="0,0,0,8"/>
                    <TextBlock Text="*" FontSize="14" FontWeight="SemiBold" Foreground="Red"/>
                </StackPanel>
                <TextBox Text="{Binding ParingCode, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Enter pairing code"
                         Margin="0,0,0,16"/>
                
                <!-- Status -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Status " 
                           FontWeight="SemiBold" 
                           FontSize="14" 
                           Margin="0,0,0,8"/>
                    <TextBlock Text="*" FontSize="14" FontWeight="SemiBold" Foreground="Red"/>
                </StackPanel>
                <ComboBox ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding SelectedStatus}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          materialDesign:HintAssist.Hint="Select status"
                          Margin="0,0,0,16"/>
                

            </StackPanel>
        </ScrollViewer>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Margin="0,20,0,0">
            <Button Content="Cancel" 
                    Width="100" 
                    Height="36"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    FontSize="14"
                    Command="{Binding CancelCommand}"
                    Margin="0,0,10,0"/>
            <Button Content="{Binding SaveButtonText}" 
                    Width="100" 
                    Height="36"
                    Background="#1976D2"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="14"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
        </Grid>
    </materialDesign:DialogHost>
</Window> 