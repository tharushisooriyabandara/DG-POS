<UserControl x:Class="POS_UI.View.ConfirmDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Border Background="White" CornerRadius="20" Padding="14" Width="360">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="{Binding Title}"
                       FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <!-- Message -->
            <TextBlock Grid.Row="1" Text="{Binding Message}"
                       TextAlignment="Center" TextWrapping="Wrap"
                       FontSize="14" Margin="0,6,0,6"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Button Content="No" Width="96" Height="36"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding NoCommand}" Margin="0,0,10,0"/>
                <Button Content="Yes" Width="96" Height="36"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#1976D2" Foreground="White"
                        Command="{Binding YesCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>


