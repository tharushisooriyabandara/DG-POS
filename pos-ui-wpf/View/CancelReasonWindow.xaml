<Window x:Class="POS_UI.View.CancelReasonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cancel Order Reason" Width="480" WindowStartupLocation="CenterOwner" SizeToContent="Height"
        ResizeMode="NoResize" WindowStyle="None" ShowInTaskbar="False" Background="White">
    <Border Background="White" CornerRadius="20" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with title and close -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Order Cancellation Reason" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="✕" Width="38" Height="28" Background="Transparent" BorderThickness="0" Foreground="Black" FontSize="15"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Click="OnClose" Margin="0,0,0,0" Padding="0"/>
            </Grid>

            <!-- Reason Dropdown -->
            <ComboBox Grid.Row="1" 
                      ItemsSource="{Binding CancellationReasons}"
                      SelectedItem="{Binding SelectedReason, Mode=TwoWay}"
                      Height="40" 
                      Margin="0,12,0,12"
                      FontSize="14"
                      VerticalContentAlignment="Center"
                      Padding="8,0,8,0"
                      Background="White"
                      BorderBrush="#000000"
                      BorderThickness="1">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="0,0,0,0" BorderBrush="#E0E0E0" Padding="8,4">
                            <TextBlock Text="{Binding}" FontSize="14"/>
                        </Border>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Button Content="Proceed" Background="#FF2196F3" Foreground="White" Width="110" Height="36"
                        Click="OnProceed" IsEnabled="{Binding CanProceed}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

