<Page x:Class="POS_UI.View.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:vm="clr-namespace:POS_UI.ViewModels"
      xmlns:local="clr-namespace:POS_UI.View"
      xmlns:controls="clr-namespace:POS_UI"
      xmlns:controls1="clr-namespace:POS_UI.View.Controls"
      xmlns:controls2="clr-namespace:POS_UI.View.Controls"
      xmlns:converters="clr-namespace:POS_UI.Converters"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      Title="Settings">
    <Page.Resources>
        <converters:StringToColorConverter x:Key="StringToColorConverter"/>
        <converters:SettingsNavTabColorConverter x:Key="SettingsNavTabColorConverter"/>
        <converters:StringToForegroundConverter x:Key="StringToForegroundConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertBooleanConverter x:Key="InvertBooleanConverter"/>
        <converters:CurrencyFormatConverter x:Key="CurrencyFormatConverter"/>
        <converters:BooleanToColorConverter x:Key="BooleanToColorConverter"/>
        <converters:BooleanToStringConverter x:Key="BooleanToStringConverter"/>
        <converters:InvertBooleanToVisibilityConverter x:Key="InvertBooleanToVisibilityConverter"/>
        <converters:InvertCollectionToVisibilityConverter x:Key="InvertCollectionToVisibilityConverter"/>
        <converters:CollectionToVisibilityConverter x:Key="CollectionToVisibilityConverter"/>
        <converters:DateTimeFormatConverter x:Key="DateTimeFormatConverter"/>
        <converters:CountryBasedDateConverter x:Key="CountryBasedDateConverter"/>
        <converters:CountryToLanguageConverter x:Key="CountryToLanguageConverter"/>
        <converters:CountryBasedDateTimeConverter x:Key="CountryBasedDateTimeConverter"/>

        <!-- Settings main nav: shared pill template (NavTabPillButtonStyle in Stylesxaml.xaml) + POS sizing -->
        <Style x:Key="SettingsNavTabButtonStyle" TargetType="Button" BasedOn="{StaticResource NavTabPillButtonStyle}">
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Sub-section tabs: slightly smaller than main nav; same pill / hover behavior -->
        <Style x:Key="SettingsSubNavTabButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsNavTabButtonStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>
    
        <!-- Material Design ToggleButton Style -->
        <Style x:Key="MaterialSwitchToggle" TargetType="ToggleButton" BasedOn="{StaticResource MaterialDesignSwitchToggleButton}">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>
        
        <!-- Full Screen Dialog Style - Override Popup Container -->
        <Style x:Key="FullScreenDialogHost" TargetType="materialDesign:DialogHost" BasedOn="{StaticResource {x:Type materialDesign:DialogHost}}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="OverlayBackground">
                <Setter.Value>
                    <SolidColorBrush Color="Black" Opacity="1.0"/>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <!-- Override internal popup Grid to remove margins -->
                <Style TargetType="Grid">
                    <Setter Property="Margin" Value="0"/>
                </Style>
            </Style.Resources>
        </Style>
    </Page.Resources>
    <Page.DataContext>
        <vm:SettingsViewModel />
    </Page.DataContext>
    <!-- Single Grid as Page child -->
    <materialDesign:DialogHost Identifier="RootDialog" CloseOnClickAway="True" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
    <Grid>
        <!-- Main Content Grid -->
        <Grid Background="#FAFAFA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Sidebar -->
            <controls:Sidebar x:Name="SidebarControl" Grid.Column="0"/>
        <!-- Main Content -->
            <Grid Grid.Column="1" Background="#F8F8F8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- Match TablesPage / other main pages: Grid.Margin 10,5,20,10 -->
            <StackPanel Orientation="Horizontal" Margin="10,5,20,8" Grid.Row="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <Border Background="#2196F3" Width="15" Height="60" CornerRadius="5"/>
                            <StackPanel Orientation="Vertical" Margin="10">
                                <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Margin="0,0,0,2"/>
                                <TextBlock Text="Manage All Your POS Settings" FontSize="15"/>
                                <!--<Button Content="Refresh" Command="{Binding RefreshTablesCommand}" Width="80" Height="24" Margin="20,0,0,0" Background="#1976D2" Foreground="White" FontWeight="Bold"/>-->
                            </StackPanel>
                        </StackPanel>
            </StackPanel>
            <Button Content="Contact Support" Width="160" Height="40" Background="#1976D2" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,30,0" Grid.Row="0"/>
            <Border Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Stretch"
                    Margin="10,0,10,0" Padding="0,4,0,14"
                    Background="Transparent">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">

                <Button Content="Platform Settings"
                        Margin="0,0,6,0"
                        Style="{StaticResource SettingsNavTabButtonStyle}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Platform Settings"
                        Background="{Binding SelectedTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=Platform Settings}"
                        Foreground="{Binding SelectedTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=Platform Settings}"
                        />
                <Button Content="Printers"
                        Margin="0,0,6,0"
                        Style="{StaticResource SettingsNavTabButtonStyle}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Printer"
                        Background="{Binding SelectedTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=Printer}"
                        Foreground="{Binding SelectedTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=Printer}"/>
                <Button Content="Card Machines"
                        Margin="0,0,6,0"
                        Style="{StaticResource SettingsNavTabButtonStyle}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Card Machines"
                        Background="{Binding SelectedTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=Card Machines}"
                        Foreground="{Binding SelectedTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=Card Machines}"/>
                <!--<Button Content="Cash Drawer"
                        Margin="0,0,6,0"
                        Style="{StaticResource SettingsNavTabButtonStyle}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Cash Drawer"
                        Background="{Binding SelectedTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=Cash Drawer}"
                        Foreground="{Binding SelectedTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=Cash Drawer}"/> -->
                <Button Content="Menu"
                        Margin="0,0,6,0"
                        Style="{StaticResource SettingsNavTabButtonStyle}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Menu"
                        Background="{Binding SelectedTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=Menu}"
                        Foreground="{Binding SelectedTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=Menu}"/>
                <Button Content="Floor Plan"
                        Margin="0,0,6,0"
                        Style="{StaticResource SettingsNavTabButtonStyle}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Floor Plan"
                        Background="{Binding SelectedTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=Floor Plan}"
                        Foreground="{Binding SelectedTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=Floor Plan}"/>
                <Button Content="Configure Orders"
                        Margin="0,0,6,0"
                        Style="{StaticResource SettingsNavTabButtonStyle}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Configure Orders"
                        Background="{Binding SelectedTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=Configure Orders}"
                        Foreground="{Binding SelectedTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=Configure Orders}"/>
                <Button Content="Users"
                        Margin="0,0,6,0"
                        Style="{StaticResource SettingsNavTabButtonStyle}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="User"
                        Background="{Binding SelectedTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=User}"
                        Foreground="{Binding SelectedTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=User}"/>
            </StackPanel>
            </Border>

                <Border Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Platform Settings}"
                    Background="White" CornerRadius="12" Margin="10,74,10,20" Padding="20,20,20,20" BorderBrush="#E0E0E0" BorderThickness="1" Grid.Row="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Content area -->
                        <Grid Grid.Row="1" VerticalAlignment="Stretch" >
                            <!-- Platforms list with scrollbar -->
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled" 
                                          VerticalScrollBarVisibility="Auto"
                                          MinHeight="400"
                                          Visibility="{Binding IsLoadingPlatforms, Converter={StaticResource InvertBooleanConverter}}">
                                <ScrollViewer.Resources>
                                    <!-- Apply thicker scrollbar style defined in Stylesxaml.xaml -->
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                                </ScrollViewer.Resources>
                                <ItemsControl ItemsSource="{Binding Platforms}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFF3F3F3" CornerRadius="12" Padding="18" Margin="0,12,15,0" Width="274" Height="115">
                                                <Grid Margin="0,0,0,-8">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Top Row: Platform logo and status badge -->
                                                    <Grid Grid.Row="0" Grid.Column="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <!-- Left: Platform logo -->
                                                        <Image Grid.Column="0"
                                                               Width="30" Height="30"
                                                               Source="{Binding PlatformLogo}"
                                                               HorizontalAlignment="Left"
                                                               VerticalAlignment="Top">
                                                            <Image.Style>
                                                                <Style TargetType="Image">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Source, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Image.Style>
                                                        </Image>
                                                        
                                                        <!-- Right: Status badge -->
                                                        <Border Grid.Column="1"
                                                                Background="{Binding StatusColor}"
                                                                CornerRadius="4" 
                                                                Padding="4,2" 
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding Status}" 
                                                                       Foreground="White" 
                                                                       FontWeight="Bold" 
                                                                       FontSize="12"/>


                                                        </Border>
                                                    </Grid>
                                                                                                     <!-- Snooze Toggle Button for each platform -->
                                                   <!-- <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                       <TextBlock Text="Snooze" FontSize="10" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,2"/> -->
                                                       
                                                       <!-- Toggle Button -->
  <!-- Toggle Button -->
<!-- <ToggleButton Width="45" Height="24" Grid.Row="0" Grid.Column="1"
              IsChecked="{Binding IsActive, Mode=TwoWay}"
              HorizontalAlignment="Right"
              Command="{Binding DataContext.OpenDialogCommand,
               RelativeSource={RelativeSource AncestorType=Page}}"
              CommandParameter="{Binding}"/> -->



                                                <ToggleButton Width="45" Height="24" Grid.Row="0" Grid.Column="1" Margin="5,-6,0,0"
                                                              IsChecked="{Binding IsActive, Mode=OneWay}"
                                                              HorizontalAlignment="Right"
                                                              IsEnabled="{Binding IsUpdating, Converter={StaticResource InvertBooleanConverter}}"
                                                              Click="ToggleButton_Click">
                                                            <ToggleButton.Style>
                                                                <Style TargetType="ToggleButton" BasedOn="{StaticResource MaterialDesignSwitchToggleButton}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                                                            <Setter Property="Background" Value="#E0E0E0"/>
                                                                            <Setter Property="BorderBrush" Value="#BDBDBD"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ToggleButton.Style>
                                                </ToggleButton>

               
<!-- TextBlock that shows the selected option -->
<!-- <TextBlock Text="{Binding SelectedSnoozeOption}"
           Width="50"
          Foreground="{Binding IsActive, Converter={StaticResource BooleanToColorConverter}, Mode=OneWay}"
           Margin="0,0,0,0"
           Grid.Row="1" Grid.Column="1"
           HorizontalAlignment="Right"/> -->

     
                                                   
                                                   <!-- </StackPanel> -->

                                                    <!-- Main Content -->
                                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                                                        <TextBlock Text="{Binding PlatformName}" FontWeight="Bold" FontSize="12" Margin="0,10,0,0"/>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="18" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Loading indicator -->
                                                         <controls2:LoadingIndicator HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center" 
                                                        ProgressRingSize="70"
                                                        Visibility="{Binding IsLoadingPlatforms, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Grid>
                </Border>
                <TextBlock Text="App Version 0.21" FontSize="13" Foreground="Black" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,70,40,0" Grid.Row="0"/>
                <!-- Printers Tab with Subtabs -->
                <Border Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Printer}"
                        Background="White" CornerRadius="12" Margin="20,74,20,20" Padding="0,0,0,0" BorderBrush="#E0E0E0" BorderThickness="1" Grid.Row="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Printer Subtabs -->
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="16,18,16,6" VerticalAlignment="Center">
                            <Button Content="Connected Printers"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource SettingsSubNavTabButtonStyle}"
                                    Command="{Binding SwitchPrinterSubTabCommand}"
                                    CommandParameter="ConnectedPrinters"
                                    Background="{Binding SelectedPrinterSubTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=ConnectedPrinters}"
                                    Foreground="{Binding SelectedPrinterSubTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=ConnectedPrinters}"/>
                            <Button Content="Printer Groups"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource SettingsSubNavTabButtonStyle}"
                                    Command="{Binding SwitchPrinterSubTabCommand}"
                                    CommandParameter="PrinterGroups"
                                    Background="{Binding SelectedPrinterSubTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=PrinterGroups}"
                                    Foreground="{Binding SelectedPrinterSubTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=PrinterGroups}"/>
                        </StackPanel>

                        <!-- Connected Printers Subtab Content -->
                        <Grid Grid.Row="1" Visibility="{Binding SelectedPrinterSubTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=ConnectedPrinters}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header Row -->
                            <Grid Grid.Row="0" Margin="20,15,20,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Connected Devices" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Grid.Column="0"/>
                                <Button Content="Add Connected Printers" Width="200" Height="36" Background="#1976D2" Foreground="White" FontWeight="Bold" FontSize="14" Margin="5,0,0,0" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Command="{Binding GetConnectedPrinterCommand}"/>
                            </Grid>
                            <!-- Table -->
                            <Grid Grid.Row="1" Margin="20,12,20,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Table Header -->
                                <Border Grid.Row="0" Grid.ColumnSpan="6" Background="#F5F6FA" CornerRadius="8,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="Device Name" FontWeight="Bold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Connected Via" FontWeight="Bold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="Status" FontWeight="Bold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="Test Print" FontWeight="Bold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="Settings" FontWeight="Bold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <!-- Table Rows -->
                                <ItemsControl Grid.Row="1" Grid.ColumnSpan="6" ItemsSource="{Binding Printers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Height="48" VerticalAlignment="Center" Background="Transparent">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DeviceName}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                <TextBlock Grid.Column="2" Text="{Binding ConnectedVia}" FontSize="14" Foreground="#6B7280" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                <Border Grid.Column="3" Background="{Binding StatusColor}" CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                                </Border>
                                                <Button Grid.Column="4" Content="Run Test Print" Foreground="#1976D2" FontWeight="Bold" Background="Transparent" BorderBrush="Transparent" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Left" Command="{Binding DataContext.TestPrintCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding DeviceName}"/>
                                                <Button Grid.Column="5" Style="{StaticResource MaterialDesignToolButton}" Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Left" Command="{Binding DataContext.OpenPrinterSettingsCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Cog" Width="22" Height="22"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                            <!-- Pagination Controls -->
                            <Grid Grid.Row="2" Margin="20,20,20,20" Height="40">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <ComboBox Width="50" Height="28" SelectedIndex="0" Margin="5">
                                        <ComboBoxItem Content="10"/>
                                        <ComboBoxItem Content="25"/>
                                        <ComboBoxItem Content="50"/>
                                    </ComboBox>
                                    <TextBlock Text="Rows per page" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="#6B7280"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="Displaying 1-10 of 100" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="#6B7280" Margin="10,0,0,0" Width="127"/>
                                <StackPanel Orientation="Horizontal" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Width="32" Height="32" Background="#F5F6FA" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,8,0" Style="{StaticResource MaterialDesignToolButton}">
                                        <materialDesign:PackIcon Kind="ChevronLeft" Width="18" Height="18"/>
                                    </Button>
                                    <Button Width="32" Height="32" Background="#F5F6FA" BorderBrush="#E5E7EB" BorderThickness="1" Style="{StaticResource MaterialDesignToolButton}">
                                        <materialDesign:PackIcon Kind="ChevronRight" Width="18" Height="18"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Printer Groups Subtab Content -->
                        <Grid Grid.Row="1" Visibility="{Binding SelectedPrinterSubTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=PrinterGroups}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header Row -->
                            <Grid Grid.Row="0" Margin="20,15,20,0">
                                <TextBlock Text="Printer Groups" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Printer Groups Table -->
                            <Grid Grid.Row="1" Margin="20,12,20,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Table Header -->
                                <Border Grid.Row="0" Grid.ColumnSpan="6" Background="#F5F6FA" CornerRadius="8,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <!--<ColumnDefinition Width="40"/>-->
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Name" FontWeight="Bold" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                        <TextBlock Grid.Column="1" Text="Description" FontWeight="Bold" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Status" FontWeight="Bold" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="Created At" FontWeight="Bold" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="Actions" FontWeight="Bold" Foreground="#6B7280" VerticalAlignment="Center" Margin="20,0,0,0"/>
                                    </Grid>
                                </Border>
                                <!-- Table Rows -->
                                <ScrollViewer Grid.Row="1" Grid.ColumnSpan="6" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding PrinterGroups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Height="48" VerticalAlignment="Center" Background="Transparent" Cursor="Hand">
                                                    <Grid.ColumnDefinitions>
                                                        
                                                        <ColumnDefinition Width="1.5*"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1.5*"/>
                                                        <ColumnDefinition Width="1.5*"/>
                                                    </Grid.ColumnDefinitions>
                                                   
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="14" Foreground="#6B7280" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Description}" FontSize="14" Foreground="#6B7280" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                    <Border Grid.Column="2" CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#FF5252"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="True">
                                                                        <Setter Property="Background" Value="#00C853"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Foreground="White" FontWeight="Bold" FontSize="13">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="Inactive"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="True">
                                                                            <Setter Property="Text" Value="Active"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
