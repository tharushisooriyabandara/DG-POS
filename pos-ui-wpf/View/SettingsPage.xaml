                                            PreviewTouchDown="DatePicker_FocusOpen"
                                            Loaded="DatePicker_Loaded"
                                            Language="{converters:CountryToLanguageExtension}"/>
                                <StackPanel Orientation="Horizontal" Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button  Content="Clear" Width="70" Height="32" Margin="10,0,10,0" VerticalAlignment="Center"  Background="#EEEEEE" Foreground="#1976D2"
                                        Command="{Binding ClearToDateCommand}"/>
                                    <Button Content="Show" Width="80" Height="32" Background="#1976D2" Foreground="White" HorizontalAlignment="Right"
                                    Command="{Binding ShowShiftDataCommand}" IsEnabled="{Binding IsLoadingShiftData, Converter={StaticResource InvertBooleanConverter}}"/>
                                </StackPanel>
                            </Grid>
                        <!-- Loading Indicator -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10"
                                    Visibility="{Binding IsLoadingShiftData, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <controls2:LoadingIndicator Width="20" Height="20" Margin="0,0,10,0"/>
                            <TextBlock Text="Loading shift data..." VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Background="#FFF" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16,16,16,3" Margin="0,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <!--<ColumnDefinition Width="*"/>-->
                                </Grid.ColumnDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Background="#F8F9FA" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Order Count" FontSize="13" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding CurrentShiftData.OrderCount}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="1" Background="#F8F9FA" CornerRadius="6" Padding="12" Margin="4,0,4,0">
                                    <StackPanel>
                                        <TextBlock Text="From Date" FontSize="13" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding CurrentShiftData.FromDate, Converter={StaticResource CountryBasedDateConverter}}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="2" Background="#F8F9FA" CornerRadius="6" Padding="12" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="To Date" FontSize="13" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding CurrentShiftData.ToDate, Converter={StaticResource CountryBasedDateConverter}}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                    <Border Grid.Row="1" Grid.Column="0" Background="#F8F9FA" CornerRadius="6" Padding="12" Margin="0,3,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Total Amount" FontSize="13" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding CurrentShiftData.TotalOrderAmount, Converter={StaticResource CurrencyFormatConverter}}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" Background="#F8F9FA" CornerRadius="6" Padding="12" Margin="4,3,4,0">
                                    <StackPanel>
                                        <TextBlock Text="Total Card Amount" FontSize="13" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding CurrentShiftData.TotalCardAmount, Converter={StaticResource CurrencyFormatConverter}}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                    <Border Grid.Row="1" Grid.Column="2" Background="#F8F9FA" CornerRadius="6" Padding="12" Margin="8,3,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Total Cash Amount" FontSize="13" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding CurrentShiftData.TotalCashAmount, Converter={StaticResource CurrencyFormatConverter}}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Background="#F8F9FA" CornerRadius="6" Padding="12,5,12,12" Margin="0,12,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" MaxHeight="320">
                                    <ScrollViewer.Resources>
                                        <!-- Apply thicker scrollbar style defined in Stylesxaml.xaml -->
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                                    </ScrollViewer.Resources>
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Login Time" FontWeight="SemiBold" Foreground="Black" FontSize="14" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="Logout Time" FontWeight="SemiBold" Foreground="Black" FontSize="14" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="Duration" FontWeight="SemiBold" Foreground="Black" FontSize="14" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="Orders" FontWeight="SemiBold" Foreground="Black" FontSize="14" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="4" Text="Amount" FontWeight="SemiBold" Foreground="Black" FontSize="14" HorizontalAlignment="Right" Margin="20,0,0,0"/>
                                                <TextBlock Grid.Column="5" Text="Status" FontWeight="SemiBold" Foreground="Black" FontSize="14" HorizontalAlignment="Center"/>
                                            </Grid>
                                            <!-- Empty-state message controlled by ItemsControl.HasItems -->
                                            <TextBlock Text="No shift records found for the selected date range." 
                                                       HorizontalAlignment="Center" Margin="0,16,0,16" FontSize="13" Foreground="#6B7280"
                                                       Visibility="{Binding ElementName=ShiftDetailsItems, Path=HasItems, Converter={StaticResource InvertBooleanToVisibilityConverter}}"/>

                                            <ItemsControl x:Name="ShiftDetailsItems" ItemsSource="{Binding PagedShiftDetails}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="Transparent" Padding="8,6" Margin="0,2,0,0" CornerRadius="4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="115"/>
                                                                    <ColumnDefinition Width="115"/>
                                                                    <ColumnDefinition Width="105"/>
                                                                    <ColumnDefinition Width="50"/>
                                                                    <ColumnDefinition Width="140"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding LoginTime, StringFormat=HH:mm:ss}" FontSize="13" HorizontalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding LogoutTime, StringFormat=HH:mm:ss}" FontSize="13" HorizontalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding ShiftDuration}" FontSize="13" HorizontalAlignment="Center"/>
                                                                <TextBlock Grid.Column="3" Text="{Binding OrderCount}" FontSize="13" HorizontalAlignment="Center"/>
                                                                <TextBlock Grid.Column="4" Text="{Binding TotalAmount, Converter={StaticResource CurrencyFormatConverter}}" FontSize="13" HorizontalAlignment="Right" Margin="10,0,0,0"/>
                                                                <Border Grid.Column="5" CornerRadius="8" Padding="5,3" HorizontalAlignment="Center">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#4CAF50"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding ActiveShift}" Value="False">
                                                                                    <Setter Property="Background" Value="#E53935"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock x:Name="StatusText" Text="{Binding ActiveShift, Converter={StaticResource BooleanToStringConverter}, ConverterParameter='Active|Inactive'}" FontSize="13" HorizontalAlignment="Center" Foreground="White"/>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                           
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                                <!-- Pagination Controls -->
                                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="8,2" VerticalAlignment="Center">
                                    <Button Content="First" Command="{Binding FirstShiftPageCommand}" Margin="0,0,8,0" Padding="10,6" BorderBrush="Transparent" Background="#1976D2" Foreground="White" VerticalAlignment="Center"/>
                                    <Button Command="{Binding PrevShiftPageCommand}" Margin="0,0,8,0" Padding="10,6" BorderBrush="Transparent" Background="#1976D2" Foreground="White" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="NavigateBefore" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                    </Button>
                                    <TextBlock Text="{Binding ShiftPageInfoText}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13" FontWeight="SemiBold"/>
                                    <Button Command="{Binding NextShiftPageCommand}" Margin="0,0,8,0" Padding="10,6" BorderBrush="Transparent" Background="#1976D2" Foreground="White" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="NavigateNext" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                    </Button>
                                    <Button Content="Last" Command="{Binding LastShiftPageCommand}" Padding="10,6" BorderBrush="Transparent" Background="#1976D2" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="Close" Width="100" Background="LightGray" Foreground="Black" BorderThickness="0" Height="32" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"/>
                        </StackPanel>
                        
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>

        <!-- DialogHost overlay for User Details dialog -->
        <materialDesign:DialogHost x:Name="UserDetailsDialogHost" IsOpen="{Binding IsUserDetailsDialogOpen, Mode=TwoWay}" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
            <materialDesign:DialogHost.DialogContent>
                <Border Background="#FFFFFF" CornerRadius="10" Padding="20" Width="520">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="45"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="44" Height="44" CornerRadius="22" Background="#E8F0FE" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Account" Width="24" Height="24" Foreground="#1E88E5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="User Details" FontWeight="Bold" FontSize="18"/>
                                    <TextBlock Text="Profile Information" Foreground="#6B7280" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,0,0" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Style="{StaticResource MaterialDesignToolButton}">
                                <materialDesign:PackIcon Kind="Close" Width="24" Height="24" Foreground="Black"/>
                            </Button>
                        </Grid>
                        <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="14" Margin="0,12,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" Foreground="#6B7280" FontSize="14"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedUserDetails.ApiId}" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="First Name" Foreground="#6B7280" FontSize="14"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedUserDetails.FirstName}" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Name" Foreground="#6B7280" FontSize="14"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedUserDetails.LastName}" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Contact No" Foreground="#6B7280" FontSize="14"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedUserDetails.Phone}" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Email" Foreground="#6B7280" FontSize="14"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedUserDetails.Email}" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Address" Foreground="#6B7280" FontSize="14"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedUserDetails.Address}" TextWrapping="Wrap" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Role ID" Foreground="#6B7280" FontSize="14"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedUserDetails.RoleId}" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Role" Foreground="#6B7280" FontSize="14"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedUserDetails.Role}" FontWeight="SemiBold" FontSize="14"/>
                            </Grid>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Content="Close" Width="110" Height="36" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Style="{StaticResource MaterialDesignRaisedButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>
    </Grid>
    </materialDesign:DialogHost>
</Page> 
