                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20" Foreground="#6B7280"/>
                                                    <TextBlock Text="No active cash drawer session. Click Start Shift to begin." FontSize="20" Margin="8,0,0,0" Foreground="#6B7280"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                </StackPanel>
                            </TabItem>
                            <TabItem Header="Cash In/Out" Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=True}">
