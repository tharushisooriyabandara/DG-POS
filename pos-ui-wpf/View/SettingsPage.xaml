                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            
                                            <TextBlock Margin="10,0,0,0" FontSize="22" FontWeight="Bold"
                                                       Text="{Binding ActiveCashDrawerSession.ClosingBalanceExpected, Converter={StaticResource CurrencyFormatConverter}}"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=True}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Current Shift" FontWeight="SemiBold" FontSize="16" Margin="0,10,0,6"/>
                                            <TextBlock Text="{Binding ActiveCashDrawerSession.Id,StringFormat='ID : {0}'}" FontWeight="SemiBold" FontSize="16" Margin="8,10,0,6"/>
                                            </StackPanel>
                                            <Border Grid.Row="1" Visibility="{Binding HasActiveCashDrawerSession, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Background="#FFFFFF" CornerRadius="10" Padding="14" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,6,0,0">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="72"/>
                                                        <RowDefinition Height="72"/>
                                                        <RowDefinition Height="72"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Row 0 -->
                                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <materialDesign:PackIcon Kind="ClockOutline" Width="22" Height="22" Margin="0,6,0,0" Foreground="#6B7280"/>
                                                                <StackPanel Orientation="Vertical">
                                                                    <TextBlock Text="Opened At" Margin="6,0,0,0" FontWeight="SemiBold" FontSize="17"/>
                                                                    <TextBlock Text="{Binding ActiveCashDrawerSession.OpenedAt, Converter={StaticResource CountryBasedDateConverter}}" FontSize="17" Margin="6,2,0,6" Foreground="#111827"/>
                                                                </StackPanel>
                                                        </StackPanel>
                                                            
                                                    </StackPanel>
                                                    <!--<StackPanel Grid.Row="0" Grid.Column="1">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <materialDesign:PackIcon Kind="Wallet" Width="22" Height="22" Margin="0,6,0,0" Foreground="#6B7280"/>
                                                                <StackPanel Orientation="Vertical">
                                                                    <TextBlock Text="Opening Balance" Margin="6,0,0,0" FontWeight="SemiBold" FontSize="17"/>
                                                                    <TextBlock Text="{Binding ActiveCashDrawerSession.OpeningBalance, StringFormat=Rs {0:N2}}" FontSize="17" Margin="6,2,0,0"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                            
                                                    </StackPanel>-->
                                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <materialDesign:PackIcon Kind="Account" Width="22" Height="22" Margin="0,6,0,0" Foreground="#6B7280"/>
                                                                <StackPanel Orientation="Vertical">
                                                                    <TextBlock Text="Shift Started By" Margin="6,0,0,0" FontWeight="SemiBold" FontSize="17"/>
                                                                    <TextBlock Text="{Binding ActiveCashDrawerSession.SessionStartedUser}" Margin="6,2,0,0" FontSize="17"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </StackPanel>

                                                    <!-- Row 1 -->
                                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <materialDesign:PackIcon Kind="CashPlus" Width="22" Height="22" Margin="0,6,0,0" Foreground="#6B7280"/>
                                                                <StackPanel Orientation="Vertical">
                                                                    <TextBlock Text="Cash In" Margin="6,0,0,0" FontWeight="SemiBold" FontSize="17"/>
                                                                    <TextBlock Text="{Binding ActiveCashDrawerSession.TotalInAmount, Converter={StaticResource CurrencyFormatConverter}}" FontSize="17" Margin="6,2,0,6"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                        </StackPanel>
                                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <materialDesign:PackIcon Kind="CashMinus" Width="22" Height="22" Margin="0,6,0,0" Foreground="#6B7280" />
                                                                <StackPanel Orientation="Vertical">
                                                                    <TextBlock Text="Cash Out" Margin="6,0,0,0" FontWeight="SemiBold" FontSize="17"/>
                                                                    <TextBlock Text="{Binding ActiveCashDrawerSession.TotalOutAmount, Converter={StaticResource CurrencyFormatConverter}}" Margin="6,2,0,0" FontSize="17"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                        </StackPanel>

                                                        <StackPanel Grid.Row="2" Grid.Column="1">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <materialDesign:PackIcon Kind="CashRegister" Width="22" Height="22" Margin="0,6,0,0" Foreground="#6B7280" />
                                                                <StackPanel Orientation="Vertical">
                                                                    <TextBlock Text="Other Sales" Margin="6,0,0,0" FontWeight="SemiBold" FontSize="17"/>
                                                                    <TextBlock Text="{Binding ActiveCashDrawerSession.OtherSalesAmount, Converter={StaticResource CurrencyFormatConverter}}" Margin="6,2,0,0" FontSize="17"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                        </StackPanel>
                                                    <StackPanel Grid.Row="0" Grid.Column="2">
