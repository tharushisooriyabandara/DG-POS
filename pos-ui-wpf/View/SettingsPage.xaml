                                                Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=True}"
                                                IsEnabled="{Binding HasActiveCashDrawerSession}"
                                                Command="{Binding OpenEndShiftDialogCommand}"/>
                                        <Button Content="Cash In" FontSize="17"
                                                Width="220" Height="50"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
