                                                                    <TextBlock Text="{Binding ActiveCashDrawerSession.Status}" Margin="6,0,0,0" Foreground="#065F46" FontWeight="SemiBold" FontSize="17"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>

                                                    <!-- Row 2 -->
                                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <materialDesign:PackIcon Kind="CashRegister" Width="22" Height="22" Margin="0,6,0,0" Foreground="#6B7280" />
                                                                <StackPanel Orientation="Vertical">
                                                                    <TextBlock Text="POS Sales" Margin="6,0,0,0" FontWeight="SemiBold" FontSize="17"/>
                                                                    <TextBlock Text="{Binding ActiveCashDrawerSession.TotalSalesAmount, Converter={StaticResource CurrencyFormatConverter}}" FontSize="17" Margin="6,2,0,8"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                        </StackPanel>
                                                    <!--<StackPanel Grid.Row="2" Grid.Column="1">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <materialDesign:PackIcon Kind="Autorenew" Width="22" Height="22" Margin="0,6,0,0" Foreground="#6B7280"/>
                                                                <StackPanel Orientation="Vertical">
                                                                    <TextBlock Text="Refund Amount" Margin="6,0,0,0" FontWeight="SemiBold" FontSize="17"/>
                                                                    <TextBlock Text="{Binding ActiveCashDrawerSession.TotalRefundAmount, StringFormat=Rs {0:N2}}" FontSize="17" Margin="6,2,0,0"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </StackPanel>-->
                                                </Grid>
                                            </Border>
                                        </Grid>

                                        <Border Visibility="{Binding HasActiveCashDrawerSession, Converter={StaticResource InvertBooleanToVisibilityConverter}}"
