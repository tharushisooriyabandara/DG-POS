                                                       TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                            <!--<TextBlock Grid.Column="2" Text="Movement ID" FontWeight="Bold" Foreground="#1976D2" Margin="20,0,0,0"
                                                       TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>-->
                                            <TextBlock Grid.Column="1" Text="User Name" FontWeight="Bold" Foreground="#1976D2" Margin="-30,0,0,0"
                                                       TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="Created At" FontWeight="Bold" Foreground="#1976D2" Margin="-50,0,0,0"
                                                       TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="Movement Type" FontWeight="Bold" Foreground="#1976D2" Margin="-35,0,0,0"
                                                       TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="Amount" FontWeight="Bold" Foreground="#1976D2" Margin="-40,0,0,0"
                                                       TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- Table Rows -->
                                        <ScrollViewer Grid.Row="1" MaxHeight="400" VerticalScrollBarVisibility="Auto" Visibility="{Binding HasNoCashTransactions, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                                            <ItemsControl ItemsSource="{Binding CashDrawerTransactions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="10,8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    
                                                                    <ColumnDefinition Width="120"/>
                                                                   
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="250"/>
                                                                    <ColumnDefinition Width="160"/>
                                                                    <ColumnDefinition Width="200"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Cash Drawer ID -->
                                                                <!--<TextBlock Grid.Column="0" Text="{Binding CashDrawerId}" 
                                                                           FontSize="14" Foreground="#333"  Padding="0,4"
                                                                           TextAlignment="Center" VerticalAlignment="Center"/>-->

                                                                <!-- Cash Drawer Session ID -->
                                                                <TextBlock Grid.Column="0" Text="{Binding CashDrawerSessionId}" 
                                                                           FontSize="14"  Foreground="#333" Padding="0,4"
                                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                                <!-- Cash Movement ID -->
                                                                <!--<TextBlock Grid.Column="2" Text="{Binding CashMovementId}" 
                                                                           FontSize="14"  Foreground="#333" Padding="0,4"
                                                                           TextAlignment="Center" VerticalAlignment="Center"/>-->

                                                                <!-- User Name -->
                                                                <TextBlock Grid.Column="1" Text="{Binding UserName}" 
                                                                           FontSize="14"  Foreground="#333" Padding="0,4"
                                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                                <!-- Created At -->
                                                                    <TextBlock Grid.Column="2" Text="{Binding CreatedAt, StringFormat='MMM dd, yyyy HH:mm'}" 
                                                                           FontSize="14" Foreground="#333" Padding="0,4"
                                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                                <!-- Movement Type -->
                                                                <TextBlock Grid.Column="3" Text="{Binding MovementType}" 
                                                                           FontSize="14"  Foreground="#333" Padding="0,4"
                                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                                <!-- Amount -->
                                                                <TextBlock Grid.Column="4" Text="{Binding Amount, Converter={StaticResource CurrencyFormatConverter}}" 
                                                                           FontSize="14" Foreground="#333" Padding="0,4"
                                                                           TextAlignment="Center" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <!-- Pagination Footer -->
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,10,0,10" Visibility="{Binding HasNoCashTransactions, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                                            <Button Content="First" Command="{Binding CashTransactionFirstPageCommand}" 
                                                    Margin="0,0,8,0" Padding="10,6" BorderBrush="Transparent" 
                                                    Background="#1976D2" Foreground="White"/>
                                            <Button Command="{Binding CashTransactionPrevPageCommand}" Margin="0,0,8,0" 
                                                    Padding="10,6" BorderBrush="Transparent" 
                                                    Background="#1976D2" Foreground="White">
                                                <materialDesign:PackIcon Kind="NavigateBefore" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                            </Button>

                                            <TextBlock Text="{Binding CashTransactionPageInfoText}" VerticalAlignment="Center" 
                                                       Margin="0,0,8,0" FontSize="14" Foreground="#666"/>

                                            <Button Command="{Binding CashTransactionNextPageCommand}" Margin="0,0,8,0" 
                                                    Padding="10,6" BorderBrush="Transparent" 
                                                    Background="#1976D2" Foreground="White">
                                                <materialDesign:PackIcon Kind="NavigateNext" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                            </Button>
                                            <Button Content="Last" Command="{Binding CashTransactionLastPageCommand}" 
                                                    Padding="10,6" BorderBrush="Transparent" 
                                                    Background="#1976D2" Foreground="White"/>
                                        </StackPanel>

                                        <!-- No Data Message -->
                                        <TextBlock Grid.Row="0" Grid.RowSpan="3" Text="No cash transactions found for the selected date range." 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="16" Foreground="Gray" Margin="0,70,0,0"
                                                   Visibility="{Binding HasNoCashTransactions, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </Grid>
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="Cash Session" FontSize="16" Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=True}">
                                <TabItem.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="Cash Session" FontWeight="Bold" FontSize="19"/>
                                    </DataTemplate>
                                </TabItem.HeaderTemplate>
                                <Grid Margin="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="368"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Date Filter Section -->
                                            <Grid Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Right">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="From Date:" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13" />
                                                <DatePicker Grid.Column="1" SelectedDate="{Binding FromDate}" Margin="0,0,20,0" FontSize="13" VerticalAlignment="Center"
                                                    IsDropDownOpen="False" DisplayDateEnd="{x:Static sys:DateTime.Today}"
                                                    PreviewMouseLeftButtonDown="DatePicker_FocusOpen"
                                                    PreviewTouchDown="DatePicker_FocusOpen"
                                                    Loaded="DatePicker_Loaded"
                                                    Language="{converters:CountryToLanguageExtension}"/>
                                                <TextBlock Text="To Date:" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
                                                <DatePicker Grid.Column="3" SelectedDate="{Binding ToDate}" Margin="0,0,8,0" FontSize="13" VerticalAlignment="Center"
                                                    IsDropDownOpen="False" DisplayDateEnd="{x:Static sys:DateTime.Today}"
                                                    PreviewMouseLeftButtonDown="DatePicker_FocusOpen"
                                                    PreviewTouchDown="DatePicker_FocusOpen"
                                                    Loaded="DatePicker_Loaded"
                                                    Language="{converters:CountryToLanguageExtension}"/>
                                                <StackPanel Orientation="Horizontal" Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Button Content="Clear" Width="70" Height="32" Margin="10,0,10,0" VerticalAlignment="Center" Background="White" Foreground="#1976D2" BorderBrush="#1976D2"
                                                    Command="{Binding ClearCashSessionDatesCommand}" />
                                                    <Button Content="Load Sessions" Width="120" Height="32" Background="#1976D2" Foreground="White" HorizontalAlignment="Right"
                                                    Command="{Binding LoadCashSessionsCommand}" IsEnabled="{Binding IsLoadingCashSessions, Converter={StaticResource InvertBooleanConverter}}"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Loading Indicator -->
                                            <controls2:LoadingIndicator HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center" Margin="0,50,0,0"
                                                        ProgressRingSize="70"
                                                        Visibility="{Binding IsLoadingCashSessions, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                            <!-- Cash Sessions Table -->
                                            <Grid  Grid.Row="1" Visibility="{Binding IsLoadingCashSessions, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    
                                                </Grid.RowDefinitions>

                                                <!-- Table Header -->
                                                <Grid Grid.Row="0" Background="Transparent" Visibility="{Binding HasNoCashSessions, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="170"/>
                                                        <ColumnDefinition Width="170"/>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="120"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="ID" FontWeight="Bold" Foreground="#1976D2" Margin="15,0,0,0"
                                                       TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="Started By User" FontWeight="Bold" Foreground="#1976D2" Margin="20,0,0,0"
                                                       TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="Ended By User" FontWeight="Bold" Foreground="#1976D2" Margin="10,0,0,0"
                                                       TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="Opening Time" FontWeight="Bold" Foreground="#1976D2" Margin="-5,0,0,0"
                                                       TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="4" Text="Closing Time" FontWeight="Bold" Foreground="#1976D2" Margin="-10,0,0,0"
                                                       TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="5" Text="Expected Balance" FontWeight="Bold" Foreground="#1976D2" 
                                                       TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="6" Text="Actions" FontWeight="Bold" Foreground="#1976D2" Margin="-15,0,0,0"
                                                       TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                                </Grid>

                                                <!-- Table Rows -->
                                                <ScrollViewer Grid.Row="1" MaxHeight="400" VerticalScrollBarVisibility="Auto" Visibility="{Binding HasNoCashSessions, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                                                    <ItemsControl ItemsSource="{Binding CashDrawerSessions}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="10,9">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="80"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="160"/>
                                                                            <ColumnDefinition Width="160"/>
                                                                            <ColumnDefinition Width="180"/>
                                                                            <ColumnDefinition Width="120"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- Session ID -->
                                                                        <TextBlock Grid.Column="0" Text="{Binding Id}" 
                                                                           FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                                        <!-- Started By User -->
                                                                        <TextBlock Grid.Column="1" Text="{Binding SessionStartedUser}" 
                                                                           FontSize="14" Foreground="#333" 
                                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                                        <!-- Ended By User -->
                                                                        <TextBlock Grid.Column="2" Text="{Binding SessionEndedUser}" 
                                                                           FontSize="14" Foreground="#333" 
                                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                                        <!-- Opening Time -->
                                                                        <TextBlock Grid.Column="3" Text="{Binding OpenedAt, StringFormat='MMM dd, yyyy HH:mm'}" 
                                                                           FontSize="14" Foreground="#333" 
                                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                                        <!-- Closing Time -->
                                                                        <TextBlock Grid.Column="4" Text="{Binding ClosedAt, StringFormat='MMM dd, yyyy HH:mm'}" 
                                                                           FontSize="14" Foreground="#333" 
                                                                           TextAlignment="Center" VerticalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="Not Closed"/>
                                                                                    <Setter Property="Foreground" Value="Gray"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding ClosedAt}" Value="{x:Null}">
                                                                                            <Setter Property="Text" Value="Not Closed"/>
                                                                                            <Setter Property="Foreground" Value="Gray"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>

                                                                        <!-- Expected Balance -->
                                                                        <TextBlock Grid.Column="5" Text="{Binding ClosingBalanceExpected, Converter={StaticResource CurrencyFormatConverter}}" 
                                                                           FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                                                           TextAlignment="Center" VerticalAlignment="Center"/>

                                                                        <!-- View Button -->
                                                                        <Button Grid.Column="6" Content="View" 
                                                                        Background="#1976D2" Foreground="White" 
                                                                        BorderBrush="Transparent" FontSize="14" 
                                                                        Width="90" Height="30" 
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Click="ViewCashSession_Click"
                                                                        Tag="{Binding}"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>

                                                <!-- No Data Message -->
                                                <TextBlock Grid.Row="0" Grid.RowSpan="2" Text="No shifts found for the selected date range." 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="16" Foreground="Gray" Margin="0,50,0,0"
                                                   Visibility="{Binding HasNoCashSessions, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            
                                            </Grid>
                                            
                                            <!-- Pagination Footer (stick to bottom of the tab) -->
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,10,0,0" Visibility="{Binding HasNoCashSessions, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                                                <Button Content="First" Command="{Binding CashSessionFirstPageCommand}" 
                                                         Margin="0,0,8,0" Padding="10,6" BorderBrush="Transparent" 
                                                         Background="#1976D2" Foreground="White"/>
                                                <Button Command="{Binding CashSessionPrevPageCommand}" Margin="0,0,8,0" 
                                                         Padding="10,6" BorderBrush="Transparent" 
                                                         Background="#1976D2" Foreground="White">   
                                                    <materialDesign:PackIcon Kind="NavigateBefore" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                </Button>

                                                <TextBlock Text="{Binding CashSessionPageInfoText}" VerticalAlignment="Center" 
                                                            Margin="0,0,8,0" FontSize="14" Foreground="#666"/>

                                                <Button Command="{Binding CashSessionNextPageCommand}" Margin="0,0,8,0" 
                                                         Padding="10,6" BorderBrush="Transparent" 
                                                         Background="#1976D2" Foreground="White">   
                                                    <materialDesign:PackIcon Kind="NavigateNext" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                </Button>
                                                <Button Content="Last" Command="{Binding CashSessionLastPageCommand}" 
                                                         Padding="10,6" BorderBrush="Transparent" 
                                                         Background="#1976D2" Foreground="White"/>
                                            </StackPanel>
                                        </Grid>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                </Border>
                
                <!-- Menu Tab - Cashier Menu Configuration -->
                <Border Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Menu}"
                    Background="White" CornerRadius="12" Margin="10,74,10,20" Padding="20,20,20,20" BorderBrush="#E0E0E0" BorderThickness="1" Grid.Row="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Cashier Menu Tabs" FontSize="20" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock Text="Configure up to 5 tabs for your cashier menu (1 default + 4 custom tabs)" 
                                           FontSize="13" Foreground="Gray"/>
                            </StackPanel>
                            
                            <Button Grid.Column="1" Content="Refresh" Width="100" Height="38" BorderBrush="#4CAF50"
                                    Background="#4CAF50" Foreground="White" FontWeight="SemiBold" FontSize="13"
                                    Command="{Binding LoadMenuConfigCommand}"
                                    VerticalAlignment="Top" Margin="0,0,0,0"/>
                        </Grid>

                        <!-- Content area -->
                        <Grid Grid.Row="1" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Menu Tabs in 2-column Grid -->
                            <ItemsControl Grid.Row="0" ItemsSource="{Binding MenuTabs}"
                                        Visibility="{Binding IsLoadingMenuConfig, Converter={StaticResource InvertBooleanToVisibilityConverter}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="2" HorizontalAlignment="Stretch"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F8F9FA" CornerRadius="12" Padding="15" Margin="0,0,10,15" 
                                                        BorderBrush="#E0E0E0" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Tab Order -->
                                                        <Border Grid.Column="0" Background="#1976D2" CornerRadius="8" Width="40" Height="40" 
                                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Order}" FontSize="18" FontWeight="Bold" 
                                                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>

                                                        <!-- Tab Info -->
                                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Background="#E3F2FD" CornerRadius="4" Padding="6,3" Margin="0,0,8,0">
                                                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                                                        <Run Text="{Binding ContentType, Mode=OneWay}" Foreground="#1976D2"/>
                                                                    </TextBlock>
                                                                </Border>
                                                                <Border Background="#FFF3E0" CornerRadius="4" Padding="6,3" 
                                                                        Visibility="{Binding IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <TextBlock Text="DEFAULT" FontSize="11" FontWeight="SemiBold" Foreground="#F57C00"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <!-- Move Up/Down Buttons -->
                                                        <StackPanel Grid.Column="2" Orientation="Vertical" Margin="10,0" VerticalAlignment="Center"
                                                                    Visibility="{Binding IsDefault, Converter={StaticResource InvertBooleanToVisibilityConverter}}">
                                                            <Button Width="45" Height="32" Margin="0,0,0,5" FontSize="15"
                                                                    Background="#EEEEEE" Foreground="#333333" BorderThickness="1" BorderBrush="#CCCCCC"
                                                                    materialDesign:ButtonAssist.CornerRadius="6"
                                                                    Cursor="Hand"
                                                                    Command="{Binding DataContext.MoveTabUpCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                    CommandParameter="{Binding}">
                                                                <TextBlock Text="▲" FontSize="15" FontWeight="Bold"/>
                                                            </Button>
                                                            <Button Width="45" Height="32" FontSize="15"
                                                                    Background="#EEEEEE" Foreground="#333333" BorderThickness="1" BorderBrush="#CCCCCC"
                                                                    materialDesign:ButtonAssist.CornerRadius="6"
                                                                    Cursor="Hand"
                                                                    Command="{Binding DataContext.MoveTabDownCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                    CommandParameter="{Binding}">
                                                                <TextBlock Text="▼" FontSize="15" FontWeight="Bold"/>
                                                            </Button>
                                                        </StackPanel>

                                                        <!-- Edit/Delete Buttons -->
                                                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                                                            <Button Content="Edit" Width="85" Height="38" Margin="4,0" FontSize="14"
                                                                    Background="#2196F3" Foreground="White" FontWeight="SemiBold"
                                                                    materialDesign:ButtonAssist.CornerRadius="6"
                                                                    Cursor="Hand"
                                                                    Command="{Binding DataContext.EditMenuTabCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                    CommandParameter="{Binding}"
                                                                    Visibility="{Binding IsDefault, Converter={StaticResource InvertBooleanToVisibilityConverter}}"/>
                                                            <Button Content="Delete" Width="85" Height="38" Margin="4,0" FontSize="14"
                                                                    Background="#F44336" Foreground="White" FontWeight="SemiBold"
                                                                    materialDesign:ButtonAssist.CornerRadius="6"
                                                                    Cursor="Hand" BorderBrush="#F44336"
                                                                    Command="{Binding DataContext.DeleteMenuTabCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                    CommandParameter="{Binding}"
                                                                    Visibility="{Binding IsDefault, Converter={StaticResource InvertBooleanToVisibilityConverter}}"/>
                                                            
                                                            <!-- Default tab info (no edit/delete) -->
                                                            <TextBlock Text="(API)" FontSize="11" Foreground="Gray" 
                                                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                                                       Visibility="{Binding IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                            
                            <!-- Bottom: Action Buttons -->
                            <StackPanel Grid.Row="1" Margin="0,15,0,0"
                                        Visibility="{Binding IsLoadingMenuConfig, Converter={StaticResource InvertBooleanToVisibilityConverter}}">
                                
                                <!-- Add New Tab Button -->
                                <Button Content="+ Add New Tab" Width="250" Height="50" Margin="0,0,0,10" FontSize="15"
                                        Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderBrush="#4CAF50"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Cursor="Hand"
                                        Command="{Binding AddMenuTabCommand}"
                                        Visibility="{Binding CanAddMoreTabs, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                
                                <!-- Max Tabs Warning -->
                                <TextBlock Text="Maximum 5 tabs reached" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="#FF9800" Margin="0,0,0,10" TextAlignment="Center"
                                           Visibility="{Binding CanAddMoreTabs, Converter={StaticResource InvertBooleanToVisibilityConverter}}"/>

                                <!-- Save Changes Button -->
                                <Button Content="Save Menu Configuration" Width="280" Height="50" Margin="0,0,0,0" FontSize="15"
                                        Background="#1976D2" Foreground="White" FontWeight="Bold"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Cursor="Hand"
                                        Command="{Binding SaveMenuConfigCommand}"
                                        Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                            
                            <!-- Loading indicator -->
                            <controls2:LoadingIndicator Grid.Row="0" Grid.RowSpan="2"
                                                        HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center" 
                                                        ProgressRingSize="70"
                                                        Visibility="{Binding IsLoadingMenuConfig, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Grid>
                </Border>
                
                <!-- Floor Plan Tab -->
                <Border Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Floor Plan}"
                    Background="White" CornerRadius="12" Margin="10,74,10,20" Padding="20,20,20,20" BorderBrush="#E0E0E0" BorderThickness="1" Grid.Row="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Floor Plans" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Create and arrange dine-in table layouts with drag &amp; drop customization." FontSize="13" Foreground="Gray" Margin="0,0,0,14"/>

                            <Grid VerticalAlignment="Center" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="FloorPlan" Width="25" Height="25" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" Margin="0,0,20,0">
                                    <TextBlock Text="Use floor plan for table selection" FontSize="15" FontWeight="Medium"/>
                                    <TextBlock Text="When on, Cashier dine-in opens your designed layouts instead of the default table grid. When off, behavior is unchanged." FontSize="14" Opacity="0.6" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="2"
                                              IsChecked="{Binding IsFloorPlanLayoutEnabled}"
                                              IsEnabled="{Binding CanEditFloorPlanSettings}"
                                              Style="{StaticResource MaterialSwitchToggle}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <!-- Floor plans list (editor opens full-screen overlay like Custom Menu) -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FloorPlans}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2" HorizontalAlignment="Stretch"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F8F9FA" CornerRadius="12" Padding="15" Margin="0,0,10,15"
                                                    BorderBrush="#E0E0E0" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" TextAlignment="Left"/>
                                                        <TextBlock Text="{Binding TableCount, StringFormat=Tables: {0}}" FontSize="12" Foreground="Gray" Margin="0,5,0,0" TextAlignment="Left"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Content="Edit" Width="85" Height="38" Margin="4,0"
                                                                Background="#2196F3" Foreground="White" FontWeight="SemiBold" FontSize="14"
                                                                materialDesign:ButtonAssist.CornerRadius="6"
                                                                Cursor="Hand"
                                                                Command="{Binding DataContext.EditFloorPlanCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding}"/>
                                                        <Button Content="Delete" Width="85" Height="38" Margin="4,0"
                                                                Background="#F44336" Foreground="White" FontWeight="SemiBold" FontSize="14"
                                                                BorderBrush="#F44336"
                                                                materialDesign:ButtonAssist.CornerRadius="6"
                                                                Cursor="Hand"
                                                                Command="{Binding DataContext.DeleteFloorPlanCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Button Grid.Row="1" Content="+ Add New Floor Plan"
                                    Width="250" Height="50" Margin="0,15,0,0"
                                    FontSize="15" FontWeight="Bold"
                                    Background="#4CAF50" Foreground="White" BorderBrush="#4CAF50"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Cursor="Hand"
                                    Command="{Binding AddFloorPlanCommand}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Configure Orders Tab with Subtabs -->
                <Border Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Configure Orders}"
                        Background="White" CornerRadius="12" Margin="10,74,10,20" Padding="0,0,0,0" BorderBrush="#E0E0E0" BorderThickness="1" Grid.Row="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Configure Orders Subtabs -->
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="16,18,16,6" VerticalAlignment="Center">
                            <Button Content="General"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource SettingsSubNavTabButtonStyle}"
                                    Command="{Binding SwitchConfigureOrdersSubTabCommand}"
                                    CommandParameter="OrdersPage"
                                    Background="{Binding SelectedConfigureOrdersSubTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=OrdersPage}"
                                    Foreground="{Binding SelectedConfigureOrdersSubTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=OrdersPage}"/>
                            <Button Content="Auto complete Orders"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource SettingsSubNavTabButtonStyle}"
                                    Command="{Binding SwitchConfigureOrdersSubTabCommand}"
                                    CommandParameter="AutoCompleteOrders"
                                    Background="{Binding SelectedConfigureOrdersSubTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=AutoCompleteOrders}"
                                    Foreground="{Binding SelectedConfigureOrdersSubTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=AutoCompleteOrders}"/>
                            <Button Content="Item Discounts"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource SettingsSubNavTabButtonStyle}"
                                    Command="{Binding SwitchConfigureOrdersSubTabCommand}"
                                    CommandParameter="ItemDiscounts"
                                    Background="{Binding SelectedConfigureOrdersSubTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=ItemDiscounts}"
                                    Foreground="{Binding SelectedConfigureOrdersSubTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=ItemDiscounts}"/>
                        </StackPanel>

                        <!-- Orders Page Subtab Content -->
                        <Grid Grid.Row="1" Visibility="{Binding SelectedConfigureOrdersSubTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=OrdersPage}" Margin="20,10,20,20">
                            <StackPanel>
                                <!-- Title -->
                                <TextBlock Text="Orders Page Configuration"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Margin="0,0,0,8"/>
                                <!-- Description -->
                                <TextBlock Text="Choose which page should open when accessing orders."
                                    FontSize="13"
                                    Opacity="0.7"
                                    Margin="0,0,0,20"/>

                                <!-- Toggle Section -->
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Orders Icon -->
                                    <materialDesign:PackIcon Kind="ClipboardTextOutline"
                                                        Width="25"
                                                        Height="25"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,10,0"/>
                                    <!-- Label -->
                                    <StackPanel Grid.Column="1" Margin="0,0,20,0">
                                        <TextBlock Text="Enable Live Orders Page"
                                            FontSize="15"
                                            FontWeight="Medium"/>
                                        <TextBlock Text="Switch between Orders view and Live Orders view."
                                            FontSize="14"
                                            Opacity="0.6"/>
                                    </StackPanel>

                                    <!-- Toggle -->
                                    <ToggleButton Grid.Column="2"
                                            IsChecked="{Binding UseLiveOrdersPage}"
                                            IsEnabled="{Binding IsGeneralOrderConfigBusy, Converter={StaticResource InvertBooleanConverter}}"
                                            Style="{StaticResource MaterialSwitchToggle}"
                                            VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Idle logout: Set timer button -->
                                <TextBlock Text="Logout Configuration"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Margin="0,30,0,8"/>
                                <Grid Margin="0,8,0,0" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="ClockOutline" Width="25" Height="25" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <StackPanel>
                                            <TextBlock Text="Idle logout" FontSize="15" FontWeight="Medium"/>
                                            <TextBlock Text="{Binding IdleLogoutMinutes, StringFormat='Log out automatically after no input in {0} minute(s). Click Set timer to update the timer.'}" FontSize="14" Opacity="0.6"/>
                                        </StackPanel>
                                        <Button Content="Set Timer" Command="{Binding OpenIdleLogoutTimerCommand}"
                                                IsEnabled="{Binding IsGeneralOrderConfigBusy, Converter={StaticResource InvertBooleanConverter}}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="SemiBold"
                                                materialDesign:ButtonAssist.CornerRadius="8" FontSize="14" Height="36" Width="120"
                                                Margin="20,2,0,0" Padding="18,8" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                            <!-- Loading overlay when loading General tab config -->
                            <Grid Background="#80FFFFFF" Panel.ZIndex="10"
                                  Visibility="{Binding IsLoadingOrderConfigForGeneral, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <controls2:LoadingIndicator HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                ProgressRingSize="70"/>
                                </StackPanel>
                            </Grid>
                            <!-- Loading overlay when saving order config -->
                            <Grid Background="#80FFFFFF" Panel.ZIndex="10"
                                  Visibility="{Binding IsSavingOrderConfig, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <controls2:LoadingIndicator HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                ProgressRingSize="70"/>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Auto complete Orders Subtab Content -->
                        <Grid Grid.Row="1" Visibility="{Binding SelectedConfigureOrdersSubTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=AutoCompleteOrders}" Margin="20,10,20,20">
                            <StackPanel>
                                <TextBlock Text="Auto complete Orders"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Margin="0,0,0,8"/>
                                <TextBlock Text="Configure automatic completion of paid POS orders."
                                    FontSize="13"
                                    Opacity="0.7"
                                    Margin="0,0,0,25"/>
                                <!-- Order Type Toggles -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Takeaway -->
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                            Text="Takeaway Orders"
                                            FontSize="15" FontWeight="SemiBold"
                                            VerticalAlignment="Center"
                                            Margin="0,0,5,8"/>

                                    <ToggleButton Grid.Row="0" Grid.Column="0"
                                                IsChecked="{Binding IncludeTakeaway}"
                                                IsEnabled="{Binding IsAutoCompleteOrderConfigBusy, Converter={StaticResource InvertBooleanConverter}}"
                                                Style="{StaticResource MaterialSwitchToggle}"
                                                VerticalAlignment="Center"
                                                Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                            Text="{Binding TakeawayTimerMinutes, StringFormat='{}{0} mins'}"
                                            FontSize="14"
                                            Opacity="0.85"
                                            VerticalAlignment="Center"
                                            Margin="0,0,0,16"
                                            Visibility="{Binding IncludeTakeaway, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Dine In -->
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                            Text="Dine-In Orders"
                                            FontSize="15" FontWeight="SemiBold"
                                            VerticalAlignment="Center"
                                            Margin="0,0,5,8"/>

                                    <ToggleButton Grid.Row="0" Grid.Column="1"
                                                IsChecked="{Binding IncludeDineIn}"
                                                IsEnabled="{Binding IsAutoCompleteOrderConfigBusy, Converter={StaticResource InvertBooleanConverter}}"
                                                Style="{StaticResource MaterialSwitchToggle}"
                                                VerticalAlignment="Center"
                                                Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                            Text="{Binding DineInTimerMinutes, StringFormat='{}{0} mins'}"
                                            FontSize="14"
                                            Opacity="0.85"
                                            VerticalAlignment="Center"
                                            Margin="0,0,0,16"
                                            Visibility="{Binding IncludeDineIn, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Delivery -->
                                    <TextBlock Grid.Row="0" Grid.Column="2"
                                            Text="Delivery Orders"
                                            FontSize="15" FontWeight="SemiBold"
                                            VerticalAlignment="Center"
                                            Margin="0,0,5,8"/>

                                    <ToggleButton Grid.Row="0" Grid.Column="2"
                                                IsChecked="{Binding IncludeDelivery}"
                                                IsEnabled="{Binding IsAutoCompleteOrderConfigBusy, Converter={StaticResource InvertBooleanConverter}}"
                                                Style="{StaticResource MaterialSwitchToggle}"
                                                VerticalAlignment="Center"
                                                Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="1" Grid.Column="2"
                                            Text="{Binding DeliveryTimerMinutes, StringFormat='{}{0} mins'}"
                                            FontSize="14"
                                            Opacity="0.85"
                                            VerticalAlignment="Center"
                                            Margin="0,0,0,16"
                                            Visibility="{Binding IncludeDelivery, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                </Grid>
                            </StackPanel>
                            <!-- Loading overlay when loading config (navigating to tab) -->
                            <Grid Background="#80FFFFFF" Panel.ZIndex="10"
                                  Visibility="{Binding IsLoadingAutoCompleteOrderConfig, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <controls2:LoadingIndicator HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                ProgressRingSize="70"/>
                                </StackPanel>
                            </Grid>
                            <!-- Loading overlay when saving (toggle off or timer save) -->
                            <Grid Background="#80FFFFFF" Panel.ZIndex="10"
                                  Visibility="{Binding IsSavingOrderConfig, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <controls2:LoadingIndicator HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                ProgressRingSize="70"/>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Item Discounts Subtab Content -->
                        <Grid Grid.Row="1" Visibility="{Binding SelectedConfigureOrdersSubTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=ItemDiscounts}" Margin="20,10,20,20">
                            <StackPanel>
                                <TextBlock Text="Quick Discount Presets"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Margin="0,0,0,8"/>
                                <TextBlock Text="Configure up to 4 quick discount buttons shown when adding items. Leave empty to skip a slot. If none are configured, defaults of 10% and 20% will be used."
                                    FontSize="13"
                                    Opacity="0.7"
                                    TextWrapping="Wrap"
                                    Margin="0,0,0,25"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Preset 1 -->
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Discount 1" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding DiscountPreset1, UpdateSourceTrigger=PropertyChanged}"
                                                     materialDesign:HintAssist.Hint="e.g. 10"
                                                     FontSize="15"
                                                     Height="38"
                                                     VerticalContentAlignment="Center"
                                                     Padding="10,0,0,0"
                                                     IsReadOnly="True"
                                                     GotFocus="DiscountPreset_GotFocus"
                                                     Tag="1"/>
                                            <TextBlock Grid.Column="1" Text="%" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Margin="6,0,0,0" Opacity="0.6"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Preset 2 -->
                                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                        <TextBlock Text="Discount 2" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding DiscountPreset2, UpdateSourceTrigger=PropertyChanged}"
                                                     materialDesign:HintAssist.Hint="e.g. 20"
                                                     FontSize="15"
                                                     Height="38"
                                                     VerticalContentAlignment="Center"
                                                     Padding="10,0,0,0"
                                                     IsReadOnly="True"
                                                     GotFocus="DiscountPreset_GotFocus"
                                                     Tag="2"/>
                                            <TextBlock Grid.Column="1" Text="%" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Margin="6,0,0,0" Opacity="0.6"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Preset 3 -->
                                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                        <TextBlock Text="Discount 3" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding DiscountPreset3, UpdateSourceTrigger=PropertyChanged}"
                                                     materialDesign:HintAssist.Hint="Optional"
                                                     FontSize="15"
                                                     Height="38"
                                                     VerticalContentAlignment="Center"
                                                     Padding="10,0,0,0"
                                                     IsReadOnly="True"
                                                     GotFocus="DiscountPreset_GotFocus"
                                                     Tag="3"/>
                                            <TextBlock Grid.Column="1" Text="%" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Margin="6,0,0,0" Opacity="0.6"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Preset 4 -->
                                    <StackPanel Grid.Column="3" Margin="0,0,0,0">
                                        <TextBlock Text="Discount 4" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding DiscountPreset4, UpdateSourceTrigger=PropertyChanged}"
                                                     materialDesign:HintAssist.Hint="Optional"
                                                     FontSize="15"
                                                     Height="38"
                                                     VerticalContentAlignment="Center"
                                                     Padding="10,0,0,0"
                                                     IsReadOnly="True"
                                                     GotFocus="DiscountPreset_GotFocus"
                                                     Tag="4"/>
                                            <TextBlock Grid.Column="1" Text="%" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Margin="6,0,0,0" Opacity="0.6"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
                <!-- User Tab Modern Layout -->
                <StackPanel Visibility="{Binding SelectedTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=User}"
                            Margin="20,74,20,10" Grid.Row="1">
                    <!-- General Information -->
                    <TextBlock Text="General Information" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                            <TextBlock Text="Logged In User"  FontWeight="SemiBold" FontSize="16" Grid.Row="0" Grid.Column="0" Margin="0,0,0,5" />
                            <!--<TextBlock Text="Shift Timer"  FontWeight="SemiBold" FontSize="16" Grid.Row="0" Grid.Column="1" Margin="0,0,0,5"/>-->
                        <Border Grid.Row="1" Grid.Column="0" Background="#FFF" CornerRadius="8" Padding="16,8" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,167,0">
                            <TextBlock  FontSize="14" Text="{Binding LoggedInUser.FullName}"/>
                        </Border>
                        <!--<Border Grid.Row="1" Grid.Column="1" Background="#FFF" CornerRadius="8" Padding="16,8" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,145,0">
                            <TextBlock Text="{Binding ShiftTimer}"  FontSize="15"/>
                        </Border>-->
                    </Grid>
                    <!-- Outlet Information -->
                    <TextBlock Text="Outlet Information" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding OutletName}"  FontSize="14" Margin="8,0,0,10"/>
                    
                    <!-- Outlet Admin Tabs -->
                    <StackPanel Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <!-- Tab Headers -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,14,0,6" VerticalAlignment="Center">
                                    <Button Grid.Column="0" Content="Shift Details"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource SettingsSubNavTabButtonStyle}"
                                    Command="{Binding SwitchAdminTabCommand}"
                                    CommandParameter="ShiftDetails"
                                    Background="{Binding SelectedAdminTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=ShiftDetails}"
                                    Foreground="{Binding SelectedAdminTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=ShiftDetails}"/>
                                    <Button Grid.Column="1" Content="User Accounts"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource SettingsSubNavTabButtonStyle}"
                                    Command="{Binding SwitchAdminTabCommand}"
                                    CommandParameter="ResetPin"
                                    Background="{Binding SelectedAdminTab, Converter={StaticResource SettingsNavTabColorConverter}, ConverterParameter=ResetPin}"
                                    Foreground="{Binding SelectedAdminTab, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=ResetPin}"/>
                                </StackPanel>

                                <!-- Search bar -->
                                <StackPanel Grid.Column="2" Visibility="{Binding SelectedAdminTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=ResetPin}" HorizontalAlignment="Right">
                                    <Border Background="#FFFFFF" CornerRadius="8" Width="380" BorderBrush="#E5E7EB" BorderThickness="1" Padding="8" Margin="0,14,0,0" HorizontalAlignment="Right">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="400"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Foreground="#6B7280" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" BorderThickness="0" Background="Transparent"  
                                                     Text="{Binding UserSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                                     materialDesign:HintAssist.Hint="Search users by Name or ID"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- ShiftDetails Tab Content -->
                        <StackPanel Visibility="{Binding SelectedAdminTab, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=ShiftDetails}">
                            <TextBlock Text="Shop Shift Information" FontWeight="SemiBold" FontSize="16" Margin="0,10,0,0"/>
                            <!-- Date Selection (matches dialog style) -->
                            <Grid Margin="0,0,0,5" HorizontalAlignment="Right">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="From Date:" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13" />
                                <DatePicker Grid.Column="1" SelectedDate="{Binding SelectedShopFromDate}" Margin="0,0,20,0" FontSize="13" VerticalAlignment="Center"
                                            IsDropDownOpen="False" DisplayDateEnd="{x:Static sys:DateTime.Today}"
                                            PreviewMouseLeftButtonDown="DatePicker_FocusOpen"
                                            PreviewTouchDown="DatePicker_FocusOpen"
                                            Loaded="DatePicker_Loaded"
                                            Language="{converters:CountryToLanguageExtension}"/>    
                                <TextBlock Text="To Date:" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
                                <DatePicker Grid.Column="3" SelectedDate="{Binding SelectedShopToDate}" Margin="0,0,8,0" FontSize="13" VerticalAlignment="Center"
                                            IsDropDownOpen="False" DisplayDateEnd="{x:Static sys:DateTime.Today}"
                                            PreviewMouseLeftButtonDown="DatePicker_FocusOpen"
                                            PreviewTouchDown="DatePicker_FocusOpen"
                                            Loaded="DatePicker_Loaded"
                                            Language="{converters:CountryToLanguageExtension}"/>    
                                <StackPanel Orientation="Horizontal" Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button  Content="Clear" Width="70" Height="32" Margin="10,0,10,0" VerticalAlignment="Center" Background="#1976D2" Foreground="White"
                                             Command="{Binding ClearShopToDateCommand}" />
                                    <Button Content="Show" Width="80" Height="32" Background="#1976D2" Foreground="White" HorizontalAlignment="Right"
                                            Command="{Binding ShowShopShiftDataCommand}" IsEnabled="{Binding IsLoadingShopShiftData, Converter={StaticResource InvertBooleanConverter}}"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Loading Indicator -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10"
                                        Visibility="{Binding IsLoadingShopShiftData, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <controls1:LoadingIndicator HorizontalAlignment="Center" 
                                            VerticalAlignment="Center" ProgressRingSize="50"/>
                                </StackPanel>
                            
                            <!-- Shop Shift Summary Cards -->
                            <Border Background="#FFF" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="8" Margin="0,0,0,5"
                                    Visibility="{Binding CurrentShopShiftData, Converter={StaticResource StringToVisibilityConverter}}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Total Order Amount Card -->
                                    <Border Grid.Row="0" Grid.Column="0" Background="#F8F9FA" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Total Order Amount" FontSize="15" Foreground="#6B7280"/>
                                            <TextBlock Text="{Binding CurrentShopShiftData.TotalOrderAmount, Converter={StaticResource CurrencyFormatConverter}}" FontSize="15" FontWeight="Bold" Margin="15,0,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Total Cash Amount Card -->
                                    <Border Grid.Row="0" Grid.Column="1" Background="#F8F9FA" CornerRadius="6" Padding="12" Margin="4,0,4,0">
