<Window x:Class="POS_UI.View.PrinterSettingsDialog"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
         Title="Printer Settings" Height="650" Width="450"
         WindowStartupLocation="CenterOwner"
         WindowStyle="None"
         ResizeMode="NoResize"
         Background="#FAFAFA"
         AllowsTransparency="True">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Printer Settings" FontWeight="Bold" FontSize="18"/>
            <Button DockPanel.Dock="Right" Width="32" Height="32" Background="Transparent" Style="{StaticResource MaterialDesignToolButton}" HorizontalAlignment="Right" BorderBrush="Transparent" Click="CancelButton_Click" ToolTip="Close">
                <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
            </Button>
        </DockPanel>
        
        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,20">
            <ScrollViewer.Resources>
                <!-- Apply thicker scrollbar style defined in Stylesxaml.xaml -->
                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
            </ScrollViewer.Resources>
            <StackPanel Margin="0,0,8,0">
                                <!-- Basic Settings -->
                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="Basic Settings" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,15"/>
                    
                    <!-- Printer Name -->
                    <TextBlock Text="Printer Name:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5"/>
                    <Border Background="White" CornerRadius="8" Padding="12,8" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,15">
                        <TextBlock Text="{Binding DeviceName}" FontSize="14" Foreground="#374151"/>
                    </Border>
                    
                    <!-- Connection Type -->
                    <TextBlock Text="Connection Type:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5"/>
                    <Border Background="White" CornerRadius="8" Padding="12,8" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,15">
                        <TextBlock Text="{Binding ConnectedVia}" FontSize="14" Foreground="#374151"/>
                    </Border>
                    
                    <!-- Status Dropdown -->
                    <TextBlock Text="Status:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,5"/>
                    <Border CornerRadius="8" Padding="2"  BorderBrush="#E5E7EB" BorderThickness="1">
                        <ComboBox SelectedItem="{Binding SelectedStatus}" 
                              ItemsSource="{Binding StatusOptions}"
                              Background="White"
                              BorderBrush="#E5E7EB"
                              BorderThickness="0,0,0,0"
                              Padding="12,8"
                              FontSize="14"
                              Margin="0,0,0,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="12" Height="12" Fill="{Binding Color}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Border>
                </StackPanel>

                                <!-- Receipt Configuration -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Receipt Configuration" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,15"/>
                    
                                         <!-- Main Receipt Settings -->
                     <Border Background="#F8F9FA" CornerRadius="8" Padding="15,15,15,15" Margin="0,0,0,15" BorderBrush="#E5E7EB" BorderThickness="1">
                         <StackPanel>
                            <CheckBox Content="Main Receipt" 
                                       IsChecked="{Binding MainReceipt}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,5">
                                 <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="Auto"/>
                                     <ColumnDefinition Width="*"/>
                                 </Grid.ColumnDefinitions>
                                 <TextBlock Text="Number of copies:" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                   <Grid Grid.Column="1" Width="120" Height="40" HorizontalAlignment="Left">
                                      <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="40"/>
                                          <ColumnDefinition Width="*"/>
                                          <ColumnDefinition Width="40"/>
                                      </Grid.ColumnDefinitions>
                                      
                                      <!-- Down Arrow Button -->
                                      <Button Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1,1,0,1" 
                                              Click="MainReceiptCountDown_Click" Padding="0" Margin="0">
                                          <TextBlock Text="▼" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6B7280"/>
                                      </Button>
                                      
                                                                             <!-- Number Display -->
                                       <Border Grid.Column="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,1" Height="34">
                                           <TextBlock Text="{Binding MainReceiptCount}" 
                                                      FontSize="16" FontWeight="SemiBold"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                      Foreground="#374151"/>
                                       </Border>
                                      
                                      <!-- Up Arrow Button -->
                                      <Button Grid.Column="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,1,1" 
                                              Click="MainReceiptCountUp_Click" Padding="0" Margin="0">
                                          <TextBlock Text="▲" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6B7280"/>
                                      </Button>
                                  </Grid>
                             </Grid>
                         </StackPanel>
                     </Border>
                    
                                         <!-- Kitchen Receipt Settings -->
                     <Border Background="#F8F9FA" CornerRadius="8" Padding="15,15,15,15" BorderBrush="#E5E7EB" BorderThickness="1">
                         <StackPanel>
                             <CheckBox Content="Kitchen Receipt" 
                                       IsChecked="{Binding KitchenReceipt}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                             <Grid Margin="0,0,0,5">
                                 <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="Auto"/>
                                     <ColumnDefinition Width="*"/>
                                 </Grid.ColumnDefinitions>
                                 <TextBlock Text="Number of copies:" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                   <Grid Grid.Column="1" Width="120" Height="40" HorizontalAlignment="Left">
                                      <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="40"/>
                                          <ColumnDefinition Width="*"/>
                                          <ColumnDefinition Width="40"/>
                                      </Grid.ColumnDefinitions>
                                      
                                      <!-- Down Arrow Button -->
                                      <Button Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1,1,0,1" 
                                              Click="KitchenReceiptCountDown_Click" Padding="0" Margin="0">
                                          <TextBlock Text="▼" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6B7280"/>
                                      </Button>
                                      
                                                                             <!-- Number Display -->
                                       <Border Grid.Column="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,1" Height="34">
                                           <TextBlock Text="{Binding KitchenReceiptCount}" 
                                                      FontSize="16" FontWeight="SemiBold"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                      Foreground="#374151"/>
                                       </Border>
                                      
                                      <!-- Up Arrow Button -->
                                      <Button Grid.Column="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,1,1" 
                                              Click="KitchenReceiptCountUp_Click" Padding="0" Margin="0">
                                          <TextBlock Text="▲" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6B7280"/>
                                      </Button>
                                  </Grid>
                             </Grid>
                         </StackPanel>
                     </Border>

                    <!-- Main Receipt when Create or Accept Order-->
                    <Border Background="#F8F9FA" CornerRadius="8" Padding="15,15,15,15" Margin="0,15,0,0" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel>
                            <CheckBox Content="Main receipt when create or accept Order" 
                                          IsChecked="{Binding MainReceiptOnOrder}"
                                          FontSize="14"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,10"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0">
            <Button Content="Cancel" 
                    Width="80" Height="36" 
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="Save" 
                    Width="80" Height="36" 
                    Background="#1976D2" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Margin="0"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window> 