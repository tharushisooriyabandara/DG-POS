<view:OptimizedDialogBase x:Class="POS_UI.View.NumericInputDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:view="clr-namespace:POS_UI.View"
             MinWidth="300"
             MinHeight="380">
    <Border Background="White" CornerRadius="16" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

            <Border Grid.Row="1" Background="#F5F5F5" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding DisplayValue}" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Clear" Height="32" Width="70"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding ClearCommand}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Content="1" Margin="3" Height="48" Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="18" FontWeight="Bold" Command="{Binding NumberPadCommand}" CommandParameter="1"/>
                <Button Grid.Row="0" Grid.Column="1" Content="2" Margin="3" Height="48" Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="18" FontWeight="Bold" Command="{Binding NumberPadCommand}" CommandParameter="2"/>
                <Button Grid.Row="0" Grid.Column="2" Content="3" Margin="3" Height="48" Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="18" FontWeight="Bold" Command="{Binding NumberPadCommand}" CommandParameter="3"/>

                <Button Grid.Row="1" Grid.Column="0" Content="4" Margin="3" Height="48" Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="18" FontWeight="Bold" Command="{Binding NumberPadCommand}" CommandParameter="4"/>
                <Button Grid.Row="1" Grid.Column="1" Content="5" Margin="3" Height="48" Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="18" FontWeight="Bold" Command="{Binding NumberPadCommand}" CommandParameter="5"/>
                <Button Grid.Row="1" Grid.Column="2" Content="6" Margin="3" Height="48" Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="18" FontWeight="Bold" Command="{Binding NumberPadCommand}" CommandParameter="6"/>

                <Button Grid.Row="2" Grid.Column="0" Content="7" Margin="3" Height="48" Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="18" FontWeight="Bold" Command="{Binding NumberPadCommand}" CommandParameter="7"/>
                <Button Grid.Row="2" Grid.Column="1" Content="8" Margin="3" Height="48" Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="18" FontWeight="Bold" Command="{Binding NumberPadCommand}" CommandParameter="8"/>
                <Button Grid.Row="2" Grid.Column="2" Content="9" Margin="3" Height="48" Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="18" FontWeight="Bold" Command="{Binding NumberPadCommand}" CommandParameter="9"/>

                <Button Grid.Row="3" Grid.Column="0" Content="." Margin="3" Height="48" Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="18" FontWeight="Bold" Command="{Binding NumberPadCommand}" CommandParameter="."/>
                <Button Grid.Row="3" Grid.Column="1" Content="0" Margin="3" Height="48" Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="18" FontWeight="Bold" Command="{Binding NumberPadCommand}" CommandParameter="0"/>
                <Button Grid.Row="3" Grid.Column="2" Content="&#x2190;" Margin="3" Height="48" Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="18" FontWeight="Bold" Command="{Binding NumberPadCommand}" CommandParameter="Backspace"/>
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                <Button Content="Cancel" Width="100" Height="36" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding CancelCommand}" Margin="0,0,10,0"/>
                <Button Content="Apply" Width="100" Height="36" Background="#1976D2" Foreground="White" FontWeight="Bold" Command="{Binding ConfirmCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</view:OptimizedDialogBase>
