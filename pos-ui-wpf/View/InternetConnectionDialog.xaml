<Window x:Class="POS_UI.View.InternetConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Internet Connection" 
        Height="300" 
        Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Border Background="White"
            CornerRadius="15" 
            BorderBrush="Transparent"
            BorderThickness="1"
            Effect="{DynamicResource MaterialDesignElevationShadow2}">
        
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="WifiOff"
                                            Width="65" 
                                            Height="65" 
                                            Foreground="#FFE71414"/>
                    
                </StackPanel>
                <!--<Button DockPanel.Dock="Right" Width="32" Height="32" VerticalAlignment="Top" Margin="0,-12,-15,0" Background="Transparent" Style="{DynamicResource MaterialDesignToolButton}" HorizontalAlignment="Right" BorderBrush="Transparent" Click="CancelButton_Click" ToolTip="Close">
                    <materialDesign:PackIcon Kind="Close" Width="25" Height="25"/>
                </Button>-->
            </DockPanel>
                
            <!-- Content -->
            <StackPanel Grid.Row="1" 
                        VerticalAlignment="Center"
                        Margin="0,0,0,20">
                <TextBlock Text="No Internet Connection" 
                           FontSize="25.5" TextAlignment="Center"
                           FontWeight="Bold" 
                           VerticalAlignment="Center"
                           Margin="0,0,0,20"/>      
                <TextBlock Text="Please check your internet connection and try again." 
                           TextWrapping="Wrap" TextAlignment="Center"
                           HorizontalAlignment="Center" 
                           FontSize="17"
                           Foreground="{DynamicResource MaterialDesignColumnHeader}"/>
                
                <!--<TextBlock Text="Your current page will be restored when connection is restored." 
                           TextWrapping="Wrap" 
                           HorizontalAlignment="Center" 
                           FontSize="12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           Margin="0,10,0,0"/>-->
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center">
                <Button x:Name="RetryButton"
                        Content="Retry" 
                        Style="{DynamicResource MaterialDesignRaisedButton}"
                        Click="RetryButton_Click" Background="#FF0F85E2"
                        MinWidth="140" FontSize="16"
                        Margin="0,0,10,10" BorderBrush="#FF0F85E2"/>
                
                <!--<Button x:Name="CancelButton"
                        Content="Cancel" 
                        Style="{DynamicResource MaterialDesignOutlinedButton}"
                        Click="CancelButton_Click"
                        MinWidth="120"/>-->
                
                <!--<Button x:Name="ContinueOfflineButton"
                        Content="Continue Offline" 
                        Style="{DynamicResource MaterialDesignOutlinedButton}"
                        Click="ContinueOfflineButton_Click"
                        MinWidth="120"/>-->
            </StackPanel>
        </Grid>
    </Border>
</Window> 