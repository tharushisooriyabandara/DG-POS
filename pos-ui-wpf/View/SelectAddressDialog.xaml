<UserControl x:Class="POS_UI.View.SelectAddressDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:POS_UI.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="340">
    <UserControl.Resources>
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter" />
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </UserControl.Resources>
                   <Border Background="White" Padding="20" CornerRadius="10" Width="340" MaxHeight="450">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Add New Address" FontWeight="Bold" FontSize="18"/>
            <!-- Close button absolutely in top-right corner -->
            <Button Grid.Row="0" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" CommandParameter="cancel"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,-10"
                    Style="{StaticResource MaterialDesignToolButton}" Background="Transparent" BorderBrush="Transparent">
                <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
            </Button>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Resources>
                    <!-- Apply thicker scrollbar style defined in Stylesxaml.xaml -->
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                </ScrollViewer.Resources>
            <StackPanel>

            <!-- Label field -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Label " Margin="0,8,0,4" FontWeight="Bold"/>
                        <TextBlock Text="*" Foreground="Red" Margin="0,8,0,4" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBox Text="{Binding NewAddressLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="38" Padding="10,8,10,8" VerticalContentAlignment="Center" FontSize="14" Margin="0,2,0,0"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="Black" Background="White"
                         materialDesign:HintAssist.Hint="e.g., Home, Work, Other"
                         materialDesign:HintAssist.Foreground="#757575"
                         materialDesign:HintAssist.IsFloating="False"/>

            <!-- Apt/Street no. field -->
                <TextBlock Text="Apartment / Street No." Margin="0,8,0,4" FontWeight="Bold"/>
                <TextBox Text="{Binding NewAddressHouseNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="38" Padding="10,8,10,8" VerticalContentAlignment="Center" FontSize="14" Margin="0,2,0,0"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="Black" Background="White"
                         materialDesign:HintAssist.Hint="Optional"
                         materialDesign:HintAssist.Foreground="#757575"
                         materialDesign:HintAssist.IsFloating="False"/>

            <!-- Places search field -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Search Place" Margin="0,8,0,4" FontWeight="Bold"/>
                        <TextBlock Text=" *" Margin="0,8,0,4" Foreground="Red" FontWeight="Bold"/>
                    </StackPanel>
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                                    <Grid>
                                         <TextBox x:Name="PlaceSearchBox" Grid.Row="0" Text="{Binding PlaceSearchText, UpdateSourceTrigger=PropertyChanged}"
                              MinHeight="38" Padding="10,8,40,8" VerticalContentAlignment="Center" FontSize="14" Margin="0,2,0,0"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="Black" Background="White"
                             materialDesign:HintAssist.Hint="Type at least 3 characters to search"
                             materialDesign:HintAssist.Foreground="#757575"
                             materialDesign:HintAssist.IsFloating="False"
                             TextWrapping="Wrap" AcceptsReturn="False" MaxLines="3" TextAlignment="Left"/>
                    
                                         <!-- Clear button -->
                     <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                             Command="{Binding ClearPlaceSearchCommand}"
                             Visibility="{Binding PlaceSearchText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"
                             Style="{StaticResource MaterialDesignToolButton}" 
                             Background="Transparent" BorderBrush="Transparent" Width="28" Height="28">
                         <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Foreground="#666"/>
                     </Button>
                </Grid>

                    <!-- Predictions popup that floats below the textbox -->
                    <Popup PlacementTarget="{Binding ElementName=PlaceSearchBox}"
                           Placement="Bottom"
                           StaysOpen="False"
                           IsOpen="{Binding PlacementTarget.DataContext.ArePredictionsVisible, RelativeSource={RelativeSource Self}, Mode=OneWay}">
                        <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" 
                                Width="{Binding ElementName=PlaceSearchBox, Path=ActualWidth}">
                            <ListBox ItemsSource="{Binding PlacementTarget.DataContext.PlacePredictions, RelativeSource={RelativeSource AncestorType=Popup}}"
                                     SelectedItem="{Binding PlacementTarget.DataContext.SelectedPrediction, RelativeSource={RelativeSource AncestorType=Popup}, Mode=TwoWay}"
                                     MaxHeight="260">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Padding="8,6" TextWrapping="Wrap" MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>

            <!-- Distance info: show only when calculated -->
                <TextBlock Foreground="#1976D2" Margin="0,4,0,0"
                           Visibility="{Binding ModalDistanceText, Converter={StaticResource StringToVisibilityConverter}}">
                    <Run Text="Distance: "/>
                    <Run Text="{Binding ModalDistanceText}"/>
                </TextBlock>

            <!-- Default address checkbox -->
            <CheckBox Content="Set as default " 
                      IsChecked="{Binding IsDefaultAddress, Mode=TwoWay}"
                      Margin="0,2,0,4"
                      VerticalAlignment="Center"
                      Foreground="Black"
                      FontSize="14"/>

            </StackPanel>
            </ScrollViewer>

            <!-- Buttons in fixed position at bottom -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="Cancel" Width="100" Height="36"  BorderBrush="#1976D2" Foreground="#1976D2" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" CommandParameter="cancel" Margin="0,0,10,0"/>
                <Button Content="Confirm Address" Height="36" Background="#1976D2" Foreground="White" FontWeight="Bold" IsDefault="True" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" CommandParameter="use"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>


