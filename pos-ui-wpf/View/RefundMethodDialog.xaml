<UserControl x:Class="POS_UI.View.RefundMethodDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             MinWidth="420" MinHeight="200">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold"/>
        <StackPanel Grid.Row="1" Margin="0,16,0,12">
            <TextBlock Text="Select how to handle the refund:" FontSize="16"/>
            <TextBlock Text="Amount:" FontSize="14" Margin="0,12,0,0"/>
            <TextBlock Text="{Binding RefundAmountText}" FontSize="22" FontWeight="Bold"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Margin="0,0,8,0" Command="{Binding CancelCommand}"/>
            <Button Content="Skip Refund" Margin="0,0,8,0" Command="{Binding SkipRefundCommand}"/>
            <Button Content="Card Machine Refund" Background="#1976D2" Foreground="White" Command="{Binding UseCardMachineCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>


