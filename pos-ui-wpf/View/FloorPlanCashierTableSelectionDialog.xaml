<UserControl x:Class="POS_UI.View.FloorPlanCashierTableSelectionDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:POS_UI.Converters"
             xmlns:models="clr-namespace:POS_UI.Models"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             MaxWidth="{Binding DialogMaxWidth}"
             MaxHeight="{Binding DialogMaxHeight}"
             MinWidth="420"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="700" d:DesignWidth="900">
    <UserControl.Resources>
        <converters:ColorHexStringToBrushConverter x:Key="ColorHexStringToBrushConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:PackIconKindConverter x:Key="PackIconKindConverter"/>
    </UserControl.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select Table" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
        <StackPanel Grid.Row="1" Margin="0,6,0,8" Visibility="{Binding IncomingTableName, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding IncomingTableName, StringFormat=Incoming Order Table Name\: {0}}" HorizontalAlignment="Center"
                       FontSize="14" FontWeight="SemiBold"/>
            <TextBlock Text="Choose a POS Table from the floor layout" FontSize="13" Foreground="#666" Margin="0,8,0,0" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Nav tabs -->
        <ListBox Grid.Row="2" ItemsSource="{Binding FloorPlans}" SelectedItem="{Binding SelectedFloorPlan, Mode=TwoWay}"
                 BorderThickness="0" Background="Transparent" Margin="0,0,0,8"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Padding" Value="14,8"/>
                    <Setter Property="Margin" Value="0,0,6,0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="TabBorder" CornerRadius="6" Padding="{TemplateBinding Padding}" Background="#EEEEEE" SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#1976D2"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBorder" Property="Opacity" Value="0.92"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Match EditFloorPlan: explicit canvas extent so ScrollViewer extent matches layout (fixes scrollbar vs. content mismatch). -->
        <ScrollViewer x:Name="CashierFloorPlanScroll" Grid.Row="3" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      PanningMode="Both"
                      MaxHeight="620" MaxWidth="{Binding DialogScrollMaxWidth}">
            <Grid Width="{Binding CanvasHostWidth}" Height="{Binding CanvasHostHeight}"
                  HorizontalAlignment="Left" VerticalAlignment="Top">
                <ItemsControl ItemsSource="{Binding FloorPlanDecorPlacements}" Panel.ZIndex="0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Background="#F9F9F9"
                                    Width="{Binding DataContext.CanvasHostWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                    Height="{Binding DataContext.CanvasHostHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="{Binding Width}" Height="{Binding Height}" IsHitTestVisible="False"
                                    Background="{Binding ColorHex, Converter={StaticResource ColorHexStringToBrushConverter}}"
                                    CornerRadius="{Binding CornerRadiusValue}" SnapsToDevicePixels="True" Opacity="0.95">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Shape}" Value="{x:Static models:FloorPlanShapeType.Parallelogram}">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <SkewTransform AngleX="-18" AngleY="0"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Shape}" Value="{x:Static models:FloorPlanShapeType.Diamond}">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="45"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="2">
                                    <materialDesign:PackIcon Kind="{Binding IconKindName, Converter={StaticResource PackIconKindConverter}}" Width="26" Height="26" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding TableName}" FontSize="10" FontWeight="SemiBold" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="{Binding Width}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding PickItems}" Panel.ZIndex="1">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Background="Transparent"
                                Width="{Binding DataContext.CanvasHostWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                Height="{Binding DataContext.CanvasHostHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Placement.X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Placement.Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="{Binding Placement.Width}" Height="{Binding Placement.Height}"
                                Command="{Binding TapCommand}"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="False"
                                SnapsToDevicePixels="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <!-- Hand only when tappable; fill stays full-strength design color for all statuses -->
                                    <Setter Property="Cursor" Value="Arrow"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelectable}" Value="True">
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <!-- Match EditFloorPlan canvas: CornerRadius from placement drives circle / rounded shapes -->
                            <Border CornerRadius="{Binding Placement.CornerRadiusValue}"
                                    Background="{Binding Placement.ColorHex, Converter={StaticResource ColorHexStringToBrushConverter}}"
                                    SnapsToDevicePixels="True">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <!-- Match EditFloorPlan canvas (IsSelectedOnCanvas): black ring -->
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="Black"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="0" Opacity="0.68"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Placement.Shape}" Value="{x:Static models:FloorPlanShapeType.Parallelogram}">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <SkewTransform AngleX="-18" AngleY="0"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Placement.Shape}" Value="{x:Static models:FloorPlanShapeType.Diamond}">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="45"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="2">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="12" Foreground="White"
                                               TextAlignment="Center" TextWrapping="Wrap" MaxWidth="{Binding Placement.Width}">
                                        <TextBlock.Effect>
                                            <DropShadowEffect BlurRadius="2" ShadowDepth="0" Opacity="0.9" Color="Black"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <Rectangle Width="22" Height="16" Margin="0,6,0,0" HorizontalAlignment="Center"
                                               Fill="{Binding StatusSwatchHex, Converter={StaticResource ColorHexStringToBrushConverter}}"
                                               Stroke="#333333" StrokeThickness="1"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="4" Background="#F9F9F9" CornerRadius="6" Padding="10,6" Margin="0,8,0,0">
            <WrapPanel HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <Border Width="14" Height="14" CornerRadius="2" Background="#E0E0E0" BorderBrush="#999" BorderThickness="1" Margin="0,0,6,0"/>
                    <TextBlock Text="Available" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <Border Width="14" Height="14" CornerRadius="2" Background="#9E9E9E" Margin="0,0,6,0"/>
                    <TextBlock Text="Unavailable" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <Border Width="14" Height="14" CornerRadius="2" Background="#FBC02D" Margin="0,0,6,0"/>
                    <TextBlock Text="Reserved (Ongoing table of this order)" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <Border Width="14" Height="14" CornerRadius="2" Background="#1976D2" Margin="0,0,6,0"/>
                    <TextBlock Text="Reserved" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                    <Border Width="14" Height="14" CornerRadius="2" Background="#FF8C00" Margin="0,0,6,0"/>
                    <TextBlock Text="Served" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,4">
            <Button Content="Cancel" Width="100" Margin="0,0,8,0" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding CancelCommand}"/>
            <Button Content="Select" Width="100" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
