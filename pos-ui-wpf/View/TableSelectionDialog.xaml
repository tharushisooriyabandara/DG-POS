
<view:OptimizedDialogBase x:Class="POS_UI.View.TableSelectionDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:POS_UI.View"
             xmlns:models="clr-namespace:POS_UI.Models"
             xmlns:converters="clr-namespace:POS_UI.Converters"
             xmlns:controls="clr-namespace:POS_UI.View.Controls"
             xmlns:view="clr-namespace:POS_UI.View"
             mc:Ignorable="d" d:DesignHeight="180" d:DesignWidth="360">
    <view:OptimizedDialogBase.Resources>
        <converters:TableStatusToEnabledConverter x:Key="TableStatusToEnabledConverter"/>
        <converters:TableSelectionTableEnabledConverter x:Key="TableSelectionTableEnabledConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <Style x:Key="TableButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Unavailable: not selectable, gray -->
                            <DataTrigger Binding="{Binding Status}" Value="Unavailable">
                                <Setter TargetName="border" Property="Background" Value="#9E9E9E"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                <Setter Property="Foreground" Value="#EEEEEE"/>
                            </DataTrigger>
                            <!-- Reserved for same session (selectable) - yellow to distinguish from other reserved -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Status}" Value="Reserved"/>
                                    <Condition Value="True">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource TableSelectionTableEnabledConverter}">
                                                <Binding RelativeSource="{RelativeSource Self}" Path="DataContext"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#FBC02D"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiDataTrigger>
                            <!-- Reserved but NOT same session (disabled reserved) - blue -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Status}" Value="Reserved"/>
                                    <Condition Value="False">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource TableSelectionTableEnabledConverter}">
                                                <Binding RelativeSource="{RelativeSource Self}" Path="DataContext"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#1976D2"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiDataTrigger>
                            <!-- Served -->
                            <DataTrigger Binding="{Binding Status}" Value="Served">
                                <Setter TargetName="border" Property="Background" Value="DarkOrange"/>
                                <Setter Property="Foreground" Value="Wheat"/>
                            </DataTrigger>
                            <!-- Drafted -->
                            <DataTrigger Binding="{Binding Status}" Value="Drafted">
                                <Setter TargetName="border" Property="Background" Value="#FFE0B2"/>
                                <Setter Property="Foreground" Value="#FF9800"/>
                                <Setter Property="BorderBrush" Value="DarkOrange"/>
                            </DataTrigger>
                            <!-- Reserved Disabled -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Status}" Value="Reserved"/>
                                    <Condition Binding="{Binding IsEnabled, RelativeSource={RelativeSource Self}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#1976D2"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiDataTrigger>
                            <!-- Drafted Disabled -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Status}" Value="Drafted"/>
                                    <Condition Binding="{Binding IsEnabled, RelativeSource={RelativeSource Self}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#FFE0B2"/>
                                <Setter Property="Foreground" Value="#FF9800"/>
                            </MultiDataTrigger>
                            <!-- Hover effect for available tables -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsEnabled, RelativeSource={RelativeSource Self}}" Value="True"/>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#1976D2"/>
                                <Setter Property="Foreground" Value="#1976D2"/>
                            </MultiDataTrigger>
                            <!-- Hover effect for yellow table (reserved same session) -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                    <Condition Binding="{Binding Status}" Value="Reserved"/>
                                    <Condition Value="True">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource TableSelectionTableEnabledConverter}">
                                                <Binding RelativeSource="{RelativeSource Self}" Path="DataContext"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#FFF176"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F57F17"/>
                                <Setter Property="Foreground" Value="#333"/>
                            </MultiDataTrigger>
                            <!-- Selected border -->
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2979FF"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                            <!-- Selected + yellow (reserved same session): black border -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSelected}" Value="True"/>
                                    <Condition Binding="{Binding Status}" Value="Reserved"/>
                                    <Condition Value="True">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource TableSelectionTableEnabledConverter}">
                                                <Binding RelativeSource="{RelativeSource Self}" Path="DataContext"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F57F17"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </view:OptimizedDialogBase.Resources>
    <StackPanel>
        <StackPanel Margin="15,10,10,0">
            <TextBlock Text="Select Table" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
            <StackPanel Margin="0,4,0,6" >
                <TextBlock Text="{Binding IncomingTableName, StringFormat=Incoming Order Table Name\: {0}}"  HorizontalAlignment="Center"
                           FontSize="14" FontWeight="SemiBold" Visibility="{Binding IncomingTableName, Converter={StaticResource StringToVisibilityConverter}}"/>
                <TextBlock Text="Choose a POS Table from below" FontSize="13" Foreground="#666" Margin="0,12,0,10"  HorizontalAlignment="Center"
                           Visibility="{Binding IncomingTableName, Converter={StaticResource StringToVisibilityConverter}}"/>
            </StackPanel>
        </StackPanel>
        <Grid>
        <!--<controls:LoadingIndicator HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center" 
                                                       ProgressRingSize="50"
                                                       Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>-->
        <ItemsControl ItemsSource="{Binding Tables}" Width="450" HorizontalAlignment="Center" HorizontalContentAlignment="Center" Margin="10,0,10,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Center" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Style="{StaticResource TableButtonStyle}"
                            Content="{Binding Name}"
                            Command="{Binding DataContext.SelectTableCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Tag="{Binding DataContext.IncomingOrderSessionId, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <Button.IsEnabled>
                            <MultiBinding Converter="{StaticResource TableSelectionTableEnabledConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="DataContext"/>
                                <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                            </MultiBinding>
                        </Button.IsEnabled>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </Grid>
        <!-- Color guide -->
        <Border Background="#F9F9F9" CornerRadius="6" Padding="12,8" Margin="16,8,16,0">
            <StackPanel>
                <!--<TextBlock Text="Color guide" FontSize="12" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,6"/> -->
                <WrapPanel HorizontalAlignment="Center" Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                        <Border Width="20" Height="20" CornerRadius="4" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,6,0"/>
                        <TextBlock Text="Available" FontSize="11" Foreground="#333" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                        <Border Width="20" Height="20" CornerRadius="4" Background="#9E9E9E" Margin="0,0,6,0"/>
                        <TextBlock Text="Unavailable" FontSize="11" Foreground="#333" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                        <Border Width="20" Height="20" CornerRadius="4" Background="#FBC02D" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,6,0"/>
                        <TextBlock Text="Reserved (Ongoing table of this order)" FontSize="11" Foreground="#333" VerticalAlignment="Center"/>
                    </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                        <Border Width="20" Height="20" CornerRadius="4" Background="#1976D2" Margin="0,0,6,0"/>
                        <TextBlock Text="Reserved" FontSize="11" Foreground="#333" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                        <Border Width="20" Height="20" CornerRadius="4" Background="DarkOrange" Margin="0,0,6,0"/>
                        <TextBlock Text="Served" FontSize="11" Foreground="#333" VerticalAlignment="Center"/>
                    </StackPanel>
                    </StackPanel>
                    <!--<StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="20" Height="20" CornerRadius="4" Background="#FFE0B2" BorderBrush="DarkOrange" BorderThickness="1" Margin="0,0,6,0"/>
                        <TextBlock Text="Drafted" FontSize="11" Foreground="#333" VerticalAlignment="Center"/>
                    </StackPanel>-->
                </WrapPanel>
            </StackPanel>
        </Border>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
            <Button Content="Cancel" Width="100" Margin="0,0,8,0" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding CancelCommand}"/>
            <Button Content="Select" Width="100" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding SaveCommand}"/>
        </StackPanel>
    </StackPanel>
</view:OptimizedDialogBase> 