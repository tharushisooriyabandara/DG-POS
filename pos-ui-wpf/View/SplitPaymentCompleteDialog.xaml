<UserControl x:Class="POS_UI.View.SplitPaymentCompleteDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="220" d:DesignWidth="410">
    <Border Background="White" CornerRadius="12" Padding="20,16" MinWidth="380" MaxWidth="420">
        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Complete Existing Order"
                           FontWeight="Bold"
                           FontSize="20"
                           Foreground="#1565C0"
                           Margin="0,0,0,12"/>
                <Button Grid.Column="1" Style="{StaticResource MaterialDesignToolButton}"
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                         VerticalAlignment="Top" Margin="10,0,-10,0"
                         ToolTip="Close">
                    <materialDesign:PackIcon Kind="Close" Width="24" Height="24"/>
                </Button>
            </Grid>
            <TextBlock TextWrapping="Wrap"
                       FontSize="15" 
                       Foreground="#424242"
                       LineHeight="22"
                       Margin="0,0,0,20"
                       Text="There is an active split payment on the cart. Please place it before proceeding."/>
            <Button Content="Close"
                    HorizontalAlignment="Center"
                    MinWidth="100"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#1976D2"
                    Foreground="White"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"/>
        </StackPanel>
    </Border>
</UserControl>
