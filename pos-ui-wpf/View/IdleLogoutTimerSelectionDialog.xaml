<UserControl x:Class="POS_UI.View.IdleLogoutTimerSelectionDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:POS_UI.Converters"
             MinWidth="360">
    <UserControl.Resources>
        <converters:TimerOptionToBoolConverter x:Key="TimerOptionToBoolConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:IntToTextConverter x:Key="IntToTextConverter" DefaultValue="15"/>
    </UserControl.Resources>
    <Border Background="White" CornerRadius="16" Padding="20">
        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding Title}"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>
                <Button Grid.Column="1" Style="{StaticResource MaterialDesignToolButton}"
                      Command="{Binding CancelCommand}"
                     VerticalAlignment="Top" Margin="0,-13,-12,0"
                     ToolTip="Close">
                    <materialDesign:PackIcon Kind="Close" Width="24" Height="24"/>
                </Button>
            </Grid>
            <StackPanel Margin="0,0,0,12">
                <RadioButton Content="5 minutes"
                              GroupName="IdleTimerOption"
                              IsChecked="{Binding SelectedOption, Converter={StaticResource TimerOptionToBoolConverter}, ConverterParameter=5, Mode=TwoWay}"
                              FontSize="17"
                              Margin="0,0,0,10"/>
                <RadioButton Content="10 minutes"
                              GroupName="IdleTimerOption"
                              IsChecked="{Binding SelectedOption, Converter={StaticResource TimerOptionToBoolConverter}, ConverterParameter=10, Mode=TwoWay}"
                              FontSize="17"
                              Margin="0,0,0,10"/>
                <RadioButton Content="30 minutes"
                              GroupName="IdleTimerOption"
                              IsChecked="{Binding SelectedOption, Converter={StaticResource TimerOptionToBoolConverter}, ConverterParameter=30, Mode=TwoWay}"
                              FontSize="17"
                              Margin="0,0,0,10"/>
                <RadioButton Content="Custom"
                              GroupName="IdleTimerOption"
                              IsChecked="{Binding SelectedOption, Converter={StaticResource TimerOptionToBoolConverter}, ConverterParameter=Custom, Mode=TwoWay}"
                              FontSize="17"
                              Margin="0,0,0,0"/>
            </StackPanel>

            <StackPanel Visibility="{Binding IsCustomSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="−" Width="50" Height="40" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="20" FontWeight="Bold"
                            Command="{Binding DecrementCustomCommand}"/>
                    <TextBox Grid.Column="1" FontSize="17"
                             Text="{Binding CustomMinutes, Converter={StaticResource IntToTextConverter}, UpdateSourceTrigger=LostFocus}"
                             materialDesign:HintAssist.Hint="Minutes (1–120)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="+" Width="50" Height="40" Margin="8,0,0,0"
                            Style="{StaticResource MaterialDesignOutlinedButton}" FontSize="20" FontWeight="Bold"
                            Command="{Binding IncrementCustomCommand}"/>
                </Grid>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <Button Content="Cancel" Width="100" Height="36"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding CancelCommand}"
                        Margin="0,0,10,0"/>
                <Button Content="Save" Width="100" Height="36"
                        Background="#1976D2" Foreground="White" FontWeight="Bold"
                        Command="{Binding ConfirmCommand}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
