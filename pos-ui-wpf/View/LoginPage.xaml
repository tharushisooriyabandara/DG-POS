<Page x:Class="POS_UI.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:viewmodels="clr-namespace:POS_UI.ViewModels"
      xmlns:local="clr-namespace:POS_UI.Converters"
      xmlns:controls="clr-namespace:POS_UI.View.Controls"
      xmlns:System="clr-namespace:System;assembly=mscorlib"
      mc:Ignorable="d"
      Background="White">
    
    <Page.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:RoleToForgotTextConverter x:Key="RoleToForgotTextConverter" />
        <local:IncomingOrderBadgeDisplayConverter x:Key="IncomingOrderBadgeDisplayConverter" />
        <Style TargetType="ScrollBar">
            <Setter Property="IsManipulationEnabled" Value="True"/>
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="False"/>
            <Setter Property="Stylus.IsTapFeedbackEnabled" Value="False"/>
            <Setter Property="Width" Value="24"/>
        </Style>
    </Page.Resources>

    <materialDesign:DialogHost x:Name="SupportDialogHost" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
        <materialDesign:DialogHost.DialogContent>
            <StackPanel Width="350" Margin="16">
                <Grid>
                    <TextBlock x:Name="DialogTitle" Text="Password Recovery" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
                    <Button Width="32" Height="32" HorizontalAlignment="Right" Margin="25,-10,-15,0" VerticalAlignment="Top" Style="{StaticResource MaterialDesignToolButton}" Click="ContactSupport_Click" ToolTip="Close">
                        <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                    </Button>
                </Grid>
                <TextBlock x:Name="DialogMessage" Text="Please contact support for assistance." TextWrapping="Wrap" Margin="0,0,0,16" />
                <StackPanel x:Name="DialogButtons" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Contact Support" Style="{StaticResource MaterialDesignRaisedButton}" Width="160" HorizontalAlignment="Center" Click="ContactSupport_Click" />
                </StackPanel>
            </StackPanel>
        </materialDesign:DialogHost.DialogContent>

        <Grid>
            <!-- Background Gradient -->
            <Grid.Background>
                <RadialGradientBrush GradientOrigin="0.8,0.2" Center="0.8,0.2" RadiusX="1.2" RadiusY="1.2">
                    <GradientStop Color="#B3E5FC" Offset="0.0" />
                    <GradientStop Color="#C8E6C9" Offset="0.5" />
                    <GradientStop Color="#FFFFFF" Offset="1.0" />
                </RadialGradientBrush>
            </Grid.Background>

            <!-- Settings Button -->
            <Button x:Name="SettingsButton" 
                    Panel.ZIndex="20"
                    Width="40" 
                    Height="40" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Margin="0,20,20,0"
                    Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                    Background="Transparent"
                    Foreground="Gray"
                    BorderBrush="Transparent"
                    Click="SettingsButton_Click"
                    ToolTip="Settings">
                <materialDesign:PackIcon Kind="Cog" Width="25" Height="25"/>
            </Button>

            <!-- Incoming orders: same chrome as NewOrderAlertPopup (green card + Hey Cashier / New Order Alert) + count -->
            <!-- Panel.ZIndex: must paint above centered login card (later siblings win by default without this). -->
            <StackPanel Panel.ZIndex="10"
                        HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20,5,20,0" Width="550"
                        Visibility="{Binding HasIncomingOrdersBadge, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Background="#6FC08F" CornerRadius="18" Padding="10" Margin="0,2,0,0">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Hey Cashier" Foreground="White" FontSize="22" FontWeight="SemiBold" TextAlignment="Center" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                <TextBlock Text="New Order Alert | " Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,0"
                                            TextAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Text="{Binding IncomingOrdersBadgeCount, Converter={StaticResource IncomingOrderBadgeDisplayConverter}}"/>
                                <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="5,0,0,0" VerticalAlignment="Center"
                                           Text="Order(s)"/>
                            </StackPanel>
                            <TextBlock Text="Sign in to accept orders" Foreground="White" FontSize="14" TextAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Welcome Section -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="40,0,0,40">
                <TextBlock Text="Good Day!" FontSize="32" FontWeight="Bold" Foreground="#222" />
                <TextBlock Text="DG POS" FontSize="24" FontWeight="Bold" Margin="0,30,0,0" />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Help Center" Foreground="#888" FontWeight="SemiBold" Margin="0,0,16,0" />
                    <TextBlock Text="Support" Foreground="#888" FontWeight="SemiBold" Margin="0,0,16,0" />
                    <TextBlock Text="Legal" Foreground="#888" FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Text="{Binding Source={x:Static System:DateTime.Now}, Path=Year, StringFormat='DG POS All rights reserved © {0}'}"
                           Foreground="#bbb" FontSize="10" Margin="0,8,0,0" />
            </StackPanel>

            <!-- Login Card -->
            <Border Width="auto" Padding="32" Background="Transparent" BorderBrush="White" BorderThickness="2" CornerRadius="16" materialDesign:ShadowAssist.ShadowDepth="Depth3" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Welcome Back!" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" />
                    <TextBlock Text="Access Your Account" FontSize="12" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,16" />

                    <!-- User Dropdown -->
                    <Grid Height="50" Width="350" Margin="0,0,0,16">
                        <!-- Loading Indicator -->
                        <controls:LoadingIndicator 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center" 
                            ProgressRingSize="28"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        
                        <!-- User ComboBox -->
                        <ComboBox x:Name="UserComboBox" 
                                  ItemsSource="{Binding Users}"
                                  SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                                  Background="White" 
                                  BorderBrush="Transparent"
                                  BorderThickness="0"
                                  Height="48" 
                                  Width="350"
                                  Padding="12,4,8,4"
                                  VerticalContentAlignment="Center"
                                  PreviewMouseDown="UserComboBox_PreviewMouseDown"
                                  DropDownOpened="UserComboBox_DropDownOpened"
                                  MaxDropDownHeight="260"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="False"
                                  Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=False}">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignComboBox}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ComboBox">
                                                <Grid>
                                                    <Border x:Name="border" 
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8"
                                                            Padding="{TemplateBinding Padding}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ContentPresenter x:Name="contentPresenter"
                                                                              Content="{TemplateBinding SelectionBoxItem}"
                                                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                                              Margin="0"
                                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                              IsHitTestVisible="False"/>
                                                            <ToggleButton x:Name="toggleButton"
                                                                          Grid.Column="1"
                                                                          Width="32" Height="32"
                                                                          Margin="0"
                                                                          VerticalAlignment="Center"
                                                                          Background="Transparent"
                                                                          BorderBrush="Transparent"
                                                                          BorderThickness="0"
                                                                          FocusVisualStyle="{x:Null}"
                                                                          IsTabStop="False"
                                                                          Panel.ZIndex="10"
                                                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                          ClickMode="Press"
                                                                          Cursor="Hand">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                                <materialDesign:PackIcon Kind="ChevronDown" Width="22" Height="22" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                            </ToggleButton>
                                                        </Grid>
                                                    </Border>
                                                    <Popup x:Name="PART_Popup"
                                                           AllowsTransparency="True"
                                                           IsOpen="{TemplateBinding IsDropDownOpen}"
                                                           Placement="Bottom"
                                                           PopupAnimation="Slide">
                                                        <Border x:Name="dropDownBorder"
                                                                Background="White"
                                                                BorderBrush="Transparent"
                                                                BorderThickness="0"
                                                                CornerRadius="8"
                                                                MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                                MinWidth="{TemplateBinding ActualWidth}">
                                                            <Border.Effect>
                                                                <DropShadowEffect Color="Black" 
                                                                                 Opacity="0.1" 
                                                                                 BlurRadius="8" 
                                                                                 ShadowDepth="2" 
                                                                                 Direction="270"/>
                                                            </Border.Effect>
                                                            <Grid>
                                                                <!-- Items list -->
                                                                <ScrollViewer x:Name="ItemsScrollViewer"
                                                                              Margin="4,6,4,6" 
                                                                              SnapsToDevicePixels="True"
                                                                              VerticalScrollBarVisibility="Auto"
                                                                              HorizontalScrollBarVisibility="Disabled"
                                                                              PanningMode="Both"
                                                                              CanContentScroll="False"
                                                                              IsManipulationEnabled="True"
                                                                              Background="Transparent"
                                                                              PanningDeceleration="0.001"
                                                                              PanningRatio="1.2">
                                                                    <ScrollViewer.Resources>
                                                                        <!-- Apply thicker scrollbar style defined in Stylesxaml.xaml -->
                                                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                                                                    </ScrollViewer.Resources>
                                                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                                                </ScrollViewer>

                                                                <!-- Empty placeholder -->
                                                                <Border x:Name="EmptyPlaceholder" Visibility="Collapsed" Margin="8" Background="#FFF" CornerRadius="6" BorderThickness="0">
                                                                    <TextBlock Text="No users found" Foreground="#666" FontWeight="SemiBold" Padding="8"/>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </Popup>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <!-- When there are no items, show placeholder and hide list -->
                                                    <Trigger Property="HasItems" Value="False">
                                                        <Setter TargetName="ItemsScrollViewer" Property="Visibility" Value="Collapsed"/>
                                                        <Setter TargetName="EmptyPlaceholder" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ComboBox.Style>
                            <ComboBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel IsVirtualizing="True"
                                                            VirtualizationMode="Recycling"
                                                            ScrollUnit="Pixel"/>
                                </ItemsPanelTemplate>
                            </ComboBox.ItemsPanel>
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Stylus.IsPressAndHoldEnabled" Value="False"/>
                                    <Setter Property="Stylus.IsTapFeedbackEnabled" Value="False"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                                        <Grid Width="40" Height="40" VerticalAlignment="Center">
                                            <Ellipse>
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#90CAF9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Role}" Value="Cashier">
                                                                <Setter Property="Fill" Value="#F48FB1"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Role}" Value="Outlet Admin">
                                                                <Setter Property="Fill" Value="#90CAF9"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Initials}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       FontWeight="Bold"
                                                       FontSize="18"
                                                       Foreground="White"
                                                       TextAlignment="Center"/>
                                        </Grid>
                                        <StackPanel Margin="8,0,0,0" Width="240">
                                            <TextBlock Text="{Binding FullName}" 
                                                       FontWeight="Bold" 
                                                       FontSize="16"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                                            <TextBlock Text="{Binding Role}" 
                                                       FontSize="12" 
                                                       Foreground="#888"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                                </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <!-- PIN Boxes -->
                    <ItemsControl ItemsSource="{Binding PinBoxes}" Margin="0,0,0,16" HorizontalAlignment="Center" Width="Auto">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBox Style="{StaticResource PinTextBoxStyle}" 
                                         Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="1"
                                         PreviewTextInput="NumberValidationTextBox"
                                         materialDesign:HintAssist.Hint="*" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <controls:LoadingIndicator 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center" 
                        ProgressRingSize="20"
                        Visibility="{Binding IsLoggingIn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Border Background="Red" CornerRadius="4" Padding="8,4" Margin="10,0,0,8"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="White" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!--<Button Content="Submit" 
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Width="120"
                            Height="40"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Center"/>-->

                    <!-- Forgot Pin Code Link -->
                    <TextBlock Text="{Binding SelectedUser.Role, Converter={StaticResource RoleToForgotTextConverter}}" 
                             Foreground="#888" 
                             FontSize="12" 
                             TextDecorations="Underline"
                             Cursor="Hand" 
                             HorizontalAlignment="Center" 
                             MouseDown="ForgotPinCode_MouseDown"/>

                    <!-- Keypad -->
                    <UniformGrid Rows="4" Columns="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="1" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="1"/>
                        <Button Content="2" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="2"/>
                        <Button Content="3" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="3"/>
                        <Button Content="4" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="4"/>
                        <Button Content="5" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="5"/>
                        <Button Content="6" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="6"/>
                        <Button Content="7" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="7"/>
                        <Button Content="8" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="8"/>
                        <Button Content="9" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="9"/>
                        <Button Content="" Style="{StaticResource KeypadButtonStyle}" IsEnabled="False"/>
                        <Button Content="0" Style="{StaticResource KeypadButtonStyle}" Command="{Binding KeypadCommand}" CommandParameter="0"/>
                        <Button Style="{StaticResource KeypadButtonStyle}" Command="{Binding DeleteLastDigitCommand}">
                            <materialDesign:PackIcon Kind="BackspaceOutline" Width="24" Height="24"/>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>
    </materialDesign:DialogHost>
</Page> 