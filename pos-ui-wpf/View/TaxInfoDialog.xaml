<UserControl x:Class="POS_UI.View.TaxInfoDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:POS_UI.Converters">
    <UserControl.Resources>
        <conv:CurrencyFormatConverter x:Key="CurrencyFormatConverter" />
        <conv:InvertCollectionToVisibilityConverter x:Key="InvertCollectionToVisibilityConverter" />
        <conv:CollectionToVisibilityConverter x:Key="CollectionToVisibilityConverter" />
    </UserControl.Resources>
    <Border Background="White" CornerRadius="10" Padding="20,10" Width="600">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with title and close -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="✕" Margin="0,0,0,0" Padding="25,0,0,0" Width="48" Height="28" Background="Transparent" BorderThickness="0" Foreground="Black"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Command="{Binding CloseCommand}" FontSize="20"/>
            </Grid>

            <!-- Summary Cards -->
            <Grid Grid.Row="1" Margin="0,16,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Total Tax Amount Card -->
                <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="8" Padding="16,12" Margin="0,0,8,0" BorderBrush="#BBDEFB" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Total Tax Amount" FontSize="14" Foreground="#1976D2" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Text="{Binding TotalTaxAmount, Converter={StaticResource CurrencyFormatConverter}}" 
                                   FontSize="22" FontWeight="Bold" Foreground="#0D47A1"/>
                    </Grid>
                </Border>
                
                <!-- Total Order Amount Card -->
                <Border Grid.Column="1" Background="#E8F5E9" CornerRadius="8" Padding="16,12" Margin="8,0,0,0" BorderBrush="#C8E6C9" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Total Order Amount" FontSize="14" Foreground="#2E7D32" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Text="{Binding TotalOrderAmount, Converter={StaticResource CurrencyFormatConverter}}" 
                                   FontSize="22" FontWeight="Bold" Foreground="#1B5E20"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Tax Table -->
            <Border Grid.Row="2" Background="#FFF" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Table Header -->
                    <Border Grid.Row="0" Background="#F5F6FA" CornerRadius="8,8,0,0" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0"
                            Visibility="{Binding TaxRows, Converter={StaticResource CollectionToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Tax Rate" FontWeight="Bold" Foreground="#1976D2" 
                                       TextAlignment="Center" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="10,10"/>
                            <TextBlock Grid.Column="1" Text="Tax Code" FontWeight="Bold" Foreground="#1976D2" 
                                       TextAlignment="Center" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="10,10"/>
                            <TextBlock Grid.Column="2" Text="Tax Amount" FontWeight="Bold" Foreground="#1976D2" 
                                       TextAlignment="Center" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="10,10"/>
                            <TextBlock Grid.Column="3" Text="Order Amount" FontWeight="Bold" Foreground="#1976D2" 
                                       TextAlignment="Center" HorizontalAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="10,10"/>
                        </Grid>
                    </Border>

                    <!-- Table Rows -->
                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                            </ScrollViewer.Resources>
                            <ItemsControl ItemsSource="{Binding TaxRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding TaxRateDisplay}" 
                                                           FontSize="14" Foreground="#666"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Padding="10,10"/>
                                                <TextBlock Grid.Column="1" Text="{Binding TaxCode}" 
                                                           FontSize="14" Foreground="#666" 
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Padding="10,10"/>
                                                <TextBlock Grid.Column="2" Text="{Binding TaxAmount, Converter={StaticResource CurrencyFormatConverter}}" 
                                                           FontSize="14" Foreground="#666" 
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Padding="10,10"/>
                                                <TextBlock Grid.Column="3" Text="{Binding OrderAmount, Converter={StaticResource CurrencyFormatConverter}}" 
                                                           FontSize="14" Foreground="#666" 
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Padding="10,10"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        
                        <!-- Empty State Message -->
                        <TextBlock Text="No tax information available for the selected period" 
                                   FontSize="16" Foreground="#999" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center" Margin="20"
                                   Visibility="{Binding TaxRows, Converter={StaticResource InvertCollectionToVisibilityConverter}}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Close Button -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
                <Button Content="Close" Background="#1976D2" Foreground="White" Width="110" Height="36" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

