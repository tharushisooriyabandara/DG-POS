<Window x:Class="POS_UI.View.PrintSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Please Select" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="White" MinWidth="420" MinHeight="220">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Please Select" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,12">
            <Button Command="{Binding SelectMainCommand}" Height="110" Margin="6" Style="{StaticResource MaterialDesignRaisedButton}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Main Receipt" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding SelectKitchenCommand}" Height="110" Margin="6" Style="{StaticResource MaterialDesignRaisedButton}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Kitchen Receipt" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding SelectBothCommand}" Height="110" Margin="6" Style="{StaticResource MaterialDesignRaisedButton}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Both" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </UniformGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="110" Height="36" Content="Cancel" Click="Cancel_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Background="Transparent" BorderBrush="Black" Foreground="Black"/>
        </StackPanel>
    </Grid>
</Window>


