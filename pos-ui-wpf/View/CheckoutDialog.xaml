<view:OptimizedDialogBase x:Class="POS_UI.View.CheckoutDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:POS_UI.ViewModels"
             xmlns:converters="clr-namespace:POS_UI.Converters"
             xmlns:controls="clr-namespace:POS_UI.View.Controls"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:view="clr-namespace:POS_UI.View"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="450">
    <view:OptimizedDialogBase.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <converters:BalanceToColorConverter x:Key="BalanceToColorConverter" />
        <converters:BalanceToTextConverter x:Key="BalanceToTextConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InvertBooleanConverter x:Key="InvertBooleanConverter" />
        <Style x:Key="PaymentToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
            <Setter Property="Foreground" Value="#1976D2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center" 
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#1976D2"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#1976D2"/>
                    <Setter Property="BorderBrush" Value="#1976D2"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsChecked" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#1976D2"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#1976D2"/>
                    <Setter Property="Opacity" Value="1"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>    
        <!-- Balance Display Style -->
        <Style x:Key="BalanceDisplayStyle" TargetType="Border">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCashPaymentValid}" Value="False">
                    <Setter Property="BorderBrush" Value="#F44336"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="CODBalanceDisplayStyle" TargetType="Border">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#4CAF50"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </view:OptimizedDialogBase.Resources>
    <Grid>
        <materialDesign:DialogHost Identifier="SplitPaymentDialogHost" CloseOnClickAway="False" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
        <Border Background="White" CornerRadius="12" Padding="24" Width="450" Height="Auto" MinHeight="200" MaxHeight="750">
        <StackPanel Margin="-14,0,-14,0">
            <Grid>
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Hamburger Menu -->
                    <Button x:Name="HamburgerMenuButton" Style="{StaticResource MaterialDesignOutlinedButton}" Grid.Column="0"
                              Margin="0,-5,8,0" Padding="0,1,0,2" HorizontalAlignment="Center" BorderThickness="0"
                              Background="Transparent" Foreground="Black" BorderBrush="Black" Height="36" Width="30"
                              Click="HamburgerMenuButton_Click">
                        <materialDesign:PackIcon Kind="Menu" Width="30" Height="35"/>
                        <Button.Resources>
                            <Style TargetType="ContextMenu">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ContextMenu">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Margin="5,0,5,0"
                                                    BorderBrush="Gray" Width="150" Height="Auto"
                                                    BorderThickness="1"
                                                    SnapsToDevicePixels="True">
                                                <StackPanel IsItemsHost="True"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background" Value="White"/>
                            </Style>
                        </Button.Resources>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="HamburgerContextMenu">
                                <MenuItem Header="Split Payment" FontSize="14" FontWeight="SemiBold" Height="40" Width="150" HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Command="{Binding EnableSplitPaymentCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                <TextBlock Grid.Column="1" Text="Checkout Cart" FontWeight="Bold" FontSize="20"/>
                
                <Button Grid.Column="2" 
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" 
                        Style="{StaticResource MaterialDesignToolButton}"
                        Background="Transparent" 
                        BorderBrush="Transparent" 
                        Width="32" 
                        Height="32" 
                        Margin="0,0,0,0"
                        ToolTip="Close">
                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20" Foreground="#666"/>
                </Button>
            </Grid>
            <TextBlock Text="Choose Payment Method" Margin="0,2,0,8" Foreground="Gray"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <ToggleButton Width="100" Height="70" Margin="4,0"
                              IsChecked="{Binding SelectedPaymentMethod, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Card}"
                              Command="{Binding SelectPaymentMethodCommand}"
                              CommandParameter="{x:Static local:PaymentMethod.Card}"
                              Style="{StaticResource PaymentToggleButtonStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="CreditCard" Width="45" Height="32" Margin="0,0,0,0"/>
                        <TextBlock Text="Card" TextAlignment="Center" FontWeight="Bold" HorizontalAlignment="Center" Height="20" Margin="0,0,0,0" Width="42"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Width="106" Height="70" Margin="4,0"
                              IsChecked="{Binding SelectedPaymentMethod, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=ManualCard}"
                              Command="{Binding SelectPaymentMethodCommand}"
                              CommandParameter="{x:Static local:PaymentMethod.ManualCard}"
                              Style="{StaticResource PaymentToggleButtonStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="CreditCardOutline" HorizontalAlignment="Center" Width="45" Height="32" Margin="0,0,0,0"/>
                            <TextBlock Text="Manual Card" TextAlignment="Center" FontWeight="Bold" HorizontalAlignment="Center" Height="20" Margin="0,0,0,0"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Width="100" Height="70" Margin="4,0"
                              IsChecked="{Binding SelectedPaymentMethod, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Cash}"
                              Command="{Binding SelectPaymentMethodCommand}"
                              CommandParameter="{x:Static local:PaymentMethod.Cash}"
                              Style="{StaticResource PaymentToggleButtonStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Cash" Width="49" Height="35"/>
                        <TextBlock Text="Cash" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Width="100" Height="70" Margin="4,0"
                              IsChecked="{Binding SelectedPaymentMethod, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=COD}"
                              Command="{Binding SelectPaymentMethodCommand}"
                              CommandParameter="{x:Static local:PaymentMethod.COD}"
                              Style="{StaticResource PaymentToggleButtonStyle}"
                              Visibility="{Binding IsDeliveryOrder, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="TruckDelivery" Width="45" Height="32"/>
                        <TextBlock Text="POD" TextAlignment="Center" FontWeight="Bold" HorizontalAlignment="Center" Height="20" Margin="0,0,0,0" Width="42"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Width="100" Height="70" Margin="4,0"
                              IsChecked="{Binding SelectedPaymentMethod, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=COT}"
                              Command="{Binding SelectPaymentMethodCommand}"
                              CommandParameter="{x:Static local:PaymentMethod.COT}"
                              Style="{StaticResource PaymentToggleButtonStyle}"
                              Visibility="{Binding IsTakeAwayOrder, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="BagPersonalOutline" Width="45" Height="32"/>
                        <TextBlock Text="POT" TextAlignment="Center" FontWeight="Bold" HorizontalAlignment="Center" Height="20" Margin="0,0,0,0" Width="42"/>
                    </StackPanel>
                </ToggleButton>
                <!-- Pay Later Option for Dine-In Orders-->
                <ToggleButton Width="100" Height="70" Margin="4,0"
                        IsChecked="{Binding SelectedPaymentMethod, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=PAY_LATER}"
                        Command="{Binding SelectPaymentMethodCommand}"
                        CommandParameter="{x:Static local:PaymentMethod.PAY_LATER}"
                        Style="{StaticResource PaymentToggleButtonStyle}"
                        Visibility="{Binding ShowPayLaterOption, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="PaymentOnDeliveryOutline" Width="45" Height="32"/>
                            <TextBlock Text="Pay Later" TextAlignment="Center" FontWeight="Bold" HorizontalAlignment="Center" Height="20" Margin="0" Width="54"/>
                        </StackPanel>
                </ToggleButton>

                </StackPanel>



                         <!-- Cash Payment Section -->
             <Border Visibility="{Binding IsCashPaymentSelected, Converter={StaticResource BooleanToVisibilityConverter}}" 
                     Background="#FAFAFA" CornerRadius="8" Padding="16" Margin="0,0,0,10" Height="386">
                <StackPanel Margin="0,0,0,-9">
                    <TextBlock Text="Cash Payment" FontWeight="Bold" FontSize="16" Margin="0,0,0,12" Foreground="#1976D2"/>
                    
                    <!-- Cash Given Input -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Cash Given" FontWeight="Medium" Margin="0,0,0,4" Foreground="#424242"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Padding="10" 
                                     Text="{Binding CashInputString, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     FontSize="16"
                                     FontWeight="Medium"
                                     VerticalContentAlignment="Center"
                                     Height="48"
                                     x:Name="CashGivenTextBox"
                                     IsReadOnly="False"
                                     Focusable="True"
                                     TabIndex="1"/>
                            <Button Grid.Column="1" 
                                    Content="Clear" 
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Width="80" Height="48" Margin="8,0,0,0"
                                    Command="{Binding ClearCashGivenCommand}"/>
                        </Grid>
                    </StackPanel>
                    
                    <!-- Number Pad -->
                    <Grid Margin="0,8,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                                                 <!-- Row 1: 1, 2, 3 -->
                         <Button Grid.Row="0" Grid.Column="0" Content="1" Margin="2" Height="40" 
                                 Style="{StaticResource MaterialDesignOutlinedButton}"
                                 FontSize="18" FontWeight="Bold"
                                 Command="{Binding NumberPadCommand}" CommandParameter="1"/>
                         <Button Grid.Row="0" Grid.Column="1" Content="2" Margin="2" Height="40" 
                                 Style="{StaticResource MaterialDesignOutlinedButton}"
                                 FontSize="18" FontWeight="Bold"
                                 Command="{Binding NumberPadCommand}" CommandParameter="2"/>
                         <Button Grid.Row="0" Grid.Column="2" Content="3" Margin="2" Height="40" 
                                 Style="{StaticResource MaterialDesignOutlinedButton}"
                                 FontSize="18" FontWeight="Bold"
                                 Command="{Binding NumberPadCommand}" CommandParameter="3"/>
                         
                         <!-- Row 2: 4, 5, 6 -->
                         <Button Grid.Row="1" Grid.Column="0" Content="4" Margin="2" Height="40" 
                                 Style="{StaticResource MaterialDesignOutlinedButton}"
                                 FontSize="18" FontWeight="Bold"
                                 Command="{Binding NumberPadCommand}" CommandParameter="4"/>
                         <Button Grid.Row="1" Grid.Column="1" Content="5" Margin="2" Height="40" 
                                 Style="{StaticResource MaterialDesignOutlinedButton}"
                                 FontSize="18" FontWeight="Bold"
                                 Command="{Binding NumberPadCommand}" CommandParameter="5"/>
                         <Button Grid.Row="1" Grid.Column="2" Content="6" Margin="2" Height="40" 
                                 Style="{StaticResource MaterialDesignOutlinedButton}"
                                 FontSize="18" FontWeight="Bold"
                                 Command="{Binding NumberPadCommand}" CommandParameter="6"/>
                         
                         <!-- Row 3: 7, 8, 9 -->
                         <Button Grid.Row="2" Grid.Column="0" Content="7" Margin="2" Height="40" 
                                 Style="{StaticResource MaterialDesignOutlinedButton}"
                                 FontSize="18" FontWeight="Bold"
                                 Command="{Binding NumberPadCommand}" CommandParameter="7"/>
                         <Button Grid.Row="2" Grid.Column="1" Content="8" Margin="2" Height="40" 
                                 Style="{StaticResource MaterialDesignOutlinedButton}"
                                 FontSize="18" FontWeight="Bold"
                                 Command="{Binding NumberPadCommand}" CommandParameter="8"/>
                         <Button Grid.Row="2" Grid.Column="2" Content="9" Margin="2" Height="40" 
                                 Style="{StaticResource MaterialDesignOutlinedButton}"
                                 FontSize="18" FontWeight="Bold"
                                 Command="{Binding NumberPadCommand}" CommandParameter="9"/>
                         
                         <!-- Row 4: ., 0, ← -->
                         <Button Grid.Row="3" Grid.Column="0" Content="." Margin="2" Height="40" 
                                 Style="{StaticResource MaterialDesignOutlinedButton}"
                                 FontSize="18" FontWeight="Bold"
                                 Command="{Binding NumberPadCommand}" CommandParameter="."/>
                         <Button Grid.Row="3" Grid.Column="1" Content="0" Margin="2" Height="40" 
                                 Style="{StaticResource MaterialDesignOutlinedButton}"
                                 FontSize="18" FontWeight="Bold"
                                 Command="{Binding NumberPadCommand}" CommandParameter="0"/>
                         <Button Grid.Row="3" Grid.Column="2" Content="←" Margin="2" Height="40" 
                                 Style="{StaticResource MaterialDesignOutlinedButton}"
                                 FontSize="18" FontWeight="Bold"
                                 Command="{Binding NumberPadCommand}" CommandParameter="Backspace"/>
                    </Grid>
                    
                    <!--<Grid Margin="0,0,0,12" Visibility="{Binding HasTaxSummary, Converter={StaticResource BooleanToVisibilityConverter}}" Width="331" HorizontalAlignment="Right">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="111"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ItemsControl Grid.Row="0" Grid.ColumnSpan="3" ItemsSource="{Binding TaxSummaryRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="111"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TaxCode}" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TaxableAmount, Converter={StaticResource CurrencyFormatConverter}}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TaxAmount, Converter={StaticResource CurrencyFormatConverter}}" HorizontalAlignment="Right" FontWeight="Bold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Tax" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" FontWeight="Bold" Text=""/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding TotalTax, Converter={StaticResource CurrencyFormatConverter}}" HorizontalAlignment="Right" FontWeight="Bold"/>
                    </Grid>-->
                    
                    <!-- Balance Display -->
                    <Border Style="{StaticResource BalanceDisplayStyle}" Height="54">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Amount" FontWeight="Medium" Foreground="#666666"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding SubTotal, Converter={StaticResource CurrencyFormatConverter}}" FontWeight="Bold" Foreground="#1976D2"/>
                            
                            <!--<TextBlock Grid.Row="1" Grid.Column="0" Text="Cash Given" FontWeight="Medium" Foreground="#666666" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CashGivenString}" FontWeight="Bold" Foreground="#4CAF50" Margin="0,4,0,0"/>-->
                            
                           <!-- <Separator Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,8" Background="#E0E0E0"/> -->
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding CashBalance, Converter={StaticResource BalanceToTextConverter}}" FontWeight="Bold" FontSize="14" Foreground="#424242"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CashBalance, Converter={StaticResource CurrencyFormatConverter}}" 
                                       FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"
                                       Foreground="{Binding CashBalance, Converter={StaticResource BalanceToColorConverter}}"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- COD Payment Section -->
            <!--<Border Visibility="{Binding IsCODPaymentSelected, Converter={StaticResource BooleanToVisibilityConverter}}" 
                    Background="#FAFAFA" CornerRadius="8" Padding="16" Margin="0,0,0,10" Height="120">
                <StackPanel Margin="0,0,0,0">
                    <TextBlock Text="Cash on Delivery (COD)" FontWeight="Bold" FontSize="16" Margin="0,0,0,12" Foreground="#1976D2"/>
                    
                     COD Info Display 
                    <Border Style="{StaticResource CODBalanceDisplayStyle}" Height="54">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Amount" FontWeight="Medium" Foreground="#666666"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Text="{Binding SubTotal, Converter={StaticResource CurrencyFormatConverter}}" FontWeight="Bold" Foreground="#1976D2"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Amount to collect" FontWeight="Bold" FontSize="14" Foreground="#424242"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SubTotal, Converter={StaticResource CurrencyFormatConverter}}" 
                                       FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"
                                       Foreground="#4CAF50"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>-->
            
            <Button Command="{Binding ConfirmOrderCommand}"
                    Height="48"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="White"
                    Background="#1976D2"
                    Margin="0,4,0,0"
                   >
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                        <Setter Property="IsEnabled" Value="{Binding IsLoading, Converter={StaticResource InvertBooleanConverter}}"/>
                        <Style.Triggers>
                            <!-- Disable when Cash is selected AND cash is invalid (empty or less than total) -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsCashPaymentSelected}" Value="True"/>
                                    <Condition Binding="{Binding IsCashPaymentValid}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="IsEnabled" Value="False"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <mah:ProgressRing Width="20" Height="20" IsActive="True" Margin="0,0,8,0"/>
                        <TextBlock Text="Finishing..."/>
                    </StackPanel>
                    <TextBlock Text="{Binding CheckoutPrimaryButtonText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"/>
                </Grid>
            </Button>
         </StackPanel>
     </Border>
        </materialDesign:DialogHost>
    </Grid>
</view:OptimizedDialogBase> 