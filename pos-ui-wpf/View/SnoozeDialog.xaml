<UserControl x:Class="POS_UI.View.SnoozeDialog"
xmlns:vm="clr-namespace:POS_UI.ViewModels"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="300">

             <!-- <UserControl.DataContext>
    <vm:SettingsViewModel />
</UserControl.DataContext> -->
    <Border Background="White" Padding="20" CornerRadius="10">
        <StackPanel>
            <TextBlock Text="Select Snooze Time" Margin="0,0,0,10" FontSize="15" FontWeight="Bold"/>
            <ListBox ItemsSource="{Binding DataContext.SnoozeOptions, RelativeSource={RelativeSource AncestorType=Page}}" FontSize="13"
         SelectedItem="{Binding DataContext.SelectedSnoozeOption, RelativeSource={RelativeSource AncestorType=Page}, Mode=TwoWay}"
         Width="200"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Width="100" Height="36" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding DataContext.CancelSnoozeCommand, RelativeSource={RelativeSource AncestorType=Page}}" Margin="0,0,10,0"/>
                <Button Content="OK" Width="100" Height="36" Background="#1976D2" Foreground="White" FontWeight="Bold" Command="{Binding DataContext.ConfirmSnoozeCommand, RelativeSource={RelativeSource AncestorType=Page}}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
