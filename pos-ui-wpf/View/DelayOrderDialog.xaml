<UserControl x:Class="POS_UI.View.DelayOrderDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Width="360" MinHeight="220">
    <Border Background="White" CornerRadius="16" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Delay Order" FontSize="20" FontWeight="Bold"/>

            <StackPanel Grid.Row="1" Margin="0,12,0,12">
                <TextBlock Text="Select delay duration" FontSize="15" Margin="0,0,0,10" Foreground="#444"/>
                <ListBox ItemsSource="{Binding DelayOptions}" SelectedItem="{Binding SelectedMinutes, Mode=TwoWay}"
                         BorderThickness="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="6" Padding="12,8" CornerRadius="10" Background="#F5F5F5">
                                <TextBlock Text="{Binding StringFormat={}{0} min}" FontWeight="SemiBold" Foreground="#333"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Container" CornerRadius="10" Background="Transparent">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Container" Property="Background" Value="#D7EBFF"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Container" Property="Background" Value="#EFEFEF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0"
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" CommandParameter="{x:Null}">
                    <TextBlock Text="Close"/>
                </Button>
                <Button Background="#1976D2" Foreground="White"
                        Command="{Binding ConfirmDelayCommand}">
                    <!--<Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMinutes}" Value="{x:Null}">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>-->
                    <TextBlock FontWeight="SemiBold" Text="Delay Order">
                        <!--<TextBlock.Text>
                            <MultiBinding StringFormat="Delay {0} min">
                                <Binding Path="SelectedMinutes"/>
                            </MultiBinding>
                        </TextBlock.Text>-->
                    </TextBlock>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

