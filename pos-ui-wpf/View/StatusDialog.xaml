<UserControl x:Class="POS_UI.View.StatusDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" d:DesignHeight="240" d:DesignWidth="420">

    <UserControl.Resources>
        <!-- Variants: Success (Green), Error (Red) -->
        <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#E53935"/>

        <Style x:Key="CircleIconBorder" TargetType="Border">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="CornerRadius" Value="36"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="20" Padding="8,5,8,20" Width="380">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Close Button -->
            <Button Grid.Row="0" HorizontalContentAlignment="Center"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Style="{StaticResource MaterialDesignToolButton}" 
                    Background="Transparent" BorderBrush="Transparent" 
                    Width="29" Height="29" Margin="0,0,1,0">
                <materialDesign:PackIcon Kind="Close" Width="25" Height="25"/>
            </Button>

            <!-- Icon Circle depends on Variant -->
            <Border Grid.Row="1"
                    Style="{StaticResource CircleIconBorder}"
                    Background="{Binding VariantBrush, FallbackValue={StaticResource SuccessBrush}}">
                <TextBlock Text="{Binding IconGlyph}" FontSize="34" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Header -->
            <TextBlock Grid.Row="2"
                       Text="{Binding Header}" FontSize="22" FontWeight="Bold"
                       Foreground="{Binding VariantBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

            <!-- Message -->
            <TextBlock Grid.Row="3" Text="{Binding Message}"
                       TextAlignment="Center" TextWrapping="Wrap" FontSize="14"
                       Foreground="{DynamicResource MaterialDesignBody}">
            </TextBlock>

            <!-- Buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                <Button Content="Ok" Width="96" Height="36"
                        Background="{Binding VariantBrush}"
                        Foreground="White" BorderThickness="0"
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                        CommandParameter="True"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

