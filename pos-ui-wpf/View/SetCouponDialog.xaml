<UserControl x:Class="POS_UI.View.SetCouponDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="250" d:DesignWidth="400">
    <Border Background="White" CornerRadius="16" Padding="16" MinWidth="400">
        <StackPanel>
            <DockPanel>
                <TextBlock Text="Set Coupon" FontWeight="Bold" FontSize="26" Margin="0,0,0,12"/>
                <Button DockPanel.Dock="Right" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" HorizontalAlignment="Right" VerticalAlignment="Top" Style="{StaticResource MaterialDesignToolButton}" Background="Transparent" BorderBrush="Transparent" Width="37" Margin="0,-12,-8,0">
                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                </Button>
            </DockPanel>
            <TextBlock Text="Coupon:" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8"/>
            <DockPanel Margin="0,0,0,24">
                <materialDesign:PackIcon Kind="Coupon" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="CouponTextBox" Width="320" Height="40" FontSize="16" VerticalAlignment="Center" VerticalContentAlignment="Center"
                         materialDesign:HintAssist.Hint="Enter Coupon Here"
                         Padding="8,0,8,0"
                         BorderBrush="#D1D5DB" BorderThickness="1"/>
            </DockPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="CancelButton" Content="Cancel" Width="100" Height="36" Style="{StaticResource MaterialDesignOutlinedButton}" Click="CancelButton_Click" Margin="0,0,10,0"/>
                <Button x:Name="ValidateButton" Content="Save" Width="100" Height="36" Background="#1976D2" Foreground="White" FontWeight="Bold" Click="ValidateButton_Click"/>
                <!--<Button x:Name="SaveButton" Content="Save" Width="120" Height="56" FontSize="18" Background="#1976D2" Foreground="White" BorderBrush="#1976D2" BorderThickness="1" Click="SaveButton_Click"/>-->
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl> 