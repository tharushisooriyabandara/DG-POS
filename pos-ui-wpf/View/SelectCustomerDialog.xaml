<view:OptimizedDialogBase x:Class="POS_UI.View.SelectCustomerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:POS_UI.View.Controls"
             xmlns:view="clr-namespace:POS_UI.View"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400">
    <Border Background="White" BorderBrush="Transparent" BorderThickness="2" CornerRadius="8" Padding="16"
            materialDesign:DialogHost.DialogClosing="OnDialogClosing">
        <materialDesign:DialogHost Identifier="NestedCustomerDialogHost" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
        <StackPanel>
            <DockPanel>
                <TextBlock Text="Customer" FontWeight="Bold" FontSize="20"/>
                <Button DockPanel.Dock="Right" Width="32" Height="32" Background="Transparent" Style="{StaticResource MaterialDesignToolButton}" HorizontalAlignment="Right" BorderBrush="Transparent" Command="{Binding CloseCommand}">
                    <materialDesign:PackIcon Kind="Close" Width="25" Height="25" Foreground="Black"/>
                </Button>
            </DockPanel>
            <TextBlock Text="Search Customer" Margin="0,12,0,4" FontWeight="SemiBold"/>
            <DockPanel>
                <Grid Width="235" Height="36" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" VerticalAlignment="Center" Grid.Column="0"
                             materialDesign:HintAssist.Hint="Search by Name or Mobile number" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="2,0,2,0"
                             Stylus.IsPressAndHoldEnabled="False"
                             Stylus.IsFlicksEnabled="False"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,0"
                            Command="{Binding ClearSearchCommand}" Grid.Column="1"
                           
                            Style="{StaticResource MaterialDesignToolButton}"
                            Background="Transparent" BorderBrush="Transparent" Width="26" Height="26">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Foreground="#666"/>
                    </Button>
                </Grid>
                <Button Content="Add New" Width="119" Height="36" Background="#1976D2" Foreground="White" BorderBrush="#1976D2" Command="{Binding AddNewCustomerCommand}"/>
            </DockPanel>

            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <controls:LoadingIndicator HorizontalAlignment="Center" Margin="0,50,0,0" 
                               VerticalAlignment="Center" 
                               ProgressRingSize="60"
                               Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Grid Margin="0,12,0,0" Height="365">
                        <ListBox ItemsSource="{Binding FilteredCustomers}" x:Name="CustomerList" Height="365" BorderThickness="0" SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                                 ScrollViewer.PanningMode="VerticalOnly"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                 VirtualizingPanel.ScrollUnit="Pixel">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <Border Width="40" Height="40" Background="#1976D2" CornerRadius="20" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Initials}" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                                        </Border>
                                        <StackPanel Margin="12,0,0,0">
                                            <TextBlock FontWeight="Bold" Text="{Binding Name}"/>
                                            <TextBlock Text="{Binding FullPhoneNumber}" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border x:Name="TopFade" VerticalAlignment="Top" Height="20" IsHitTestVisible="False" Opacity="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#40000000" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border x:Name="BottomFade" VerticalAlignment="Bottom" Height="20" IsHitTestVisible="False" Opacity="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#40000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,12,0,0" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="25"/>
                            <ColumnDefinition Width="25"/>
                        </Grid.ColumnDefinitions>
                                                 <StackPanel Grid.Column="0">
                             <TextBlock Text="a" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="b" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="c" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="d" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="e" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="f" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="g" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="h" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="i" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="j" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="k" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="l" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="m" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                         </StackPanel>
                                                 <StackPanel Grid.Column="1">
                             <TextBlock Text="n" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="o" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="p" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="q" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="r" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="s" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="t" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="u" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="v" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="w" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="x" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="y" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                             <TextBlock Text="z" MouseDown="AlphaIndex_MouseDown" Margin="0,0,0,3" Foreground="#555" HorizontalAlignment="Center" Cursor="Hand" FontSize="16" Padding="4,2"/>
                         </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
            <Button Content="Proceed" Height="48" Margin="0,4,0,0" Background="#1976D2" Foreground="White" FontWeight="Bold" Command="{Binding ProceedCommand}"/>
        </StackPanel>
        </materialDesign:DialogHost>
    </Border>
</view:OptimizedDialogBase> 