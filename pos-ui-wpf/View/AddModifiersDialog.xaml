<view:OptimizedDialogBase x:Class="POS_UI.View.AddModifiersDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:POS_UI.Converters"
             xmlns:view="clr-namespace:POS_UI.View"
             Height="{Binding ModifierItems.Count, Converter={StaticResource DynamicHeightConverter}}" 
            MaxWidth="850"
             >
    <view:OptimizedDialogBase.Resources>
        <!--  <conv:SizeSelectionBackgroundMultiConverter x:Key="SizeSelectionBackgroundMultiConverter" />
        <conv:SizeSelectionForegroundMultiConverter x:Key="SizeSelectionForegroundMultiConverter" />-->
        <conv:ModifierButtonTextConverter x:Key="ModifierButtonTextConverter" />
        <conv:ModifierSelectionConverter x:Key="ModifierSelectionConverter" />
        <conv:ModifierItemSelectionConverter x:Key="ModifierItemSelectionConverter" />
        <conv:ModifierItemEnabledConverter x:Key="ModifierItemEnabledConverter" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:SelectedModifierItemDisplayConverter x:Key="SelectedModifierItemDisplayConverter" />
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter" />
    </view:OptimizedDialogBase.Resources>
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Header -->
        <DockPanel Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="35"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Select Modifiers" FontSize="22" FontWeight="Bold" Margin="0,0,0,5"/>
                <Button Grid.Column="1" Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,0" Style="{StaticResource MaterialDesignToolButton}" Command="{Binding CancelCommand}" ToolTip="Close">
                    <materialDesign:PackIcon Kind="Close" Width="25" Height="25"/>
                </Button>
            </Grid>
        </DockPanel>
        
        <!-- Modifier Groups -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="ModifiersScrollViewer" VerticalScrollBarVisibility="Hidden" PanningMode="None" Margin="0,5,0,0">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding ModifierGroups, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10" Padding="12" Background="#F8F9FA" CornerRadius="8">
                                    <StackPanel>
                                        <!-- Modifier Group Title -->
                                        <TextBlock Text="{Binding Title}" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="16" 
                                                   Margin="0,0,0,2"/>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Min Constraint Text -->
                                            <TextBlock Text="{Binding MinConstraintText}" 
                                                       FontSize="11" 
                                                       Foreground="#FF7D7D7D" 
                                                       Margin="0,0,5,0"
                                                       Visibility="{Binding MinConstraintText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>   
                                            <!-- Max Constraint Text -->
                                            <TextBlock Text="{Binding MaxConstraintText}" 
                                                        FontSize="11" 
                                                        Foreground="#FF7D7D7D" 
                                                        Margin="5,0,0,2"
                                                        Visibility="{Binding MaxConstraintText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                        </StackPanel>
                                        
                                        <!-- Modifier Items -->
                                        <ItemsControl ItemsSource="{Binding ModifierItems, Mode=OneWay}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Width="140" HorizontalContentAlignment="Center"
                                                            Height="43"
                                                            Padding="0"
                                                            Margin="0,0,14,14"
                                                            Command="{Binding DataContext.SelectModifierItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            BorderBrush="#1976D2"
                                                            BorderThickness="1"
                                                            FontSize="14"
                                                            FontWeight="SemiBold">
                                                        <Button.IsEnabled>
                                                            <MultiBinding Converter="{StaticResource ModifierItemEnabledConverter}">
                                                                <Binding Path="DataContext.SelectedItems" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                <Binding Path="DataContext.Id" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                <Binding Path="ItemName"/>
                                                                <Binding Path="DataContext.MaxPermitted" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                            </MultiBinding>
                                                        </Button.IsEnabled>
                                                        <Button.CommandParameter>
                                                            <MultiBinding Converter="{StaticResource ModifierSelectionConverter}">
                                                                <Binding Path="DataContext.Id" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                <Binding Path="Id"/>
                                                                <Binding Path="ItemName"/>
                                                            </MultiBinding>
                                                        </Button.CommandParameter>
                                                        <Button.Background>
                                                            <MultiBinding Converter="{StaticResource ModifierItemSelectionConverter}">
                                                                <Binding Path="DataContext.SelectedItems" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                <Binding Path="DataContext.Id" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                <Binding Path="ItemName"/>
                                                            </MultiBinding>
                                                        </Button.Background>
                                                        <Button.Foreground>
                                                            <MultiBinding Converter="{StaticResource ModifierItemSelectionConverter}" ConverterParameter="Foreground">
                                                                <Binding Path="DataContext.SelectedItems" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                <Binding Path="DataContext.Id" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                <Binding Path="ItemName"/>
                                                            </MultiBinding>
                                                        </Button.Foreground>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding ItemName}"
                                                                       Grid.Column="0"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="SemiBold" HorizontalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="4,0,4,0"/>
                                                            <TextBlock Grid.Column="1"
                                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                       FontWeight="Normal" 
                                                                       Margin="4,0,4,0"> 
                                                                <TextBlock.Text>
                                                                    <MultiBinding StringFormat="+{0}">
                                                                        <Binding Path="ItemPrice" Converter="{StaticResource CurrencyFormatConverter}"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
            <Border x:Name="ModifiersFadeOverlay" IsHitTestVisible="False" VerticalAlignment="Bottom" Height="80" Opacity="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#CCFFFFFF" Offset="0.4"/>
                        <GradientStop Color="#FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>
        
        <!-- Selected Items Summary -->
        <!--<StackPanel Grid.Row="2" Margin="0,0,0,8">
            <ItemsControl ItemsSource="{Binding SelectedModifierDetails}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,2"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>-->
        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button Content="Cancel" Width="100" Height="36" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding CancelCommand}" Margin="0,0,10,0"/>
            <Button Content="Next" Width="100" Height="36" Background="#1976D2" Foreground="White" FontWeight="Bold" Command="{Binding SaveCommand}" IsEnabled="{Binding CanProceed}"/>
        </StackPanel>
    </Grid>
</view:OptimizedDialogBase> 