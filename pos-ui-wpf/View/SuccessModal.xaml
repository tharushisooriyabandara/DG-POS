<UserControl x:Class="POS_UI.View.SuccessModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:POS_UI.View"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" d:DesignHeight="200" d:DesignWidth="400">
    
    <Border Background="White" CornerRadius="8" Padding="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Success Icon -->
            <Border Width="60" Height="60" Background="#4CAF50" CornerRadius="30" 
                    HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="✓" FontSize="32" FontWeight="Bold" Foreground="White" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            
            <!-- Success Message -->
            <TextBlock Text="Order saved as draft successfully!" 
                       FontSize="18" FontWeight="SemiBold" 
                       HorizontalAlignment="Center" 
                       TextWrapping="Wrap" 
                       Margin="0,0,0,30"/>
            
            <!-- OK Button -->
            <Button Content="OK" 
                    Width="100" 
                    Height="40"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="True"/>
        </StackPanel>
    </Border>
</UserControl>
