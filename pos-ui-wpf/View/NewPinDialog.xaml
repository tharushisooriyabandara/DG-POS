<UserControl x:Class="POS_UI.View.NewPinDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:POS_UI.View"
             xmlns:conv="clr-namespace:POS_UI.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" Width="450">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Margin="0,0,0,0">
        <Border Background="White" CornerRadius="16" Padding="20" MinWidth="400" MinHeight="400" Margin="0,0,0,0">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="New PIN  Setup" FontWeight="Bold" FontSize="24" Margin="0,0,0,24"/>
                <TextBlock Text="New PIN" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,16">
                    <TextBox x:Name="NewPin1" Style="{StaticResource PinTextBoxStyle}" MaxLength="1" FontSize="28" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextChanged="PinBox_TextChanged" PreviewKeyDown="PinBox_PreviewKeyDown" Text="{Binding DataContext.NewPinDigit1, RelativeSource={RelativeSource AncestorType=materialDesign:DialogHost}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="NewPin2" Style="{StaticResource PinTextBoxStyle}" MaxLength="1" FontSize="28" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextChanged="PinBox_TextChanged" PreviewKeyDown="PinBox_PreviewKeyDown" Text="{Binding DataContext.NewPinDigit2, RelativeSource={RelativeSource AncestorType=materialDesign:DialogHost}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="NewPin3" Style="{StaticResource PinTextBoxStyle}" MaxLength="1" FontSize="28" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextChanged="PinBox_TextChanged" PreviewKeyDown="PinBox_PreviewKeyDown" Text="{Binding DataContext.NewPinDigit3, RelativeSource={RelativeSource AncestorType=materialDesign:DialogHost}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="NewPin4" Style="{StaticResource PinTextBoxStyle}" MaxLength="1" FontSize="28" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextChanged="PinBox_TextChanged" PreviewKeyDown="PinBox_PreviewKeyDown" Text="{Binding DataContext.NewPinDigit4, RelativeSource={RelativeSource AncestorType=materialDesign:DialogHost}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="NewPin5" Style="{StaticResource PinTextBoxStyle}" MaxLength="1" FontSize="28" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Visibility="{Binding DataContext.IsPinTargetOutletAdmin, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}" TextChanged="PinBox_TextChanged" PreviewKeyDown="PinBox_PreviewKeyDown" Text="{Binding DataContext.NewPinDigit5, RelativeSource={RelativeSource AncestorType=materialDesign:DialogHost}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="NewPin6" Style="{StaticResource PinTextBoxStyle}" MaxLength="1" FontSize="28" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Visibility="{Binding DataContext.IsPinTargetOutletAdmin, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}" TextChanged="PinBox_TextChanged" PreviewKeyDown="PinBox_PreviewKeyDown" Text="{Binding DataContext.NewPinDigit6, RelativeSource={RelativeSource AncestorType=materialDesign:DialogHost}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <TextBlock Text="Confirm New PIN" FontWeight="SemiBold" FontSize="16" Margin="0,16,0,8"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,32">
                    <TextBox x:Name="ConfirmPin1" Style="{StaticResource PinTextBoxStyle}" MaxLength="1" FontSize="28" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextChanged="PinBox_TextChanged" PreviewKeyDown="PinBox_PreviewKeyDown" Text="{Binding DataContext.ConfirmPinDigit1, RelativeSource={RelativeSource AncestorType=materialDesign:DialogHost}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="ConfirmPin2" Style="{StaticResource PinTextBoxStyle}" MaxLength="1" FontSize="28" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextChanged="PinBox_TextChanged" PreviewKeyDown="PinBox_PreviewKeyDown" Text="{Binding DataContext.ConfirmPinDigit2, RelativeSource={RelativeSource AncestorType=materialDesign:DialogHost}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="ConfirmPin3" Style="{StaticResource PinTextBoxStyle}" MaxLength="1" FontSize="28" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextChanged="PinBox_TextChanged" PreviewKeyDown="PinBox_PreviewKeyDown" Text="{Binding DataContext.ConfirmPinDigit3, RelativeSource={RelativeSource AncestorType=materialDesign:DialogHost}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="ConfirmPin4" Style="{StaticResource PinTextBoxStyle}" MaxLength="1" FontSize="28" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextChanged="PinBox_TextChanged" PreviewKeyDown="PinBox_PreviewKeyDown" Text="{Binding DataContext.ConfirmPinDigit4, RelativeSource={RelativeSource AncestorType=materialDesign:DialogHost}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="ConfirmPin5" Style="{StaticResource PinTextBoxStyle}" MaxLength="1" FontSize="28" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Visibility="{Binding DataContext.IsPinTargetOutletAdmin, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}" TextChanged="PinBox_TextChanged" PreviewKeyDown="PinBox_PreviewKeyDown" Text="{Binding DataContext.ConfirmPinDigit5, RelativeSource={RelativeSource AncestorType=materialDesign:DialogHost}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="ConfirmPin6" Style="{StaticResource PinTextBoxStyle}" MaxLength="1" FontSize="28" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Visibility="{Binding DataContext.IsPinTargetOutletAdmin, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}" TextChanged="PinBox_TextChanged" PreviewKeyDown="PinBox_PreviewKeyDown" Text="{Binding DataContext.ConfirmPinDigit6, RelativeSource={RelativeSource AncestorType=materialDesign:DialogHost}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="Cancel" Width="170" Height="46" Background="Black" Foreground="White" FontWeight="Bold" FontSize="20" Margin="0,0,24,0" BorderBrush="Transparent" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"/>
                    <Button Content="Set New PIN" Width="170" Height="46" FontWeight="Bold" FontSize="20" Foreground="White" Margin="0,0,0,0" Command="{Binding DataContext.SetNewPinCommand, RelativeSource={RelativeSource AncestorType=materialDesign:DialogHost}}">

                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1976D2" Offset="0.0"/>
                                <GradientStop Color="#2196F3" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
