<Page x:Class="POS_UI.View.LiveOrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:vm="clr-namespace:POS_UI.ViewModels"
      xmlns:local="clr-namespace:POS_UI"
      xmlns:converters="clr-namespace:POS_UI.Converters"
      xmlns:models="clr-namespace:POS_UI.Models"
      xmlns:controls="clr-namespace:POS_UI.View.Controls"
      Title="Live Orders">
    <Page.DataContext>
        <vm:LiveOrdersViewModel />
    </Page.DataContext>
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:CountryBasedDateTimeConverter x:Key="CountryBasedDateTimeConverter"/>
        <converters:OrderTypeToBadgeBrushConverter x:Key="OrderTypeToBadgeBrushConverter"/>
    </Page.Resources>
    <Grid>
    <materialDesign:DialogHost Identifier="RootDialog" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <local:Sidebar x:Name="SidebarControl" Grid.Column="0"/>
            <Grid Grid.Column="1" Background="#F8F8F8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Header: Live Orders + Filter buttons + Refresh -->
                <Border Grid.Row="0" Background="Transparent" Padding="10,0,20,0" Margin="0,5,0,20">
                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                <Border Background="#2196F3" Width="15" Height="60" CornerRadius="5"/>
                                <StackPanel Orientation="Vertical" Margin="10" VerticalAlignment="Center">
                                    <TextBlock Text="Live Orders" FontSize="22" FontWeight="Bold" Margin="0,0,0,2"/>
                                    
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,0">
                        <Button Content="ALL" Command="{Binding SetFilterAllCommand}" FontSize="16" Margin="0,0,15,0" Padding="14,8" BorderThickness="2" FontWeight="Bold" Width="100" Height="45">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFilterAll}" Value="True">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Setter Property="Foreground" Value="#1976D2"/>
                                            <Setter Property="BorderBrush" Value="#2196F3"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="PAID" Command="{Binding SetFilterPaidCommand}" FontSize="16" Margin="0,0,15,0" Padding="14,8" BorderThickness="2" FontWeight="Bold" Height="45" Width="100">
                            <Button.Style>
                                <Style TargetType="Button"
                                        BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFilterPaid}" Value="True">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Setter Property="Foreground" Value="#1976D2"/>
                                            <Setter Property="BorderBrush" Value="#2196F3"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="UNPAID" Command="{Binding SetFilterUnpaidCommand}" FontSize="16" Margin="0,0,15,0" Padding="14,8" BorderThickness="2" FontWeight="Bold" Height="45" Width="100">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFilterUnpaid}" Value="True">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Setter Property="Foreground" Value="#1976D2"/>
                                            <Setter Property="BorderBrush" Value="#2196F3"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="DINE-IN" Command="{Binding SetFilterDineInCommand}" FontSize="16" Margin="0,0,15,0" Padding="14,8" BorderThickness="2" FontWeight="Bold" Height="45" Width="100">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFilterDineIn}" Value="True">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Setter Property="Foreground" Value="#1976D2"/>
                                            <Setter Property="BorderBrush" Value="#2196F3"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="TAKEAWAY" Command="{Binding SetFilterTakeawayCommand}" FontSize="16" Margin="0,0,15,0" Padding="14,8" BorderThickness="2" FontWeight="Bold" Height="45" Width="120">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFilterTakeaway}" Value="True">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Setter Property="Foreground" Value="#1976D2"/>
                                            <Setter Property="BorderBrush" Value="#2196F3"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="DELIVERY" Command="{Binding SetFilterDeliveryCommand}" FontSize="16" Margin="0,0,15,0" Padding="14,8" BorderThickness="2" FontWeight="Bold" Height="45" Width="100">
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFilterDelivery}" Value="True">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Setter Property="Foreground" Value="#1976D2"/>
                                            <Setter Property="BorderBrush" Value="#2196F3"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}" BorderThickness="0"
                            materialDesign:ButtonAssist.CornerRadius="10" Margin="0,0,0,0" Height="44"
                            Background="#2196F3"  Foreground="White" Padding="16,8" VerticalAlignment="Center"
                            ToolTip="Refresh orders">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="REFRESH" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
             </Border>
                <Grid Grid.Row="1">
                    <ScrollViewer x:Name="OrdersScrollViewer" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" Margin="10,0,20,10">
                    <Grid>
                        <controls:LoadingIndicator HorizontalAlignment="Center" VerticalAlignment="Center" ProgressRingSize="70" Margin="0,70,0,0"
                                                   Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock Text="No orders available" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#CCCCCC" FontSize="18" FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsLoading}" Value="False"/>
                                                <Condition Binding="{Binding Orders.Count}" Value="0"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding Orders}" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:OrderModel">
                                    <Border Background="White" CornerRadius="8" Padding="14,10" Margin="0,0,0,10"
                                            BorderBrush="#E0E0E0" BorderThickness="1"
                                            MouseLeftButtonUp="OrderCard_Click">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.12"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="260"/>
                                                <ColumnDefinition Width="350"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Column 1: Source icon + Order ID + Source label -->
                                            <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,16,0">
                                                <Border Width="44" Height="44" CornerRadius="22" Margin="0,0,0,4" Background="#E3F2FD">
                                                    <Image Source="{Binding PlatformLogo}" Width="38" Height="38"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                            
                                            <!-- Column 2 : DIsplayOrderID + PlatformName-->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                                <TextBlock FontWeight="Bold" FontSize="21" Text="{Binding DisplayOrderId}"/>
                                                <TextBlock Text="{Binding DeliveryPlatfornName, FallbackValue=PlatformName}" FontSize="14" Foreground="#757575"/>
                                            </StackPanel>
                                            <!-- Column 2: Amount + Time + UNPAID -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,16,0">
                                                <TextBlock FontWeight="Bold" FontSize="19" Text="{Binding DisplayTotal, Converter={StaticResource CurrencyFormatConverter}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">

                                                            <Setter Property="Foreground" Value="#D32F2F"/>

                                                            <Style.Triggers>

                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="PAID">
                                                                    <Setter Property="Foreground" Value="Black"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="1" Text="{Binding PaymentStatus}" FontSize="14" FontWeight="Bold" Margin="0,3,0,0" TextAlignment="Left">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <!-- Default = Red (Not Paid) -->
                                                                <Setter Property="Foreground" Value="#D32F2F"/>

                                                                <Style.Triggers>
                                                                    <!-- If Paid = Black -->
                                                                    <DataTrigger Binding="{Binding PaymentStatus}" Value="PAID">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="0" Text="{Binding CreatedAt, Converter={StaticResource CountryBasedDateTimeConverter}}" Margin="0,3,0,0" FontSize="14" Foreground="#757575"/>
                                                </Grid>
                                            </StackPanel>
                                            <!-- Column 3: Order type + Progress -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="10,0,20,0" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding OrderTypeDisplay}" FontSize="16" FontWeight="Bold" Foreground="{Binding OrderTypeDisplay, Converter={StaticResource OrderTypeToBadgeBrushConverter}}" TextAlignment="Left"/>
                                                <TextBlock Text="{Binding LiveOrdersStatus}" Margin="0,3,0,0" FontSize="13" Foreground="#757575" TextAlignment="Left"/>
                                            </StackPanel>

                                            <!-- POS dine-in or table-order dine-in: table icon + name (between status and actions) -->
                                            <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8,0,20,0">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowPosDineInTableOnLiveOrders}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                        <materialDesign:PackIcon Kind="TableFurniture" Width="29" Height="29" Foreground="#2196F3" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding LiveOrdersPosTableDisplay}" Margin="0,4,0,0" FontSize="14" FontWeight="SemiBold" Foreground="#2196F3" HorizontalAlignment="Center" TextAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <!-- Column 5: View + Action button -->
                                            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <!-- View Button -->
                                             <!-- <Button Content="View" Padding="12,6" BorderBrush="#2196F3" Style="{StaticResource MaterialDesignRaisedButton}"
                                                        materialDesign:ButtonAssist.CornerRadius="10" Foreground="White" Margin="0,0,8,0" Width="100"
                                                        Command="{Binding DataContext.ViewOrderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"/> -->
                                                
                                                <!-- Ready (for non-POS orders Unpaid) -->
                                                <Button Content="Ready" Padding="12,6" BorderThickness="2" BorderBrush="#FFBF00" Background="#FFBF00" Foreground="White"
                                                        FontWeight="SemiBold" FontSize="17" Cursor="Hand" Margin="0,0,0,0" Height="40" Width="155"
                                                        Command="{Binding DataContext.ReadyOrderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding DataContext.IsNotProcessing, RelativeSource={RelativeSource AncestorType=Page}}">
                                                    <Button.Style>
                                                        <Style TargetType="Button"
                                                                BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOtherPlatform}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <!-- Payment (unpaid) - hidden for Uber/Deliveroo/Table after Ready -->
                                                <Button Content="Pay &amp; Complete" Padding="12,6" BorderThickness="2" BorderBrush="#D32F2F" Background="#D32F2F" Foreground="White"
                                                         FontWeight="SemiBold" FontSize="17" Cursor="Hand" Height="40" Width="155"
                                                         Command="{Binding DataContext.PaymentOrderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                         CommandParameter="{Binding}"
                                                         IsEnabled="{Binding DataContext.IsNotProcessing, RelativeSource={RelativeSource AncestorType=Page}}">
                                                    <Button.Style>
                                                        <Style TargetType="Button"
                                                               BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsPaidForLiveOrder}" Value="False"/>
                                                                        <Condition Binding="{Binding IsOtherPlatform}" Value="False"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                                <DataTrigger Binding="{Binding IsAlwaysCompleteAfterReady}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <!-- Complete - show when paid, or always for Uber/Deliveroo/Table after Ready -->
                                                <Button Content="Complete" Padding="12,6" BorderThickness="2" BorderBrush="#1EA41E" Background="#1EA41E" Foreground="White"
                                                        FontWeight="SemiBold" FontSize="17" Cursor="Hand" Margin="0,0,0,0" Height="40" Width="155"
                                                        Command="{Binding DataContext.CompleteOrderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding DataContext.IsNotProcessing, RelativeSource={RelativeSource AncestorType=Page}}">
                                                    <Button.Style>
                                                        <Style TargetType="Button"
                                                               BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsPaidForLiveOrder}" Value="True"/>
                                                                        <Condition Binding="{Binding IsOtherPlatform}" Value="False"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                                <DataTrigger Binding="{Binding IsAlwaysCompleteAfterReady}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                    </ScrollViewer>
                    <Border x:Name="OrdersBottomFade" VerticalAlignment="Bottom" Height="50" IsHitTestVisible="False" Margin="10,0,20,10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#F8F8F8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
    <!-- Overlay for split payment / cash-drawer errors while RootDialog shows split or checkout (same host cannot stack two dialogs). -->
    <materialDesign:DialogHost Identifier="KitchenSplitOverlayDialogHost" Panel.ZIndex="1"/>
    </Grid>
</Page>
