<Window x:Class="POS_UI.View.RefundMethodWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:POS_UI.Converters"
        Title="Refund Method" Height="220" Width="520" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None" ShowInTaskbar="False"
        Background="Transparent" AllowsTransparency="True"
        VerticalAlignment="Center">
    <Window.Resources>
        <converters:CurrencyFormatConverter x:Key="CurrencyFormatConverter"/>
    </Window.Resources>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Header with title and close -->
        <Border Padding="10" Margin="0,0,0,0"
            Background="White" CornerRadius="10" Height="220" Width="520"
            BorderBrush="Transparent" BorderThickness="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="5" 
                                BlurRadius="10" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" TextAlignment="Center"/>
                    <Button Grid.Column="1" Content="✕" Width="28" Height="28" Background="Transparent" Foreground="Black" BorderThickness="0"
                HorizontalAlignment="Right" VerticalAlignment="Top" Click="OnClose" Padding="2" Margin="-5"/>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,16,0,20">
                    <TextBlock Text="Please select the method to process the refund" FontSize="16" TextAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                        <TextBlock Text="Amount:" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" " Width="6"/>
                        <TextBlock Text="{Binding RefundAmountText, Converter={StaticResource CurrencyFormatConverter}}" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>


                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="Cancel" Margin="0,0,10,0" Click="OnCancel" Foreground="#FF2196F3" Background="White"/>
                    <Button Content="Manual Refund" Margin="0,0,10,0" Click="OnSkip"/>
                    <Button Content="Card Machine Refund" Click="OnCard"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>


