<UserControl x:Class="POS_UI.View.PrintSelectionDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             MinWidth="420" MinHeight="260">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select what to print" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,12">
            <Button Command="{Binding SelectMainCommand}" Height="110" Margin="6" Style="{StaticResource MaterialDesignRaisedButton}">
                <StackPanel VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Receipt" Width="32" Height="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Main Receipt" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding SelectKitchenCommand}" Height="110" Margin="6" Style="{StaticResource MaterialDesignRaisedButton}">
                <StackPanel VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ChefHat" Width="32" Height="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Kitchen Receipt" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding SelectBothCommand}" Height="110" Margin="6" Style="{StaticResource MaterialDesignRaisedButton}">
                <StackPanel VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Printer" Width="32" Height="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Both" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </UniformGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}">Cancel</Button>
        </StackPanel>
    </Grid>
</UserControl>


