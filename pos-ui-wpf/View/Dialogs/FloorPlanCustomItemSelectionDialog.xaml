<view:OptimizedDialogBase x:Class="POS_UI.View.Dialogs.FloorPlanCustomItemSelectionDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:view="clr-namespace:POS_UI.View"
             xmlns:models="clr-namespace:POS_UI.Models"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:POS_UI.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             MaxWidth="720"
             d:DesignHeight="560" d:DesignWidth="720">
    <view:OptimizedDialogBase.Resources>
        <converters:PackIconKindConverter x:Key="PackIconKindConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </view:OptimizedDialogBase.Resources>

    <!-- Grid keeps footer outside scroll clip; bottom padding avoids Cancel being cut off in DialogHost -->
    <Grid Margin="18,12,18,22" MaxWidth="684">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="160" MaxHeight="500"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Add Floor Item" FontWeight="SemiBold" FontSize="19" HorizontalAlignment="Center"/>
        <StackPanel Grid.Row="1" Margin="0,8,0,12" HorizontalAlignment="Center">
            <TextBlock Text="Tap a tile to place it on the floor plan. Shapes are plain decorations."
                       FontSize="13" Foreground="#666" TextAlignment="Center" TextWrapping="Wrap"/>
            <TextBlock Text="Types come from the server catalog when available, with built-in defaults."
                       FontSize="13" Foreground="#666" TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer x:Name="TileScroll"
                      Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0"
                      CanContentScroll="False"
                      IsDeferredScrollingEnabled="False">
            <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Shapes" FontSize="13" Foreground="Gray" Margin="0,0,0,6" HorizontalAlignment="Left"/>
                <ItemsControl ItemsSource="{Binding ShapeOptions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="106" MinHeight="92" Margin="3" Padding="6"
                                    HorizontalAlignment="Left" VerticalAlignment="Top"
                                    VerticalContentAlignment="Center"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding DataContext.PlaceShapePrimitiveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="8">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="0">
                                    <Border Width="70" Height="42" HorizontalAlignment="Center" Background="Transparent">
                                        <Grid Width="60" Height="38" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Rectangle x:Name="RectShape" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" RadiusX="4" RadiusY="4" Width="56" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            <Rectangle x:Name="SqrShape" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" RadiusX="2" RadiusY="2" Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            <Ellipse x:Name="CircShape" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            <Ellipse x:Name="OvalShape" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" Width="56" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            <Rectangle x:Name="PillShape" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" RadiusX="14" RadiusY="14" Width="58" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            <Rectangle x:Name="RoundedShape" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" RadiusX="10" RadiusY="10" Width="52" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            <Path x:Name="ParaShape" Visibility="Collapsed" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" Stretch="None"
                                                  Data="M 2,36 L 50,4 L 56,14 L 8,44 Z" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Path x:Name="DiaShape" Visibility="Collapsed" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" Stretch="Uniform" Width="36" Height="36"
                                                  Data="M 18,2 L 34,18 L 18,34 L 2,18 Z" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,2"
                                               TextAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Button>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Rectangle}">
                                    <Setter TargetName="RectShape" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Square}">
                                    <Setter TargetName="SqrShape" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Circle}">
                                    <Setter TargetName="CircShape" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Oval}">
                                    <Setter TargetName="OvalShape" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Pill}">
                                    <Setter TargetName="PillShape" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Rounded}">
                                    <Setter TargetName="RoundedShape" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Parallelogram}">
                                    <Setter TargetName="ParaShape" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Diamond}">
                                    <Setter TargetName="DiaShape" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Margin="0,8,0,12" Visibility="{Binding HasCatalogTypes, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Separator Margin="0,0,0,8"/>
                    <TextBlock Text="Element type" FontSize="13" Foreground="Gray" Margin="0,0,0,6" HorizontalAlignment="Left"/>
                    <ItemsControl ItemsSource="{Binding Types}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="106" MinHeight="100" Margin="3" Padding="6"
                                        HorizontalAlignment="Left" VerticalAlignment="Top"
                                        VerticalContentAlignment="Center"
                                        HorizontalContentAlignment="Stretch"
                                        Command="{Binding DataContext.PickTypeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="8">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="0">
                                        <materialDesign:PackIcon Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                 Kind="{Binding IconKind, Converter={StaticResource PackIconKindConverter}}"/>
                                        <TextBlock MaxWidth="94" Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold" Margin="0,6,0,0"
                                                   TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="3" Content="Cancel" Width="128" Height="42" Margin="0,12,0,0" HorizontalAlignment="Center"
                Style="{StaticResource MaterialDesignOutlinedButton}"
                Command="{Binding CancelCommand}"/>
    </Grid>
</view:OptimizedDialogBase>
