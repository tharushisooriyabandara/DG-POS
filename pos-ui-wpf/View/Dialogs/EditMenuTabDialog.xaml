<UserControl x:Class="POS_UI.View.Dialogs.EditMenuTabDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:POS_UI.Converters"
             Width="1366" Height="700">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="WpfBoolToVis"/>
    </UserControl.Resources>

    <Grid Background="#F0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <TextBlock Grid.Column="0" Text="Create Your Own Menu"
                           FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                           Foreground="#1976D2" VerticalAlignment="Center" Margin="0,0,25,0"/>

                <!-- Tab Name -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Tab Name:" FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                               Foreground="#555" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Background="White" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Padding="1">
                        <TextBox Text="{Binding TabName, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Segoe UI" FontSize="14" Height="36" Width="200"
                                 Padding="10,6" Background="White" Foreground="#000"
                                 BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Placed count -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Border Background="#E3F2FD" CornerRadius="12" Padding="12,4"
                            Visibility="{Binding HasPlacedItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Foreground="#1976D2" FontSize="13" FontWeight="Bold" FontFamily="Segoe UI">
                            <Run Text="{Binding PlacedCount, Mode=OneWay}"/>
                            <Run Text=" "/><Run Text="{Binding PlacedLabel, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Clear All -->
                <Button Grid.Column="3" Content="CLEAR ALL" Width="100" Height="36" Margin="0,0,10,0"
                        FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                        Command="{Binding ClearAllCommand}" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FFEBEE"/>
                            <Setter Property="Foreground" Value="#E53935"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#E53935"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                BorderBrush="{TemplateBinding BorderBrush}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Save -->
                <Button Grid.Column="4" Content="SAVE" Width="100" Height="36" Margin="0,0,10,0"
                        FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                        Command="{Binding SaveCommand}" Background="#4CAF50" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Cancel -->
                <Button Grid.Column="5" Content="CANCEL" Width="100" Height="36"
                        FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                        Command="{Binding CancelCommand}" Background="#F44336" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Content: Split Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Menu Layout Grid -->
            <Border Grid.Column="0" Background="#FAFAFA" Margin="8" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.1" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Left Header -->
                    <Border Grid.Row="0" Background="#E3F2FD" Padding="14,10" CornerRadius="8,8,0,0">
                        <TextBlock FontSize="14" Foreground="#1565C0" FontWeight="SemiBold" FontFamily="Segoe UI"
                                   Text="Menu Layout — Tap an empty box to select it, then pick a category or item from the right panel."/>
                    </Border>

                    <!-- Grid of Slots -->
                    <ScrollViewer Grid.Row="1" x:Name="MenuGridScrollViewer"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="8" PanningMode="None">
                        <ItemsControl ItemsSource="{Binding MenuSlots}" x:Name="MenuSlotsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="SlotBorder" Width="150" Height="100" Margin="5"
                                            CornerRadius="10" Cursor="Hand"
                                            MouseLeftButtonDown="Slot_MouseLeftButtonDown">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F5F5F5"/>
                                                <Setter Property="BorderBrush" Value="#BDBDBD"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Style.Triggers>
                                                    <!-- Empty slot default -->
                                                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                        <Setter Property="Background" Value="#FAFAFA"/>
                                                        <Setter Property="BorderBrush" Value="#BDBDBD"/>
                                                    </DataTrigger>
                                                    <!-- Active empty slot: blue highlight -->
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="#E3F2FD"/>
                                                        <Setter Property="BorderBrush" Value="#1976D2"/>
                                                        <Setter Property="BorderThickness" Value="3"/>
                                                    </DataTrigger>
                                                    <!-- Filled slot: use item color -->
                                                    <DataTrigger Binding="{Binding IsFilled}" Value="True">
                                                        <Setter Property="Background" Value="{Binding BackgroundColor}"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.15" Color="Black"/>
                                        </Border.Effect>
                                        <Grid>
                                            <!-- Empty Slot Content -->
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                        Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="+" FontSize="32" FontWeight="Light"
                                                           Foreground="#BDBDBD" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Add" FontSize="11" Foreground="#9E9E9E"
                                                           HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                                            </StackPanel>

                                            <!-- Filled Slot Content -->
                                            <Grid Visibility="{Binding IsFilled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <!-- Type Badge + Color Picker Toggle (top-left) -->
                                                <Button HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="Hand"
                                                        Command="{Binding DataContext.ToggleColorPickerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="typeBadge" Background="{Binding TypeColor}" CornerRadius="10,0,6,0"
                                                                                Padding="6,2">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="{Binding TypeLabel}" FontSize="10" FontWeight="Bold"
                                                                                           Foreground="White" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                                                <TextBlock Text=" ▼" FontSize="8" Foreground="#CCFFFFFF"
                                                                                           VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <!-- Color Picker Popup -->
                                                <Popup IsOpen="{Binding IsColorPickerOpen}" StaysOpen="False"
                                                       Placement="Bottom" PlacementTarget="{Binding ElementName=SlotBorder}"
                                                       HorizontalOffset="0" VerticalOffset="0" AllowsTransparency="True">
                                                    <Border Background="White" CornerRadius="10" Padding="12"
                                                            BorderBrush="#E0E0E0" BorderThickness="1">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.25" Color="Black"/>
                                                        </Border.Effect>
                                                        <StackPanel>
                                                            <TextBlock Text="Pick a color" FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="#666" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                                            <ItemsControl ItemsSource="{Binding DataContext.AvailableColors, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel Orientation="Horizontal" MaxWidth="270"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Width="44" Height="44" Margin="4" CornerRadius="22"
                                                                                Background="{Binding}" Cursor="Hand"
                                                                                MouseLeftButtonDown="ColorCircle_Click">
                                                                            <Border.Effect>
                                                                                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.2" Color="Black"/>
                                                                            </Border.Effect>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>

                                                <!-- Remove X Button (top-right) -->
                                                <Button Width="24" Height="24" HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        Margin="0,-2,-2,0" Cursor="Hand"
                                                        Command="{Binding DataContext.RemoveSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="#80000000" CornerRadius="0,10,0,6" Padding="0">
                                                                            <TextBlock Text="✕" FontSize="12" FontWeight="Bold"
                                                                                       Foreground="White" HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <!-- Name and Category -->
                                                <StackPanel VerticalAlignment="Center" Margin="8,14,8,4">
                                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold"
                                                               Foreground="White" TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis" MaxHeight="38"
                                                               TextAlignment="Center" HorizontalAlignment="Center"
                                                               FontFamily="Segoe UI"/>
                                                    <TextBlock Text="{Binding Category}" FontSize="11"
                                                               Foreground="White" Opacity="0.85"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextAlignment="Center" HorizontalAlignment="Center"
                                                               FontFamily="Segoe UI" Margin="0,2,0,0"
                                                               Visibility="{Binding Category, Converter={StaticResource WpfBoolToVis}, FallbackValue=Collapsed}"/>
                                                </StackPanel>

                                                <!-- Order number (bottom-right) — 1-based -->
                                                <Border Background="#50000000" CornerRadius="8" Padding="5,1"
                                                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,4">
                                                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="White"
                                                               FontFamily="Segoe UI">
                                                        <Run Text="#"/><Run Text="{Binding DisplayNumber, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT PANEL: Picker -->
            <Border Grid.Column="1" Background="White" Margin="0,8,8,8" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.1" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Picker Tab Buttons -->
                    <Grid Grid.Row="0" Margin="10,10,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="Categories" Height="38" Margin="0,0,4,0"
                                FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                Command="{Binding ToggleCategoriesCommand}" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                    <Setter Property="Foreground" Value="#666"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="BorderBrush" Value="#CCC"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        BorderBrush="{TemplateBinding BorderBrush}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsShowCategories}" Value="True">
                                            <Setter Property="Background" Value="#4CAF50"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="1" Content="Items" Height="38" Margin="4,0,0,0"
                                FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                Command="{Binding ToggleItemsCommand}" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                    <Setter Property="Foreground" Value="#666"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="BorderBrush" Value="#CCC"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        BorderBrush="{TemplateBinding BorderBrush}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsShowItems}" Value="True">
                                            <Setter Property="Background" Value="#FF9800"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#FF9800"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- Search Box -->
                    <Border Grid.Row="1" Background="White" BorderBrush="#CCC" BorderThickness="1"
                            CornerRadius="6" Margin="10,8,10,4" Padding="1">
                        <Grid>
                            <TextBox x:Name="CategorySearchBox"
                                     Text="{Binding CategorySearchText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Segoe UI" FontSize="14" Height="36" Padding="10,6"
                                     Background="White" Foreground="#000" BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     Visibility="{Binding IsShowCategories, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBox x:Name="ItemSearchBox"
                                     Text="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Segoe UI" FontSize="14" Height="36" Padding="10,6"
                                     Background="White" Foreground="#000" BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     Visibility="{Binding IsShowItems, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="Search..." FontFamily="Segoe UI" FontSize="14"
                                       Foreground="#999" VerticalAlignment="Center" Margin="12,0,0,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsShowCategories}" Value="True"/>
                                                    <Condition Binding="{Binding CategorySearchText}" Value=""/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsShowCategories}" Value="True"/>
                                                    <Condition Binding="{Binding CategorySearchText}" Value="{x:Null}"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsShowItems}" Value="True"/>
                                                    <Condition Binding="{Binding ItemSearchText}" Value=""/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsShowItems}" Value="True"/>
                                                    <Condition Binding="{Binding ItemSearchText}" Value="{x:Null}"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Picker Content -->
                    <Grid Grid.Row="2" Margin="6,0,6,6">
                        <!-- Categories Picker -->
                        <ScrollViewer x:Name="PickerCategoriesScrollViewer"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      PanningMode="None"
                                      Visibility="{Binding IsShowCategories, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding FilteredCategories}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Width="155" Height="70" Margin="4" Cursor="Hand"
                                                Command="{Binding DataContext.AssignCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="catBorder" CornerRadius="8" Padding="8"
                                                                        Background="{Binding BackgroundColor}">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" Color="Black"/>
                                                                    </Border.Effect>
                                                                    <Grid>
                                                                        <Border Background="White" CornerRadius="10"
                                                                                Width="20" Height="20"
                                                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                                Margin="0,-2,-2,0"
                                                                                Visibility="{Binding IsPlaced, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                            <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                                                                       Foreground="#4CAF50" HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold"
                                                                                   Foreground="White" TextWrapping="Wrap"
                                                                                   TextAlignment="Center" VerticalAlignment="Center"
                                                                                   TextTrimming="CharacterEllipsis" MaxHeight="36"
                                                                                   FontFamily="Segoe UI"/>
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPlaced}" Value="True">
                                                                        <Setter TargetName="catBorder" Property="Opacity" Value="0.5"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="catBorder" Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Items Picker -->
                        <ScrollViewer x:Name="PickerItemsScrollViewer"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      PanningMode="None"
                                      Visibility="{Binding IsShowItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding FilteredItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Width="155" Height="65" Margin="4" Cursor="Hand"
                                                Command="{Binding DataContext.AssignItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="itemBorder" CornerRadius="8" Padding="8"
                                                                        Background="{Binding BackgroundColor}">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" Color="Black"/>
                                                                    </Border.Effect>
                                                                    <Grid>
                                                                        <Border Background="White" CornerRadius="10"
                                                                                Width="20" Height="20"
                                                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                                Margin="0,-2,-2,0"
                                                                                Visibility="{Binding IsPlaced, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                            <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                                                                       Foreground="#FF9800" HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <StackPanel VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold"
                                                                                       Foreground="White" TextWrapping="Wrap"
                                                                                       TextTrimming="CharacterEllipsis" MaxHeight="32"
                                                                                       FontFamily="Segoe UI"/>
                                                                            <TextBlock Text="{Binding Category}" FontSize="11"
                                                                                       Foreground="White" Opacity="0.85"
                                                                                       TextTrimming="CharacterEllipsis"
                                                                                       FontFamily="Segoe UI" Margin="0,2,0,0"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPlaced}" Value="True">
                                                                        <Setter TargetName="itemBorder" Property="Opacity" Value="0.5"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="itemBorder" Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
