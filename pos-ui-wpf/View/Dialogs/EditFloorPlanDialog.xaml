<UserControl x:Class="POS_UI.View.Dialogs.EditFloorPlanDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:POS_UI.Converters"
             xmlns:controls2="clr-namespace:POS_UI.View.Controls"
             xmlns:models="clr-namespace:POS_UI.Models"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded"
             Background="#F0F2F5">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:ColorHexStringToBrushConverter x:Key="ColorHexStringToBrushConverter"/>
        <converters:PackIconKindConverter x:Key="PackIconKindConverter"/>
        <converters:FloorPlanSeatLineVisibilityConverter x:Key="FloorPlanSeatLineVisibilityConverter"/>
        <Style x:Key="FloorPlanShapeListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="2"/>
                        <Setter Property="Margin" Value="0,0,6,6"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder" Padding="4" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Background="White">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#1976D2"/>
                                            <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Floor Plan Layout"
                           FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                           Foreground="#1976D2" VerticalAlignment="Center" Margin="0,0,25,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Floor Plan Name:" FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                               Foreground="#555" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Background="White" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Padding="1">
                        <TextBox Text="{Binding EditingFloorPlanDraft.Name, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Segoe UI" FontSize="14" Height="36" Width="220"
                                 Padding="10,6" Background="White" Foreground="#000"
                                 BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>
                </StackPanel>
                <Button Grid.Column="3" Content="CLEAR ALL" Width="100" Height="36" Margin="0,0,10,0"
                        FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                        Command="{Binding ClearFloorPlanCommand}" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FFEBEE"/>
                            <Setter Property="Foreground" Value="#E53935"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#E53935"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                BorderBrush="{TemplateBinding BorderBrush}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="4" Content="SAVE" Width="100" Height="36" Margin="0,0,10,0"
                        FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                        Command="{Binding SaveFloorPlanCommand}" Background="#4CAF50" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="5" Content="CANCEL" Width="100" Height="36"
                        FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                        Command="{Binding CancelFloorPlanEditCommand}" Background="#F44336" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="350" MinWidth="220"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" BorderBrush="#D6D6D6" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,0,8,0">
                    <!-- Both: finger-pan the canvas on empty space; table borders capture touch for drag (code-behind). -->
                    <ScrollViewer x:Name="FloorPlanCanvasScroll" PanningMode="Both"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Grid MinWidth="900" MinHeight="500">
                            <ItemsControl ItemsSource="{Binding EditingFloorPlanDraft.Tables}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="1800" Height="1100" Background="#F9F9F9"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Border x:Name="TileBorder" Width="{Binding Width}" Height="{Binding Height}"
                                                    Background="{Binding ColorHex, Converter={StaticResource ColorHexStringToBrushConverter}}"
                                                    CornerRadius="{Binding CornerRadiusValue}" Cursor="Hand"
                                                    MouseLeftButtonDown="FloorPlanTable_MouseLeftButtonDown"
                                                    MouseMove="FloorPlanTable_MouseMove"
                                                    MouseLeftButtonUp="FloorPlanTable_MouseLeftButtonUp"
                                                    PreviewTouchDown="FloorPlanTable_PreviewTouchDown"
                                                    TouchMove="FloorPlanTable_TouchMove"
                                                    TouchUp="FloorPlanTable_TouchUp"
                                                    LostTouchCapture="FloorPlanTable_LostTouchCapture">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelectedOnCanvas}" Value="True">
                                                                <Setter Property="BorderBrush" Value="Black"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="0" Opacity="0.68"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Shape}" Value="{x:Static models:FloorPlanShapeType.Parallelogram}">
                                                                <Setter Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <SkewTransform AngleX="-18" AngleY="0"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Shape}" Value="{x:Static models:FloorPlanShapeType.Diamond}">
                                                                <Setter Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <RotateTransform Angle="45"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <StackPanel x:Name="TableLabelPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding TableName}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="200"/>
                                                        <TextBlock Text="{Binding SeatCount, StringFormat=Seats: {0}}" Foreground="White" FontSize="11" HorizontalAlignment="Center"
                                                                   Visibility="{Binding Kind, Converter={StaticResource FloorPlanSeatLineVisibilityConverter}}"/>
                                                    </StackPanel>
                                                    <StackPanel x:Name="CustomItemPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                                                        <materialDesign:PackIcon Kind="{Binding IconKindName, Converter={StaticResource PackIconKindConverter}}" Width="28" Height="28" Foreground="White" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding TableName}" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="200" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:FloorPlanElementKind.CustomItem}">
                                                <Setter TargetName="TableLabelPanel" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="CustomItemPanel" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="1" Background="White" BorderBrush="#D6D6D6" BorderThickness="1" CornerRadius="8" Padding="8">
                    <ScrollViewer x:Name="CustomizePanelScroll" 
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False"
                                  Padding="0,0,0,40"
                                  PreviewMouseWheel="CustomizePanelScroll_PreviewMouseWheel">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Add / Remove" FontWeight="Bold" FontSize="13" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                            <UniformGrid Columns="2" Margin="0,0,0,8">
                                <Button Content="Add Table" Height="40" Margin="0,0,4,0"
                                        Background="#1976D2" Foreground="White" BorderBrush="#1976D2"
                                        materialDesign:ButtonAssist.CornerRadius="6"
                                        FontSize="13" FontWeight="SemiBold"
                                        Command="{Binding AddTableToFloorPlanCommand}"/>
                                <Button Content="Add Item" Height="40" Margin="4,0,0,0"
                                        Background="#1976D2" Foreground="White" BorderBrush="#1976D2"
                                        materialDesign:ButtonAssist.CornerRadius="6"
                                        FontSize="13" FontWeight="SemiBold"
                                        Command="{Binding AddCustomItemToFloorPlanCommand}"/>
                            </UniformGrid>
                            <Button Content="Remove" Height="40" Margin="0,0,0,12" HorizontalAlignment="Stretch"
                                    Background="#F44336" Foreground="White" BorderBrush="#F44336"
                                    materialDesign:ButtonAssist.CornerRadius="6"
                                    FontSize="13" FontWeight="SemiBold"
                                    Command="{Binding RemoveTableFromFloorPlanCommand}"
                                    IsEnabled="{Binding HasSelectedFloorPlanTable}"/>

                            <Separator Margin="0,0,0,12"/>

                            <TextBlock Text="Customize selection" FontWeight="Bold" FontSize="13" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding SelectedPlacedFloorPlanTable.TableName, TargetNullValue=Tap a table or item on the canvas}" Margin="0,0,0,10" Foreground="#455A64" TextWrapping="Wrap"
                                       FontSize="16" FontWeight="SemiBold" FontFamily="Segoe UI"/>

                            <TextBlock Text="Width" FontSize="12" Foreground="Gray"/>
                            <Grid Margin="0,4,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Width="44" Height="44" MinWidth="44" MinHeight="44" Padding="0" Margin="0,0,8,0"
                                        Content="−" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                                        Command="{Binding DecreaseFloorPlanTableWidthCommand}"
                                        IsEnabled="{Binding HasSelectedFloorPlanTable}"/>
                                <TextBox x:Name="FloorPlanWidthBox" Grid.Column="1"
                                         Margin="0,0,8,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                         HorizontalAlignment="Stretch" MinHeight="44"
                                         PreviewTextInput="FloorPlanDimTextBox_PreviewTextInput"
                                         PreviewKeyDown="FloorPlanDimTextBox_PreviewKeyDown"
                                         Text="{Binding SelectedPlacedFloorPlanTable.Width, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding HasSelectedFloorPlanTable}"/>
                                <Button Grid.Column="2" Width="44" Height="44" MinWidth="44" MinHeight="44" Padding="0"
                                        Content="+" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                                        Command="{Binding IncreaseFloorPlanTableWidthCommand}"
                                        IsEnabled="{Binding HasSelectedFloorPlanTable}"/>
                            </Grid>

                            <TextBlock Text="Height" FontSize="12" Foreground="Gray"/>
                            <Grid Margin="0,4,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Width="44" Height="44" MinWidth="44" MinHeight="44" Padding="0" Margin="0,0,8,0"
                                        Content="−" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                                        Command="{Binding DecreaseFloorPlanTableHeightCommand}"
                                        IsEnabled="{Binding HasSelectedFloorPlanTable}"/>
                                <TextBox x:Name="FloorPlanHeightBox" Grid.Column="1"
                                         Margin="0,0,8,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                         HorizontalAlignment="Stretch" MinHeight="44"
                                         PreviewTextInput="FloorPlanDimTextBox_PreviewTextInput"
                                         PreviewKeyDown="FloorPlanDimTextBox_PreviewKeyDown"
                                         Text="{Binding SelectedPlacedFloorPlanTable.Height, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding HasSelectedFloorPlanTable}"/>
                                <Button Grid.Column="2" Width="44" Height="44" MinWidth="44" MinHeight="44" Padding="0"
                                        Content="+" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                                        Command="{Binding IncreaseFloorPlanTableHeightCommand}"
                                        IsEnabled="{Binding HasSelectedFloorPlanTable}"/>
                            </Grid>

                            <TextBlock Text="Shape" FontSize="12" Foreground="Gray"/>
                            <ListBox Style="{StaticResource FloorPlanShapeListBox}"
                                     ItemsSource="{Binding FloorPlanShapeOptions}"
                                     SelectedItem="{Binding SelectedPlacedFloorPlanTable.Shape, Mode=TwoWay}"
                                     Margin="0,4,0,8"
                                     IsEnabled="{Binding HasSelectedFloorPlanTable}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="58" Height="44" Background="Transparent">
                                            <Grid Width="40" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Rectangle x:Name="RectShape" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" RadiusX="4" RadiusY="4" Width="36" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                <Rectangle x:Name="SqrShape" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" RadiusX="2" RadiusY="2" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                <Ellipse x:Name="CircShape" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                <Ellipse x:Name="OvalShape" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" Width="36" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                <Rectangle x:Name="PillShape" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" RadiusX="11" RadiusY="11" Width="36" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                <Rectangle x:Name="RoundedShape" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" RadiusX="10" RadiusY="10" Width="34" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                <Path x:Name="ParaShape" Visibility="Collapsed" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" Stretch="None"
                                                      Data="M 4,26 L 30,8 L 36,14 L 10,32 Z" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Path x:Name="DiaShape" Visibility="Collapsed" Fill="#B0BEC5" Stroke="#455A64" StrokeThickness="1" Stretch="Uniform" Width="26" Height="26"
                                                      Data="M 13,2 L 24,13 L 13,24 L 2,13 Z" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Rectangle}">
                                                <Setter TargetName="RectShape" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Square}">
                                                <Setter TargetName="SqrShape" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Circle}">
                                                <Setter TargetName="CircShape" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Oval}">
                                                <Setter TargetName="OvalShape" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Pill}">
                                                <Setter TargetName="PillShape" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Rounded}">
                                                <Setter TargetName="RoundedShape" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Parallelogram}">
                                                <Setter TargetName="ParaShape" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static models:FloorPlanShapeType.Diamond}">
                                                <Setter TargetName="DiaShape" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Text="Pick Color  ▼" FontSize="12" Foreground="Gray"/>
                            <StackPanel Margin="0,4,0,8">
                                <Button x:Name="FloorPlanColorButton" HorizontalAlignment="Left" Padding="4" Cursor="Hand"
                                        Command="{Binding ToggleFloorPlanColorPickerCommand}"
                                        IsEnabled="{Binding HasSelectedFloorPlanTable}"
                                        materialDesign:ButtonAssist.CornerRadius="6"
                                        BorderBrush="#CCC" BorderThickness="1" Background="White">
                                    <Grid Width="200" Height="40">
                                        <Border CornerRadius="4" Margin="2,2,2,2"
                                                Background="{Binding SelectedPlacedFloorPlanTable.ColorHex, Converter={StaticResource ColorHexStringToBrushConverter}}"/>
                                    </Grid>
                                </Button>
                                <Popup IsOpen="{Binding IsFloorPlanColorPickerOpen}" StaysOpen="False"
                                       Placement="Bottom" PlacementTarget="{Binding ElementName=FloorPlanColorButton}"
                                       AllowsTransparency="True">
                                    <Border Background="White" CornerRadius="10" Padding="12" BorderBrush="#E0E0E0" BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.25" Color="Black"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock Text="Pick a color" FontSize="13" FontWeight="SemiBold" Foreground="#666" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                            <ItemsControl ItemsSource="{Binding FloorPlanColorPalette}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" MaxWidth="270"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="44" Height="44" Margin="4" CornerRadius="22"
                                                                Background="{Binding Converter={StaticResource ColorHexStringToBrushConverter}}" Cursor="Hand"
                                                                MouseLeftButtonDown="FloorPlanColorCircle_MouseLeftButtonDown">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.2" Color="Black"/>
                                                            </Border.Effect>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>

                            <TextBlock Text="Color (Hex)" FontSize="12" Foreground="Gray"/>
                            <TextBox Text="{Binding SelectedPlacedFloorPlanTable.ColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,0,20" MaxLength="9"
                                     VerticalContentAlignment="Center" Padding="8,6"
                                     IsEnabled="{Binding HasSelectedFloorPlanTable}"
                                     ToolTip="e.g. #1976D2"/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <controls2:LoadingIndicator Grid.Row="1"
                                     Panel.ZIndex="10"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     ProgressRingSize="56"
                                     Visibility="{Binding IsLoadingFloorPlanTables, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</UserControl>
