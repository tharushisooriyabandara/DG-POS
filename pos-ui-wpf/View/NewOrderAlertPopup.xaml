<UserControl x:Class="POS_UI.View.NewOrderAlertPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Height="120" Width="600" Background="Transparent">
    <UserControl.Resources>
        <Storyboard x:Key="FadeUpAndOut" FillBehavior="Stop">
            <DoubleAnimation Storyboard.TargetName="AlertBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetName="AlertTranslate" Storyboard.TargetProperty="Y" To="-30" Duration="0:0:0.25"/>
        </Storyboard>
    </UserControl.Resources>
    <StackPanel>
        <!-- Main Alert -->
        <Border x:Name="AlertBorder" Background="#6FC08F" CornerRadius="18" Padding="18" Margin="0,8,0,0" MouseLeftButtonUp="AlertBorder_MouseLeftButtonUp">
            <Border.RenderTransform>
                <TranslateTransform x:Name="AlertTranslate" Y="0"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Hey Cashier" Foreground="White" FontSize="20" TextAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Text="New Order Alert" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,6,0,0" TextAlignment="Center" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </StackPanel>
</UserControl> 