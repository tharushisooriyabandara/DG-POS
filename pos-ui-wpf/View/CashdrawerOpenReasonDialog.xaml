<UserControl x:Class="POS_UI.View.CashdrawerOpenReasonDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             MinWidth="420" MinHeight="220">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Open Cash Drawer" FontWeight="Bold" FontSize="19"/>
            <Button Grid.Column="1" Width="32" Height="32" Margin="0,-10,-10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource MaterialDesignToolButton}" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" CommandParameter="{x:Null}" ToolTip="Close" Background="Transparent" BorderBrush="Transparent">
                <materialDesign:PackIcon Kind="Close" Width="25" Height="25"/>
            </Button>
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,25,0,0">
            <TextBlock Text="Reason" Margin="0,0,0,6" FontSize="14" FontWeight="SemiBold"/>
            <Border Background="#FFF" Width="400" HorizontalAlignment="Left" CornerRadius="8" Padding="5" BorderBrush="#E5E7EB" BorderThickness="1">
                <TextBox x:Name="ReasonTextBox" Height="40" BorderBrush="Transparent"
                     materialDesign:HintAssist.Hint="Enter reason for opening cash drawer" FontSize="14"
                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden" Margin="2,0,0,0"
                     VerticalContentAlignment="Center"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Cancel" Height="36" Margin="0,0,8,0" Background="White" Foreground="#FF2196F3" BorderBrush="#FF2196F3"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" CommandParameter="{x:Null}"/>
            <Button Content="Open" Height="36" Width="120"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    IsEnabled="{Binding IsOpenEnabled}"
                    Click="Open_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
