<UserControl x:Class="POS_UI.View.CardTransactionLoadingDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:POS_UI.ViewModels"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400">
    <UserControl.Resources>
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseEllipse" 
                            Storyboard.TargetProperty="Opacity"
                            From="0.3" To="1.0" Duration="0:0:1.5" 
                            AutoReverse="True"/>
        </Storyboard>
    </UserControl.Resources>
    
    <Border Background="White" CornerRadius="16" Padding="32" Width="400" Height="300">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,24">
                <Ellipse x:Name="PulseEllipse" Width="80" Height="80" 
                         Fill="#1976D2" Opacity="0.7" Margin="0,0,0,16">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Ellipse.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                    From="0.3" To="1.0" Duration="0:0:1.5" 
                                                    AutoReverse="True" RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                
                <materialDesign:PackIcon Kind="CreditCard" Width="40" Height="40" 
                                        Foreground="White" HorizontalAlignment="Center"/>
                
                <TextBlock Text="Processing Card Payment" FontWeight="Bold" FontSize="20" 
                           HorizontalAlignment="Center" Margin="0,16,0,8"/>
                <TextBlock Text="Please wait while we process your payment..." 
                           Foreground="Gray" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
            
            <!-- Progress Section -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,16">
                <TextBlock Text="{Binding StatusText}" 
                           FontWeight="Medium" HorizontalAlignment="Center" 
                           Margin="0,0,0,16" TextWrapping="Wrap"/>
                
                <ProgressBar Height="6" Margin="0,0,0,8" 
                            IsIndeterminate="{Binding IsProcessing}" Background="#E0E0E0" 
                            Foreground="#1976D2"/>
                
                <TextBlock Text="{Binding ProgressText}" 
                           Foreground="Gray" HorizontalAlignment="Center" 
                           FontSize="12"/>
            </StackPanel>
            
            <!-- Cancel Button -->
            <Button Grid.Row="2" Content="Cancel Transaction" 
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding CancelCommand}"
                    HorizontalAlignment="Center" Margin="0,16,0,0"
                    Padding="24,8" FontWeight="Medium"/>
        </Grid>
    </Border>
</UserControl> 