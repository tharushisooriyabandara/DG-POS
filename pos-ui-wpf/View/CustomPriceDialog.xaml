<UserControl x:Class="POS_UI.View.CustomPriceDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             MinWidth="360"
             MinHeight="420">
    <Border Background="White"
            CornerRadius="16"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Set Custom Price"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding ItemName}"
                               FontSize="14"
                               Foreground="#666"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Width="32"
                        Height="32"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-8,-8,0"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Command="{Binding CancelCommand}">
                    <materialDesign:PackIcon Kind="Close"
                                               Width="20"
                                               Height="20"/>
                </Button>
            </Grid>

            <!-- Price Display -->
            <Border Grid.Row="1"
                    Background="#F5F5F5"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding DisplayPrice}"
                               FontSize="32"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="Clear"
                            Margin="12,0,0,0"
                            Height="36"
                            Width="80"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding ClearCommand}"/>
                </Grid>
            </Border>

            <!-- Helper Text -->
            <TextBlock Grid.Row="2"
                       Text="Use the keypad to enter a price."
                       Foreground="#888"
                       FontSize="12"
                       Margin="0,0,0,16"/>

            <!-- Number Pad -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Content="1" Margin="4" Height="52"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontSize="18" FontWeight="Bold"
                        Command="{Binding NumberPadCommand}" CommandParameter="1"/>
                <Button Grid.Row="0" Grid.Column="1" Content="2" Margin="4" Height="52"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontSize="18" FontWeight="Bold"
                        Command="{Binding NumberPadCommand}" CommandParameter="2"/>
                <Button Grid.Row="0" Grid.Column="2" Content="3" Margin="4" Height="52"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontSize="18" FontWeight="Bold"
                        Command="{Binding NumberPadCommand}" CommandParameter="3"/>

                <Button Grid.Row="1" Grid.Column="0" Content="4" Margin="4" Height="52"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontSize="18" FontWeight="Bold"
                        Command="{Binding NumberPadCommand}" CommandParameter="4"/>
                <Button Grid.Row="1" Grid.Column="1" Content="5" Margin="4" Height="52"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontSize="18" FontWeight="Bold"
                        Command="{Binding NumberPadCommand}" CommandParameter="5"/>
                <Button Grid.Row="1" Grid.Column="2" Content="6" Margin="4" Height="52"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontSize="18" FontWeight="Bold"
                        Command="{Binding NumberPadCommand}" CommandParameter="6"/>

                <Button Grid.Row="2" Grid.Column="0" Content="7" Margin="4" Height="52"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontSize="18" FontWeight="Bold"
                        Command="{Binding NumberPadCommand}" CommandParameter="7"/>
                <Button Grid.Row="2" Grid.Column="1" Content="8" Margin="4" Height="52"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontSize="18" FontWeight="Bold"
                        Command="{Binding NumberPadCommand}" CommandParameter="8"/>
                <Button Grid.Row="2" Grid.Column="2" Content="9" Margin="4" Height="52"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontSize="18" FontWeight="Bold"
                        Command="{Binding NumberPadCommand}" CommandParameter="9"/>

                <Button Grid.Row="3" Grid.Column="0" Content="." Margin="4" Height="52"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontSize="18" FontWeight="Bold"
                        Command="{Binding NumberPadCommand}" CommandParameter="."/>
                <Button Grid.Row="3" Grid.Column="1" Content="0" Margin="4" Height="52"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontSize="18" FontWeight="Bold"
                        Command="{Binding NumberPadCommand}" CommandParameter="0"/>
                <Button Grid.Row="3" Grid.Column="2" Content="←" Margin="4" Height="52"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        FontSize="18" FontWeight="Bold"
                        Command="{Binding NumberPadCommand}" CommandParameter="Backspace"/>
            </Grid>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">
                <Button Content="Apply Price"
                        Width="123"
                        Height="36"
                        Background="#1976D2"
                        Foreground="White"
                        FontWeight="Bold"
                        Command="{Binding ConfirmCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

