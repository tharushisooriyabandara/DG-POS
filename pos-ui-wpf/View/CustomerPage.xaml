<UserControl x:Class="POS_UI.View.CustomerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:POS_UI.View.Controls"
             xmlns:view="clr-namespace:POS_UI.View"
             xmlns:local="clr-namespace:POS_UI"
             xmlns:converters="clr-namespace:POS_UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">
    
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertBooleanToVisibilityConverter x:Key="InvertBooleanToVisibilityConverter"/>
        <converters:GuestCustomerToBooleanConverter x:Key="GuestCustomerToBooleanConverter"/>
    </UserControl.Resources>
    
    <Grid Background="#F5F5F5">
      

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <local:Sidebar x:Name="SidebarControl" Grid.Column="0"/>
        <materialDesign:DialogHost Grid.Column="1" Identifier="CustomerDialogHost" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
        <Grid Background="#F8F8F8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- Header -->
            <Border Grid.Row="0" Padding="0,0,10,10" Margin="10,0,10,0" >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,5,10,0">
                                <Border Background="#2196F3" Width="15" Height="60" CornerRadius="5"/>
                                <StackPanel Orientation="Vertical" Margin="10">
                                    <TextBlock Text="Customer Management" FontSize="22" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <TextBlock Text="Manage Your Customer Database" FontSize="15"/>
                                    <!--<Button Content="Refresh" Command="{Binding RefreshTablesCommand}" Width="80" Height="24" Margin="20,0,0,0" Background="#1976D2" Foreground="White" FontWeight="Bold"/>-->
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Margin="0,30,-10,0">
                            <Border Background="#FFFFFF" CornerRadius="8" Width="280" BorderBrush="#E5E7EB" BorderThickness="1" Padding="8" Margin="0,0,0,0" HorizontalAlignment="Right">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="400"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" BorderThickness="0" Background="Transparent"  
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                            materialDesign:HintAssist.Hint="Search Customers..." FontSize="14"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    <!--<Button Grid.Column="1" Content="Add Customer" 
                        Background="#1976D2" Foreground="White" 
                        Padding="16,8" FontWeight="SemiBold"
                        Command="{Binding AddCustomerCommand}"/>-->
                    
                    
                </Grid>
            </Border>

            <!-- Customer Table -->
            <Border Grid.Row="1" Background="White" Margin="10,0,10,16" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Loading Indicator -->
                    <controls:LoadingIndicator Grid.Row="0" Grid.RowSpan="2"
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center" 
                                          ProgressRingSize="70"
                                          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- Table Header -->
                        <Border  Background="#FFE2E2E2">
                            <Grid Grid.Row="0"  Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="370"/>
                                </Grid.ColumnDefinitions>


                                <TextBlock Grid.Column="0" Text="ID" FontWeight="Bold" Foreground="#1976D2" TextAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="5"/>
                                <TextBlock Grid.Column="1" Text="Full Name" FontWeight="Bold" Foreground="#1976D2" TextAlignment="Left" FontSize="16" VerticalAlignment="Center" Padding="5"/>
                                <TextBlock Grid.Column="2" Text="Phone Number" FontWeight="Bold" Foreground="#1976D2" TextAlignment="Left" FontSize="16" VerticalAlignment="Center" Padding="5" Margin="-15,0,0,0"/>
                                <TextBlock Grid.Column="3" Text="Actions" FontWeight="Bold" Foreground="#1976D2" TextAlignment="Center" FontSize="16" VerticalAlignment="Center" Padding="5" Margin="-28,0,0,0"/>

                            </Grid>
                        </Border>

                        <!-- Customer List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Resources>
                                <!-- Apply thicker scrollbar style defined in Stylesxaml.xaml -->
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                            </ScrollViewer.Resources>
                        <ItemsControl ItemsSource="{Binding Customers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="350"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Customer ID -->
                                            <TextBlock Grid.Column="0" Text="{Binding CustomerId}" HorizontalAlignment="Center"
                                                   FontSize="15" FontWeight="SemiBold" Foreground="#333" VerticalAlignment="Center"/>

                                            <!-- Full Name -->
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" 
                                                   FontSize="15" FontWeight="SemiBold" Foreground="#333" VerticalAlignment="Center"/>

                                            <!-- Phone Number -->
                                            <TextBlock Grid.Column="2" Text="{Binding FullPhoneNumber}" 
                                                   FontSize="15" Foreground="#666" VerticalAlignment="Center"/>

                                            <!-- Action Buttons -->
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="View" BorderBrush="Transparent"
                                                    Background="#1976D2" Foreground="White" FontWeight="SemiBold"
                                                    Padding="10,6" Margin="0,0,15,0" FontSize="14" Width="150" Height="38"
                                                    Command="{Binding DataContext.ViewCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>

                                                    <Button Content="Edit" BorderBrush="Transparent"
                                                    Background="#1976D2" Foreground="White" FontWeight="SemiBold"
                                                    Padding="12,6" Margin="0,0,8,0" FontSize="14" Width="150" Height="38"
                                                    Command="{Binding DataContext.EditCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding Converter={StaticResource GuestCustomerToBooleanConverter}, ConverterParameter=Invert}"/>
                                                </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Pagination Footer -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="8">
                        <Button Content="First" Command="{Binding FirstPageCommand}" Margin="0,0,8,0" Padding="10,6" BorderBrush="Transparent" Background="#1976D2" Foreground="White"/>
                        <Button Command="{Binding PrevPageCommand}" Margin="0,0,8,0" Padding="10,6" BorderBrush="Transparent" Background="#1976D2" Foreground="White">
                        <materialDesign:PackIcon Kind="NavigateBefore" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </Button>

                        <TextBlock Text="{Binding PageInfoText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Command="{Binding NextPageCommand}" Margin="0,0,8,0" Padding="10,6" BorderBrush="Transparent" Background="#1976D2" Foreground="White">
                        <materialDesign:PackIcon Kind="NavigateNext" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </Button>
                        <Button Content="Last" Command="{Binding LastPageCommand}" Padding="10,6" BorderBrush="Transparent" Background="#1976D2" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        </materialDesign:DialogHost>
    </Grid>
</UserControl>
