<Page x:Class="POS_UI.CashierHomePage"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:POS_UI.ViewModels"
      xmlns:local="clr-namespace:POS_UI"
      xmlns:converters="clr-namespace:POS_UI.Converters"
      xmlns:view="clr-namespace:POS_UI.View"
      xmlns:controls="clr-namespace:POS_UI.View.Controls"
      Title="Cashier Home">
    <Page.DataContext>
        <vm:CashierHomeViewModel/>
    </Page.DataContext>
    <Page.Resources>
        <converters:StringToColorConverter x:Key="StringToColorConverter"/>
        <converters:StringToForegroundConverter x:Key="StringToForegroundConverter"/>
        <converters:CategorySelectionToBackgroundMultiConverter x:Key="CategorySelectionToBackgroundMultiConverter"/>
        <converters:CategorySelectionToForegroundMultiConverter x:Key="CategorySelectionToForegroundMultiConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:StringToIconConverter x:Key="StringToIconConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:SortOptionToStringConverter x:Key="SortOptionToStringConverter"/>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <converters:QuantityToTextConverter x:Key="QuantityToTextConverter"/>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="134*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>
        <!-- Sidebar -->
        <local:Sidebar x:Name="SidebarControl" Grid.Column="0" Grid.RowSpan="2"/>
        <!-- DialogHost covering columns 1 and 2 -->
        <materialDesign:DialogHost x:Name="AddItemDialogHost" Grid.Column="1" Grid.ColumnSpan="2" Identifier="AddItemDialogHost" Grid.RowSpan="2" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="121*"/>
                    <RowDefinition Height="443*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- Main Content (was Grid.Column=1) -->
                <Grid Grid.Column="0" Background="#F8F8F8" Grid.RowSpan="2" IsEnabled="{Binding CanUseCashier}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Combined Menu Tabs + Search Row -->
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="76"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Combined: Menu Tabs (Left) + Search (Right) -->
                    <Grid Grid.Row="0" Background="White" Margin="0,0,0,0" Height="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- LEFT: Menu Tabs (No Scroll, Dynamic Width) -->
                        <ItemsControl Grid.Column="0" ItemsSource="{Binding MenuTabs}" Margin="10,8,10,8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton Height="44" Margin="0,0,8,0" Padding="8,4"
                                                  FontSize="13" FontWeight="SemiBold"
                                                  HorizontalAlignment="Stretch"
                                                  Style="{StaticResource CashierMenuTabToggleStyle}"
                                                  Command="{Binding DataContext.SelectMenuTabCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                  CommandParameter="{Binding}"
                                                  IsChecked="{Binding IsSelected, Mode=OneWay}">
                                        <TextBlock Text="{Binding Name}" 
                                                   TextWrapping="Wrap" 
                                                   TextAlignment="Center" 
                                                   MaxHeight="36"
                                                   TextTrimming="CharacterEllipsis"
                                                   LineHeight="18"
                                                   LineStackingStrategy="BlockLineHeight"/>
                                    </ToggleButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- RIGHT: Search and filter -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                            <!-- Search Box -->
                            <materialDesign:PackIcon Kind="Search" Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <Grid Width="220" Height="38" Margin="0,0,10,0" VerticalAlignment="Center">
                                <TextBox x:Name="SearchTextBox" 
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                         materialDesign:TextFieldAssist.DecorationVisibility="Visible" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         materialDesign:HintAssist.Hint="Search items..."
                                         FontSize="14"
                                         materialDesign:HintAssist.Foreground="Gray"
                                         VerticalContentAlignment="Center"/>
                                <Button Click="ClearSearch_Click"
                                        Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                        Padding="0" Width="22" Height="22" Cursor="Hand"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="6,0,6,0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Foreground="Black"/>
                                </Button>
                            </Grid>
                            
                            <!-- Sort Hamburger Menu (only show in items view) -->
                            <Button x:Name="SortMenuButton" Width="40" Height="40" 
                                    Background="#1976D2" 
                                    Foreground="White"
                                    Style="{StaticResource NavTabPillButtonStyle}"
                                    Padding="0" Margin="0,0,0,0"
                                    VerticalAlignment="Center"
                                    Click="SortMenuButton_Click"
                                    Visibility="{Binding ShowItemsView, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <materialDesign:PackIcon Kind="FilterOutline" Width="24" Height="24" Foreground="White"/>
                            </Button>
                            
                            <!-- Sort Menu Popup -->
                            <Popup x:Name="SortPopup" 
                                   PlacementTarget="{Binding ElementName=SortMenuButton}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True">
                                <Border Background="White" 
                                        BorderBrush="#E0E0E0" 
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="5"
                                        Effect="{StaticResource MaterialDesignShadowDepth2}">
                                    <StackPanel Width="180">
                                        <ItemsControl ItemsSource="{Binding SortOptions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Click="SortItemButton_Click"
                                                            Height="45" Margin="2"
                                                            HorizontalContentAlignment="Left"
                                                            Padding="12,0"
                                                            Style="{StaticResource MaterialDesignFlatButton}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Converter={StaticResource SortOptionToStringConverter}}" 
                                                                       FontSize="13" FontWeight="Medium"/>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Category Grid View (Full Page) -->
                    <Grid Grid.Row="1" Grid.RowSpan="3" 
                          Visibility="{Binding ShowCategoryView, Converter={StaticResource BooleanToVisibilityConverter}}">
                        
                        <!-- Loading Indicator for Categories -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <controls:LoadingIndicator HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       ProgressRingSize="80"/>
                            <TextBlock Text="Loading categories, please wait..."
                                       Margin="0,20,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#666"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Categories ScrollViewer -->
                        <ScrollViewer x:Name="CategoriesScrollViewer"
                                      VerticalScrollBarVisibility="Hidden" 
                                      Margin="10,0,0,10"
                                      PanningMode="VerticalOnly"
                                      Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=False}">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                            </ScrollViewer.Resources>
                            <ItemsControl ItemsSource="{Binding CategoriesWithCount}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel  HorizontalAlignment="Left" Margin="15,0,0,0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="4" Width="198" Height="90"
                                            Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding CategoryName}"
                                            Background="{Binding BackgroundColor}"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Padding="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="10">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding CategoryName}" 
                                                                   FontWeight="SemiBold" 
                                                                   HorizontalAlignment="Center" 
                                                                   FontSize="16" 
                                                                   TextWrapping="Wrap"
                                                                   TextAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="5,2"
                                                                   Foreground="{Binding TextColor}"/>
                                                        <TextBlock Text="{Binding Quantity, Converter={StaticResource QuantityToTextConverter}}" 
                                                                   FontSize="15" 
                                                                   HorizontalAlignment="Center"
                                                                   FontWeight="Bold"
                                                                   Margin="5,2"
                                                                   Foreground="{Binding TextColor}"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                    
                    <!-- Items View -->
                    <ScrollViewer x:Name="ItemsScrollViewer"
                                  Grid.Row="1" Grid.RowSpan="3" 
                                  VerticalScrollBarVisibility="Hidden" 
                                  Margin="10,0,0,0"
                                  PanningMode="VerticalOnly"
                                  Visibility="{Binding ShowItemsView, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ScrollViewer.Resources>
                            <!-- Apply thicker scrollbar style defined in Stylesxaml.xaml -->
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                        </ScrollViewer.Resources>

                        <Grid>
                            <!-- Loading Indicator for Categories -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-100,0,0"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <controls:LoadingIndicator HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           ProgressRingSize="70"/>
                                <TextBlock Text="Loading items, please wait..."
                                           Margin="0,8,0,0"
                                           FontSize="14"
                                           Foreground="#666"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <!-- No Items Found Message -->
                            <TextBlock Text="No items found." 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       FontSize="16" 
                                       Foreground="#666">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Products.Count}" Value="0"/>
                                                    <Condition Binding="{Binding IsLoading}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            
                            <!-- Products List -->
                            <ItemsControl ItemsSource="{Binding Products}" 
                                          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=False}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Left" Margin="15,0,0,0"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.OpenAddItemDialogCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Padding="0"
                                                Margin="4"
                                                Background="{Binding BackgroundColor}"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                Width="198"
                                                Height="90"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="itemBorder"
                                                            Background="{TemplateBinding Background}" 
                                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                                            BorderThickness="{TemplateBinding BorderThickness}" 
                                                            CornerRadius="10">
                                                        <Grid VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Orientation="Vertical" Margin="0,0,0,0" HorizontalAlignment="Center">
                                                            <TextBlock Grid.Column="0" 
                                                                       Text="{Binding ItemName}" 
                                                                       FontWeight="SemiBold" 
                                                                       FontSize="16" 
                                                                       Foreground="{Binding TextColor}" 
                                                                       HorizontalAlignment="Center" 
                                                                       TextTrimming="CharacterEllipsis" 
                                                                       Margin="5,2" 
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" 
                                                                       Text="{Binding Price, Converter={StaticResource CurrencyFormatConverter}, ConverterParameter=DashOnZero}"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="5,2"
                                                                       FontWeight="Bold"
                                                                       FontSize="15"
                                                                       Foreground="{Binding TextColor}"
                                                                       VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="itemBorder" Property="Opacity" Value="0.85"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>

                    <!-- Mixed View (categories + items in same grid) -->
                    <ScrollViewer x:Name="MixedScrollViewer"
                                  Grid.Row="1" Grid.RowSpan="3"
                                  VerticalScrollBarVisibility="Hidden"
                                  Margin="10,0,0,0"
                                  PanningMode="VerticalOnly"
                                  Visibility="{Binding ShowMixedView, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                        </ScrollViewer.Resources>
                        <ItemsControl ItemsSource="{Binding MixedMenuItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Left" Margin="15,0,0,0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Padding="0" Margin="4"
                                            Background="{Binding BackgroundColor}"
                                            BorderBrush="Transparent" BorderThickness="0"
                                            Width="198" Height="90" Cursor="Hand"
                                            Command="{Binding DataContext.MixedItemClickCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="mixedBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="10">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold" FontSize="16"
                                                                   Foreground="{Binding TextColor}"
                                                                   HorizontalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                                   Margin="5,2"/>
                                                        <TextBlock Text="{Binding SecondLine}"
                                                                   FontWeight="Bold" FontSize="15"
                                                                   Foreground="{Binding TextColor}"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="5,2"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="mixedBorder" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Floating Drafts Button + Incoming Order Banner + Back Button -->

                    <Grid Grid.Row="4" VerticalAlignment="Center" Margin="10,10,10,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left side: Drafts + Incoming Orders -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Width="158" Height="48" Foreground="Black" FontWeight="Bold"
                                    Style="{StaticResource NavTabPillButtonStyle}"
                                    Background="#EEEEEE"
                                    Padding="10,0"
                                    Command="{Binding OpenDraftsCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="FileDocumentOutline" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Drafts" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding DraftCount, StringFormat='({0})'}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" Foreground="Black"/>
                            </StackPanel>
                        </Button>



                        <!-- Incoming orders refresh loading indicator -->
                        <Border Background="#E3F2FD" BorderBrush="#2196F3" BorderThickness="1" CornerRadius="8" Padding="8,4" Margin="10,4,0,0"
                                Visibility="{Binding IsRefreshingIncomingOrders, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <controls:LoadingIndicator ProgressRingSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Refreshing incoming orders..." FontSize="12" Foreground="#1976D2" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Incoming orders banner with "+N" indicator -->
                        <Border Background="Transparent" BorderThickness="1"
                                Visibility="{Binding IsIncomingOrderBannerVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <ItemsControl ItemsSource="{Binding IncomingOrdersBanner}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Background="#6FC08F" Foreground="White" Padding="6,0" Margin="10,0,6,0" BorderBrush="Transparent" Height="48" Width="158"
                                                    Command="{Binding DataContext.ViewIncomingOrderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>

                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <!-- Platform Logo -->
                                                    <Image Source="{Binding PlatformLogo, FallbackValue={x:Null}, TargetNullValue={x:Null}}" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0" Stretch="Uniform">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Source, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Source, RelativeSource={RelativeSource Self}}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                        <Image.ToolTip>
                                                            <TextBlock Text="{Binding PlatformName}"/>
                                                        </Image.ToolTip>
                                                    </Image>
                                                    <!-- Order ID Text -->
                                                    <TextBlock Text="{Binding DisplayOrderId, StringFormat=Order : {0}}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- "+N" indicator for remaining orders -->
                                <Border Background="#FF9800" CornerRadius="6" Height="48" Width="60" Margin="6,0,0,0"
                                        Visibility="{Binding ShowRemainingOrdersIndicator, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding RemainingOrdersCount, StringFormat=+{0}}" 
                                               FontWeight="Bold" 
                                               FontSize="16"
                                               Foreground="White" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                        
                        <!-- Right side: Back Button -->
                        <Button Grid.Column="1" 
                                Width="148" 
                                Height="48" 
                                Background="#1976D2" 
                                Foreground="White" 
                                FontWeight="Bold"
                                Style="{StaticResource NavTabPillButtonStyle}"
                                Padding="10,0"
                                HorizontalAlignment="Right"
                                Command="{Binding BackToCategoriesCommand}"
                                Visibility="{Binding CanGoBack, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Back" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                </Grid>
                <!-- Order Summary (was Grid.Column=2) -->
                <Border Grid.Column="1" Background="White" Padding="0,0,0,0" Grid.RowSpan="2" IsEnabled="{Binding CanUseCashier}">
                    <Grid Margin="0,0,8,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- Order Details and Items -->
                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Order Header -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <StackPanel Width="110">
                                    <StackPanel Orientation="Horizontal"  Margin="-3,0,0,0">
                                        <TextBlock Text="Order " FontWeight="Bold" FontSize="18"/>
                                        <TextBlock Text="{Binding DisplayOrderId}" FontWeight="Bold" FontSize="18" Margin="0,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <controls:LoadingIndicator HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center" 
                                                                   ProgressRingSize="17"
                                                                   Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding SelectedCustomer.Name}" Width="95" Margin="0,0,0,0" FontSize="12" TextWrapping="Wrap" TextTrimming="None"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Width="50" Height="36" Margin="0,0,10,0" ToolTip="Edit Name" Background="Transparent" Foreground="Black" BorderBrush="Transparent" Command="{Binding SelectCustomerCommand}">
                                    <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="6"
                                Margin="0"  Padding="1,2" Command="{Binding PrintCommand}" Width="68" Background="#FFF3E0" Foreground="Black" BorderBrush="Black">
                                    <materialDesign:PackIcon Kind="CashRegister" Width="18" Height="18"/>
                                </Button>

                                <!-- Now/Table Button Logic -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                    <Button x:Name="NowButton"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="6"
                                    Margin="4,0,0,0" Padding="0"
                                    Command="{Binding OpenTimePickerCommand}"
                                    Width="95"
                                    Visibility="{Binding OrderType, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Take Away|Delivery}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Clock" Width="18" Height="18" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding TimeButtonText}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="TableButton"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="6"
                                    Margin="4,0,0,0" Padding="0"
                                    Command="{Binding OpenTableSelectionCommand}"
                                    Width="95"
                                    Visibility="{Binding OrderType, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Dine In}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="TableFurniture" Width="18" Height="18" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding TimeButtonText}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                            <!-- Delivering To / Select Address (visible only for Delivery) -->
                            <Grid Grid.Row="1" Margin="14,0,14,12"
                                  Visibility="{Binding OrderType, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Delivery}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Delivering To" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0" TextWrapping="NoWrap"/>
                                <!-- Single clickable area showing location icon + current address or 'Select Address' -->
                                <!-- If customer has addresses, show dropdown by label; otherwise show Select Address button -->
                                <Grid Grid.Column="1">
                                    <Grid.Resources>
                                        <Style TargetType="ComboBox" x:Key="AddressComboStyle" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                                            <Setter Property="Height" Value="40"/>
                                            <Setter Property="Padding" Value="8"/>
                                            <Setter Property="materialDesign:HintAssist.Hint" Value="Select Address"/>
                                        </Style>
                                    </Grid.Resources>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Combo when addresses exist -->
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding CustomerAddresses}"
                                              SelectedItem="{Binding SelectedAddress, Mode=TwoWay}"
                                              DisplayMemberPath="Label"
                                              Style="{StaticResource AddressComboStyle}"
                                              IsDropDownOpen="{Binding IsAddressDropdownOpen, Mode=TwoWay}"
                                              PreviewMouseDown="AddressCombo_PreviewMouseDown"
                                              DropDownOpened="AddressCombo_DropDownOpened"
                                              SelectionChanged="AddressCombo_SelectionChanged"
                                              Visibility="{Binding HasCustomerAddresses, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <!-- Dropdown items show label + address -->
                                        <ComboBox.Resources>
                                            <DataTemplate x:Key="AddressDropdownTemplate">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="FontSize" Value="13"/>
                                                                <Setter Property="TextAlignment" Value="Left"/>
                                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Id}" Value="0">
                                                                        <Setter Property="FontSize" Value="15"/>
                                                                        <Setter Property="TextAlignment" Value="Center"/>
                                                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding PrimaryAddressDisplay}" FontSize="11" Foreground="#666" TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Id}" Value="0">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.Resources>
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="ContentTemplate" Value="{StaticResource AddressDropdownTemplate}"/>
                                                <Setter Property="Padding" Value="6,4"/>
                                                <Style.Triggers>
                                                    <!-- Make the 'Add new address' row larger -->
                                                    <DataTrigger Binding="{Binding Id}" Value="0">
                                                        <Setter Property="Padding" Value="10,12"/>
                                                        <Setter Property="MinHeight" Value="44"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                    </ComboBox>
                                    <!-- Distance value on the right (e.g., 4.5 km) -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DistanceText}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="#1976D2"
                                               Visibility="{Binding DistanceText, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    <!-- Fallback button when no addresses -->
                                    <Button Grid.Column="0" Height="40" Padding="10" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="1"
                                            Command="{Binding OpenSelectAddressDialogCommand}"
                                            Visibility="{Binding HasCustomerAddresses, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=False}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="MapMarker" Width="20" Height="20" Margin="0,0,8,0" Foreground="#1976D2"/>
                                            <TextBlock FontSize="13" Foreground="#666" Text="Select Address"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>

                            <!-- Order Type Buttons -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,12" HorizontalAlignment="Center">
                                <Button Content="TAKEAWAY" Width="110" Height="32" Margin="0,0,8,0" VerticalContentAlignment="Center" VerticalAlignment="Center" Padding="0,0,0,4"
                                FontSize="14" FontWeight="SemiBold"
                                Style="{StaticResource NavTabPillButtonStyle}"
                                Command="{Binding ChangeOrderTypeCommand}" CommandParameter="Take Away"
                                Background="{Binding OrderType, Converter={StaticResource StringToColorConverter}, ConverterParameter=Take Away}"
                                Foreground="{Binding OrderType, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=Take Away}"
                                IsEnabled="{Binding IsOrderLoadedForEdit, Converter={StaticResource InvertBooleanConverter}}"
                                IsHitTestVisible="{Binding IsOrderLoadedForEdit, Converter={StaticResource InvertBooleanConverter}}"
                                Focusable="False"/>
                                <Button Content="DINE IN" Width="110" Height="32" Margin="0,0,8,0" VerticalContentAlignment="Center" VerticalAlignment="Center" Padding="0,0,0,4"
                                FontSize="14" FontWeight="SemiBold"
                                Style="{StaticResource NavTabPillButtonStyle}"
                                Command="{Binding ChangeOrderTypeCommand}" CommandParameter="Dine In"
                                Background="{Binding OrderType, Converter={StaticResource StringToColorConverter}, ConverterParameter=Dine In}"
                                Foreground="{Binding OrderType, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=Dine In}"/>
                                <Button Content="DELIVERY" Width="110" Height="32" VerticalContentAlignment="Center" VerticalAlignment="Center" Padding="0,0,0,4"
                                FontSize="14" FontWeight="SemiBold"
                                Style="{StaticResource NavTabPillButtonStyle}"
                                Command="{Binding ChangeOrderTypeCommand}" CommandParameter="Delivery"
                                Background="{Binding OrderType, Converter={StaticResource StringToColorConverter}, ConverterParameter=Delivery}"
                                Foreground="{Binding OrderType, Converter={StaticResource StringToForegroundConverter}, ConverterParameter=Delivery}"
                                IsEnabled="{Binding IsOrderLoadedForEdit, Converter={StaticResource InvertBooleanConverter}}"
                                IsHitTestVisible="{Binding IsOrderLoadedForEdit, Converter={StaticResource InvertBooleanConverter}}"
                                Focusable="False"/>
                            </StackPanel>


                            <!-- Order Items List (scrollable) -->
                            <Grid Grid.Row="3">
                                <ScrollViewer x:Name="CartScrollViewer" VerticalScrollBarVisibility="Hidden" ScrollChanged="CartScrollViewer_ScrollChanged">
                                    <ItemsControl ItemsSource="{Binding OrderItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <view:SwipeToDeleteOrderItem 
                                                    RemoveCommand="{Binding DataContext.RemoveFromOrderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    EditCommand="{Binding DataContext.EditOrderItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <!-- Bottom fade overlay, visible when more items to scroll -->
                                <Border x:Name="CartFadeOverlay" 
                                        VerticalAlignment="Bottom" 
                                        Height="40" 
                                        IsHitTestVisible="False"
                                        Opacity="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                                            <GradientStop Color="#FFFFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <!-- Cart loading overlay -->
                                <Border Background="#CCFFFFFF"
                                        Visibility="{Binding IsFinishOrderLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <controls:LoadingIndicator ProgressRingSize="40"/>
                                        <TextBlock Text="Loading order..." 
                                                   FontSize="13" Foreground="#666"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>


                        <!-- Action Buttons -->
                        <StackPanel Grid.Row="1">
                            <StackPanel Margin="0,15,0,0" VerticalAlignment="Bottom" >
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,8" HorizontalAlignment="Center">
                                    <Button Width="96" 
                                        Height="40" 
                                        Margin="0,0,8,0" 
                                        Background="#F0F0F0" 
                                        Foreground="Black" 
                                        Padding="8,0"
                                        Style="{StaticResource NavTabPillButtonStyle}"
                                        Command="{Binding AddNoteCommand}" 
                                        IsEnabled="{Binding CanAddNote}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <materialDesign:PackIcon Kind="NoteOutline" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="Black"/>
                                            <TextBlock Text="Note" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="Black"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Width="108" 
                                        Height="40" 
                                        Margin="0,0,8,0" 
                                        Background="#F0F0F0" 
                                        Foreground="Black" 
                                        Padding="8,0"
                                        Style="{StaticResource NavTabPillButtonStyle}"
                                        Command="{Binding OpenCouponDialogCommand}"
                                        IsEnabled="{Binding CanAddCoupon}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <materialDesign:PackIcon Kind="TicketPercentOutline" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="Black"/>
                                            <TextBlock Text="Coupon" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="Black"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Width="118" 
                                        Height="40" 
                                        Background="#F0F0F0" 
                                        Foreground="Black" 
                                        Padding="8,0"
                                        Style="{StaticResource NavTabPillButtonStyle}"
                                        Command="{Binding OpenDiscountDialogCommand}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <materialDesign:PackIcon Kind="PercentOutline" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="Black"/>
                                            <TextBlock Text="Discount" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="Black"/>
                                        </StackPanel>
                                    </Button>

                                </StackPanel>

                                <!-- Note Display -->
                                <Border Background="#F5F5F5" 
                                     CornerRadius="4" 
                                     Margin="14,0,14,8" 
                                     Padding="12"
                                     Visibility="{Binding HasNote, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Note}" 
                                             TextWrapping="Wrap" 
                                             Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" Margin="0,-8,0,-8">
                                            <Button Command="{Binding EditNoteCommand}"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Padding="0" Width="20" Height="20"
                                                ToolTip="Edit Note">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="0">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <materialDesign:PackIcon Kind="Pencil" Width="12" Height="12"/>
                                            </Button>
                                            <Button Command="{Binding RemoveNoteCommand}"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Padding="0" Width="20" Height="20" Margin="0,0,0,0"
                                                ToolTip="Remove Note">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="0">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Foreground="Red"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Summary Section -->
                                <Border Background="#FAFAFA" CornerRadius="8" Padding="5" Margin="0,0,2,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="Sub Total" FontWeight="Bold" Width="230"/>
                                            <TextBlock Text="{Binding Total, Converter={StaticResource CurrencyFormatConverter}}" Width="100" TextAlignment="Right" FontWeight="Bold"/>
                                        </StackPanel>
                                        <!-- Voucher Discount Row -->
                                       <!-- <Grid Visibility="{Binding HasVoucherDiscount, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Right" Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="230"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Coupon" Foreground="#1976D2" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding VoucherDiscount, Converter={StaticResource CurrencyFormatConverter}}" Foreground="#1976D2" Width="100" TextAlignment="Right" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Grid>-->
                                        <Grid HorizontalAlignment="Right" Margin="0,0,0,0" Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="230"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Label + Remove Button in first column -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DiscountDescription}"
                                                       Foreground="Red"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,0,0"/>

                                                <!-- Show percent when DiscountPercent > 0 -->
                                                <TextBlock Text="{Binding DiscountPercent, StringFormat={}({0}%)}"
                                                   Foreground="Red"
                                                  FontWeight="Bold"
                                                VerticalAlignment="Center"
                                                 Margin="4,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DiscountPercent}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Show amount in brackets when using fixed amount (i.e., DiscountPercent == 0 and HasDiscount) -->
                                                <TextBlock Text="(value)"
                                                    Foreground="Red"
                                                   FontWeight="Bold"
                                                 VerticalAlignment="Center"
                                                 Margin="4,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DiscountPercent}" Value="0">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Button Command="{Binding RemoveDiscountCommand}"
                                                     Width="20"
                                                     Height="20"
                                                     Margin="0,0,0,0"
                                                     Background="Transparent"
                                                     BorderBrush="Transparent"
                                                     ToolTip="Remove Discount"
                                                     Style="{x:Null}"
                                                     VerticalAlignment="Center">
                                                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Foreground="Red"/>
                                                </Button>
                                            </StackPanel>
                                            <!-- Value in second column -->
                                            <TextBlock Grid.Column="1"
                                                   Text="{Binding Discount, Converter={StaticResource CurrencyFormatConverter}}"
                                                   Foreground="Red"
                                                   Width="100"
                                                   TextAlignment="Right"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        </Grid>
                                        <!-- Coupon Row -->
                                        <Grid Visibility="{Binding HasCoupon, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Right" Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="230"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Label + Remove Button in first column -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CouponDescriptionWithAmount}"
                                                       Foreground="#1976D2"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,0,0"/>
                                                <Button Command="{Binding RemoveCouponCommand}"
                                                    Width="24"
                                                    Height="24"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    ToolTip="Remove Coupon"
                                                    Style="{x:Null}"
                                                    VerticalAlignment="Center">
                                                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Foreground="Red"/>
                                                </Button>
                                            </StackPanel>
                                            <!-- Value in second column -->
                                            <TextBlock Grid.Column="1"
                                                   Text="{Binding CouponDiscount, Converter={StaticResource CurrencyFormatConverter}}"
                                                   Foreground="#1976D2"
                                                   Width="100"
                                                   TextAlignment="Right"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        </Grid>
                                        <!-- Delivery Charge Row -->
                                        <Grid  Visibility="{Binding OrderType, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Delivery}" HorizontalAlignment="Right" Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="230"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Content="Delivery Charge" Margin="0,5,0,5"
                                                Width="150"
                                                 Height="30" 
                                                 Background="#1976D2" 
                                                 Foreground="White"
                                                 Style="{StaticResource NavTabPillButtonStyle}"
                                                 FontWeight="SemiBold"
                                                 FontSize="13"
                                                 Command="{Binding OpenDeliveryChargeDialogCommand}" 
                                                HorizontalAlignment="Left"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                 Visibility="{Binding OrderType, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Delivery}" />
                                            <TextBlock Grid.Column="1" Text="{Binding DeliveryCharge, Converter={StaticResource CurrencyFormatConverter}}" Foreground="#1976D2" Width="100" TextAlignment="Right" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Grid>
                                        <!-- Shop Fees Rows -->
                                        <ItemsControl ItemsSource="{Binding ShopFeeRows}" Visibility="{Binding HasShopFees, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid HorizontalAlignment="Right" Margin="0,2,0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="230"/>
                                                            <ColumnDefinition Width="100"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- When removed, entire row runs AddCommand (same as + ADD); text is non-hit-test so clicks reach this border -->
                                                        <Border Grid.ColumnSpan="2"
                                                                Background="Transparent"
                                                                Cursor="Hand"
                                                                Panel.ZIndex="0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRemoved}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                              Command="{Binding AddCommand}"
                                                                              CommandParameter="{Binding}"/>
                                                            </Border.InputBindings>
                                                        </Border>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Panel.ZIndex="1">
                                                            <TextBlock Text="{Binding Label}" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="150">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="Black"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsRemoved}" Value="True">
                                                                                <Setter Property="Foreground" Value="#FFBCBBBB"/>
                                                                                <Setter Property="IsHitTestVisible" Value="False"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <Button Margin="4,0,0,0"
                                                                    Padding="2,3"
                                                                    VerticalAlignment="Center"
                                                                    Visibility="{Binding ShowAddButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                    Command="{Binding AddCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip="Add fee back"
                                                                    Foreground="#1976D2"
                                                                    FontWeight="Bold"
                                                                    Background="Transparent"
                                                                    BorderBrush="#1976D2"
                                                                    BorderThickness="1"
                                                                    FontSize="15"
                                                                    Cursor="Hand">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="Button">
                                                                                   <Border Background="{TemplateBinding Background}"
                                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                                            BorderThickness="0"
                                                                                            CornerRadius="8"
                                                                                            Padding="{TemplateBinding Padding}">
                                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                    </Border>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </Button.Style>
                                                                <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Foreground="#1976D2"/>
                                                            </Button>
                                                            <Button Width="25"
                                                                    Height="25"
                                                                    Padding="2"
                                                                    Margin="4,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    Visibility="{Binding ShowRemoveCross, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                    Command="{Binding RemoveCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip="Remove fee"
                                                                    Cursor="Hand"
                                                                    Background="Transparent"
                                                                    BorderBrush="Transparent"
                                                                    Style="{StaticResource MaterialDesignToolButton}">
                                                                <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Foreground="Red"/>
                                                            </Button>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Panel.ZIndex="1" Text="{Binding Amount, Converter={StaticResource CurrencyFormatConverter}}" Width="100" TextAlignment="Right" FontWeight="Bold" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="Black"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRemoved}" Value="True">
                                                                            <Setter Property="Foreground" Value="#FFBCBBBB"/>
                                                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Grid Margin="0,8,0,0" Visibility="{Binding HasTaxSummary, Converter={StaticResource BooleanToVisibilityConverter}}" Width="331" HorizontalAlignment="Right">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="111"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <ItemsControl Grid.Row="0" Grid.ColumnSpan="3" ItemsSource="{Binding TaxSummaryRows}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="111"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding TaxCode}" FontWeight="Bold"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding TaxableAmount, Converter={StaticResource CurrencyFormatConverter}}" HorizontalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding TaxAmount, Converter={StaticResource CurrencyFormatConverter}}" HorizontalAlignment="Right" FontWeight="Bold"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Tax" FontWeight="Bold"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" FontWeight="Bold" Text=""/>
                                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding TotalTax, Converter={StaticResource CurrencyFormatConverter}}" HorizontalAlignment="Right" FontWeight="Bold"/>
                                        </Grid>
                                        <Separator Margin="0,1"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Width="331">
                                            <TextBlock Text="Total" FontWeight="Bold" Width="229" FontSize="18"/>
                                            <TextBlock Text="{Binding SubTotal, Converter={StaticResource CurrencyFormatConverter}}" Width="103" TextAlignment="Right" FontWeight="Bold" FontSize="18"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Save and Place Order Buttons at Bottom -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"  Margin="5" Width="350" Visibility="{Binding ShowSavePlaceOrderButtons, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button Width="77" Height="52" Background="#FFF3E0" Foreground="Black" Margin="10,0,0,0" BorderBrush="Black" BorderThickness="2" Command="{Binding PrintCartCommand}" Cursor="Hand" ToolTip="Print cart receipt">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="Black" BorderThickness="1"> 
                                                            <Border.Effect>
                                                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0" Color="Black"/>
                                                            </Border.Effect>
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <materialDesign:PackIcon Kind="Printer" Width="24" Height="24"/>
                                </Button>
                                <Button Width="90" Height="52" Background="Black" Foreground="White" Margin="15,0,15,0" FontWeight="Bold" FontSize="16" BorderBrush="Transparent" Command="{Binding SaveOrderCommand}" Cursor="Hand" IsEnabled="{Binding IsCartActionNotProcessing}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Opacity="{TemplateBinding Opacity}">
                                                            <Border.Effect>
                                                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="Black"/>
                                                            </Border.Effect>
                                                            <Grid>
                                                                <TextBlock Text="Save" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="16" Foreground="White"
                                                                           Visibility="{Binding DataContext.IsSavingOrder, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"/>
                                                                <ProgressBar IsIndeterminate="True" Width="24" Height="24" Style="{StaticResource MaterialDesignCircularProgressBar}" Foreground="White"
                                                                             Visibility="{Binding DataContext.IsSavingOrder, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                            </Grid>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                    <Setter Property="Cursor" Value="No"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Place Order" Width="138" Height="52" Background="#1976D2" Foreground="White" Margin="0,0,10,0" FontWeight="Bold" FontSize="16" Command="{Binding PlaceOrderCommand}" Cursor="Hand" IsEnabled="{Binding IsCartActionNotProcessing}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Opacity="{TemplateBinding Opacity}">
                                                            <Border.Effect>
                                                                <DropShadowEffect ShadowDepth="3" BlurRadius="10" Opacity="0.4" Color="#1976D2"/>
                                                            </Border.Effect>
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                    <Setter Property="Background" Value="#999999"/>
                                                    <Setter Property="Cursor" Value="No"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- Update Order Button at Bottom -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"  Margin="5" Width="350" Visibility="{Binding ShowUpdateOrderButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button Content="Cancel" HorizontalAlignment="Center" Width="115" Height="52" Background="Black" Foreground="White" Margin="20,0,20,0" FontWeight="Bold" FontSize="16" BorderBrush="Transparent" Command="{Binding CancelOrderCommand}" Cursor="Hand" IsEnabled="{Binding IsCartActionNotProcessing}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Opacity="{TemplateBinding Opacity}">
                                                            <Border.Effect>
                                                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="Black"/>
                                                            </Border.Effect>
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                    <Setter Property="Cursor" Value="No"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button HorizontalAlignment="Center" Width="175" Height="52" Background="#1976D2" Foreground="White" FontWeight="Bold" FontSize="16" BorderBrush="Transparent" Command="{Binding UpdateOrderCommand}" Cursor="Hand" IsEnabled="{Binding IsCartActionNotProcessing}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Opacity="{TemplateBinding Opacity}">
                                                            <Border.Effect>
                                                                <DropShadowEffect ShadowDepth="3" BlurRadius="10" Opacity="0.4" Color="#1976D2"/>
                                                            </Border.Effect>
                                                            <Grid>
                                                                <TextBlock Text="Update Order" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="16" Foreground="White"
                                                                           Visibility="{Binding DataContext.IsUpdatingOrder, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"/>
                                                                <ProgressBar IsIndeterminate="True" Width="24" Height="24" Style="{StaticResource MaterialDesignCircularProgressBar}" Foreground="White"
                                                                             Visibility="{Binding DataContext.IsUpdatingOrder, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                            </Grid>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                    <Setter Property="Cursor" Value="No"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- Finish Flow Buttons at Bottom (Finish & Cancel) -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"  Margin="5" Width="350" Visibility="{Binding ShowFinishButtons, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button Content="Cancel" HorizontalAlignment="Center" Width="115" Height="52" Background="Black" Foreground="White" Margin="20,0,20,0" FontWeight="Bold" FontSize="16" BorderBrush="Transparent" Command="{Binding CancelOrderCommand}" Cursor="Hand" IsEnabled="{Binding IsCartActionNotProcessing}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Opacity="{TemplateBinding Opacity}">
                                                            <Border.Effect>
                                                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="Black"/>
                                                            </Border.Effect>
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                    <Setter Property="Cursor" Value="No"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Finish Order" HorizontalAlignment="Center" Width="175" Height="52" Background="#1976D2" Foreground="White" FontWeight="Bold" FontSize="16" BorderBrush="Transparent" Command="{Binding FinishOrderCommand}" Cursor="Hand" IsEnabled="{Binding IsCartActionNotProcessing}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Opacity="{TemplateBinding Opacity}">
                                                            <Border.Effect>
                                                                <DropShadowEffect ShadowDepth="3" BlurRadius="10" Opacity="0.4" Color="#1976D2"/>
                                                            </Border.Effect>
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                    <Setter Property="Cursor" Value="No"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- Center-top New Order Alert within main content area -->
                    <view:NewOrderAlertPopup Grid.Column="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Top"
                                          Margin="0,10,0,0"
                                          Visibility="{Binding IsOrderAlertVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Grid.RowSpan="2"/>

                <!-- Shift inactive: must be inside DialogHost content so Opening Balance (DialogHost.Show) renders above this layer -->
                <Grid Grid.ColumnSpan="2" Grid.RowSpan="2"
                      Panel.ZIndex="50"
                      Background="#80000000"
                      Visibility="{Binding IsShiftInactive, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Background="White"
                            CornerRadius="10"
                            Padding="40"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="400">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="ClockAlert"
                                                     Width="64"
                                                     Height="64"
                                                     Foreground="#FF6B6B6B"
                                                     HorizontalAlignment="Center"
                                                     Margin="0,0,0,20"/>
                            <TextBlock Text="Shift Not Started"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"
                                       Foreground="#333333"/>
                            <TextBlock Text="Please start a shift to begin using the system."
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       Margin="0,0,0,30"
                                       Foreground="#666666"/>
                            <Button Content="Start Shift"
                                    Command="{Binding StartShiftCommand}"
                                    Style="{StaticResource NavTabPillButtonStyle}"
                                    Background="#1976D2"
                                    Foreground="White"
                                    Padding="20,10"
                                    Height="45" Width="150"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>
        </materialDesign:DialogHost>

        <!-- Separate DialogHost for nested modifiers -->
        <materialDesign:DialogHost x:Name="NestedModifiersDialogHost" Grid.Column="1" Grid.ColumnSpan="2" Identifier="NestedModifiersDialogHost" Grid.RowSpan="2" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
        </materialDesign:DialogHost>
    </Grid>
</Page> 