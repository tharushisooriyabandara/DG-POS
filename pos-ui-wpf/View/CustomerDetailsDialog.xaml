<UserControl x:Class="POS_UI.View.CustomerDetailsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:POS_UI.Converters"
             xmlns:controls="clr-namespace:POS_UI.View.Controls"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="720">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InvertBooleanToVisibilityConverter x:Key="InvertBoolToVis"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:CountryBasedDateTimeConverter2 x:Key="CountryBasedDateTimeConverter2"/>
    </UserControl.Resources>
    <Border Background="White" CornerRadius="8" Padding="12,10,12,12" MinWidth="720" MinHeight="640">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Customer Details" FontWeight="Bold" FontSize="25" Grid.Column="0"/>
                <Button Grid.Column="1" DockPanel.Dock="Right" Width="32" Height="32" Background="Transparent" BorderBrush="Transparent" Style="{StaticResource MaterialDesignToolButton}"
                        Command="{Binding CloseCommand}">
                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                </Button>
                </Grid>
            </DockPanel>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="0,12,0,0">
                <!-- Loading Indicator -->
                <controls:LoadingIndicator HorizontalAlignment="Center" 
                                          VerticalAlignment="Center" 
                                          ProgressRingSize="70"
                                          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                
                <!-- Content (hidden when loading) -->
                <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                <!-- Basic info -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="0">
                        <TextBlock Text="Full Name :" FontWeight="SemiBold"  FontSize="15"/>
                        <TextBlock Text="{Binding FullName}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="0">
                            <TextBlock Text="Customer ID :" FontWeight="SemiBold"  FontSize="15"/>
                            <TextBlock Text="{Binding CustomerId}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="1" Margin="0,5,0,0">
                            <TextBlock Text="Phone :" FontWeight="SemiBold"  FontSize="15"/>
                        <TextBlock>
                            <Run Text="{Binding CountryCode}" FontSize="14"/>
                            <Run Text=" "/>
                            <Run Text="{Binding Phone}" FontSize="14"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- Addresses -->
                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock Text="Addresses" FontWeight="Bold" Margin="0,0,0,6"  FontSize="16"/>
                    <!-- Header row for addresses -->
                    <Grid Background="#FFEAEAEA" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ID" FontWeight="Bold" Foreground="#333" Padding="5" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="Address Line" FontWeight="Bold" Foreground="#333" Padding="5" FontSize="14"/>
                       <!--<TextBlock Grid.Column="2" Text="Address Line 2" FontWeight="Bold" Foreground="#333" Padding="5"/>
                        <TextBlock Grid.Column="3" Text="FlatNo" FontWeight="Bold" Foreground="#333" Padding="5"/>-->
                            <TextBlock Grid.Column="2" Text="House No" FontWeight="Bold" Foreground="#333" Padding="5" FontSize="14"/>
                            <TextBlock Grid.Column="3" Text="City" FontWeight="Bold" Foreground="#333" Padding="5" FontSize="14"/>
                            <TextBlock Grid.Column="4" Text="PostalCode" FontWeight="Bold" Foreground="#333" Padding="5" FontSize="14"/>
                    </Grid>
                    <!-- Address rows or empty state -->
                    <Grid Height="160">
                        <ScrollViewer VerticalScrollBarVisibility="Visible"
                                      Visibility="{Binding ElementName=AddressItems, Path=HasItems, Converter={StaticResource BoolToVis}}">
                            <ScrollViewer.Resources>
                                <!-- Apply thicker scrollbar style defined in Stylesxaml.xaml -->
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                            </ScrollViewer.Resources>
                            <ItemsControl x:Name="AddressItems" ItemsSource="{Binding Addresses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="45"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Id}" Foreground="#222" FontSize="13"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AddressLine1}" Foreground="#222" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                                <!--<TextBlock Grid.Column="2" Text="{Binding AddressLine2}" Foreground="#222" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="3" Text="{Binding FlatNo}" Foreground="#222"/>-->
                                                <TextBlock Grid.Column="2" Text="{Binding ApartmentDisplay}" Foreground="#222" FontSize="13"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding City}" Foreground="#222"  FontSize="13"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding PostalCode}" Foreground="#222"  FontSize="13"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock Text="No addresses" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#666" FontStyle="Italic"
                                   Visibility="{Binding ElementName=AddressItems, Path=HasItems, Converter={StaticResource InvertBoolToVis}}"/>
                    </Grid>
                </StackPanel>

                <!-- Orders -->
                <StackPanel Grid.Row="2">
                        <TextBlock Text="Orders" FontWeight="Bold" Margin="0,0,0,8"  FontSize="16"/>
                    <!-- Header row -->
                        <Grid Background="#FFEAEAEA" Margin="0,0,0,4" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Display Order ID" FontWeight="Bold" Foreground="#333" Padding="5" FontSize="14" TextAlignment="Left"/>
                            <TextBlock Grid.Column="1" Text="Delivery Date/Time" FontWeight="Bold" Foreground="#333" Margin="-10,0,0,0" Padding="5" FontSize="14" TextAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="Shipping Method" FontWeight="Bold" Foreground="#333" FontSize="14" Padding="5"/>
                            <TextBlock Grid.Column="3" Text="Actions" FontWeight="Bold" Foreground="#333" FontSize="14" Padding="5" Margin="20,0,0,0"/>
                    </Grid>
                    <!-- Rows or empty state -->
                    <Grid Height="230">
                        <ScrollViewer VerticalScrollBarVisibility="Visible"
                                      Visibility="{Binding ElementName=OrderItems, Path=HasItems, Converter={StaticResource BoolToVis}}">
                            <ScrollViewer.Resources>
                                <!-- Apply thicker scrollbar style defined in Stylesxaml.xaml -->
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThickScrollbar}"/>
                            </ScrollViewer.Resources>
                            <ItemsControl x:Name="OrderItems" ItemsSource="{Binding Orders}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="190"/>
                                                    <ColumnDefinition Width="220"/>
                                                    <ColumnDefinition Width="160"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding DisplayOrderId}" Foreground="#222" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding DeliveryDateTime, Converter={StaticResource CountryBasedDateTimeConverter2}}" Foreground="#222" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding ShippingMethod}" Foreground="#222" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="3" Content="View" Padding="8,4" Background="#1976D2" Foreground="White" BorderBrush="Transparent" VerticalAlignment="Center"
                                                        Command="{Binding DataContext.ViewOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock Text="No orders" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#666" FontStyle="Italic"
                                   Visibility="{Binding ElementName=OrderItems, Path=HasItems, Converter={StaticResource InvertBoolToVis}}"/>
                    </Grid>
                </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>


