<UserControl x:Class="POS_UI.View.SwipeToDeleteOrderItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:POS_UI.View"
    xmlns:converters="clr-namespace:POS_UI.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Height="Auto" Width="Auto" MinHeight="60">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:CollectionToVisibilityConverter x:Key="CollectionToVisibilityConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:ItemEditableToOpacityConverter x:Key="ItemEditableToOpacityConverter"/>
        <converters:ItemEditableToHitTestVisibleConverter x:Key="ItemEditableToHitTestVisibleConverter"/>
    </UserControl.Resources>
    <Grid x:Name="RootGrid" Background="Transparent" ClipToBounds="True">
        <!-- Red background for delete feedback, hidden by default -->
        <Border x:Name="DeleteFeedback" Background="#FFEE0A0A" CornerRadius="6"  Visibility="Collapsed">
            <TextBlock Text="Delete" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Border>
        <!-- Main Content (Order Item) -->
        <Border x:Name="ContentBorder"
                Background="White"
                CornerRadius="6"
                Margin="0"
                RenderTransformOrigin="0.5,0.5"
                >
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="IsHitTestVisible" Value="True"/>
                    <Setter Property="IsEnabled" Value="True"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                            <Setter Property="Opacity" Value="0.4"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.RenderTransform>
                <TranslateTransform x:Name="ContentTransform"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MinHeight="40"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Left: Name, Size, Note -->
                <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Vertical" Margin="8,8,0,0">
                    <TextBlock Text="{Binding DisplayName}" 
                               FontWeight="Bold" 
                               FontSize="15"
                               TextWrapping="Wrap"
                               TextTrimming="None"/>
                    <!--<TextBlock Text="Discount" FontSize="12" Foreground="#888" Margin="0,2,0,0"/>-->
                    <!--<TextBlock Text="None" FontSize="12" Foreground="#888" Margin="0,2,0,0"
                               Visibility="Collapsed"/>-->
                </StackPanel>
                <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Vertical" Margin="8,0,0,3">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="Margin" Value="8,0,0,3"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding VisibleDiscountAmount}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Margin" Value="8,0,0,0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Discount" FontSize="12" Foreground="#E53935" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel  Grid.Column="2" Grid.Row="1" Orientation="Vertical" Margin="8,0,12,3">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="Margin" Value="8,0,12,3"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding VisibleDiscountAmount}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Margin" Value="8,0,12,0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{Binding VisibleDiscountAmount, Converter={StaticResource CurrencyFormatConverter}}" FontSize="12" Foreground="#E53935" Margin="0,2,0,0" TextAlignment="Right"/>
                </StackPanel>

                <!-- Center: Quantity Controls -->
                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0,2,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                    <Button Grid.Column="0" Width="45" Height="35" Margin="0,0,6,0" Foreground="Black" 
                            Background="#F7F7F7" BorderBrush="#F7F7F7" BorderThickness="1"
                            Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                            CommandParameter="{Binding}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="1"/>
                                <Setter Property="IsHitTestVisible" Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                        <Setter Property="Opacity" Value="0.4"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <materialDesign:PackIcon Kind="Minus" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <TextBlock Text="{Binding Quantity}"  Grid.Column="1" TextAlignment="Center" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Padding="1,0,1,0"/>
                    <Button  Grid.Column="2" Width="45" Height="35" Margin="6,0,0,0" Foreground="Black" 
                            Background="#F7F7F7" BorderBrush="#F7F7F7" BorderThickness="1"
                            Command="{Binding DataContext.AddToOrderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                            CommandParameter="{Binding}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="1"/>
                                <Setter Property="IsHitTestVisible" Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                        <Setter Property="Opacity" Value="0.4"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
                
                <!-- Right: Price (line total) -->
                <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Vertical" Width="85" HorizontalAlignment="Right" Margin="0,8,4,8">
                    <TextBlock Text="{Binding Total, Converter={StaticResource CurrencyFormatConverter}}" FontWeight="Bold" FontSize="15" TextAlignment="Right"/>
                    <!--<TextBlock Text="{Binding DiscountAmount, Converter={StaticResource CurrencyFormatConverter}}" FontSize="12" Foreground="#888" Margin="0,2,0,0" TextAlignment="Right"
                        />-->
                </StackPanel>

                <!-- Modifier Details (Full Width, Second Row) -->
                <ItemsControl Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" 
                              ItemsSource="{Binding ModifierDetailsForDisplay}" 
                              Margin="8,0,12,5"
                              Visibility="{Binding ModifierDetailsForDisplay, Converter={StaticResource CollectionToVisibilityConverter}}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Margin" Value="8,0,12,5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DiscountAmount}" Value="0">
                                    <Setter Property="Margin" Value="8,0,12,0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" 
                                           Text="{Binding Indentation}" 
                                           Foreground="Transparent"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding ModifierName}" 
                                           Foreground="#666" 
                                           FontWeight="Normal" 
                                           FontSize="11"
                                           TextAlignment="Left"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextTrimming="None"/>
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding Price, Converter={StaticResource CurrencyFormatConverter}}" 
                                           Foreground="#666" 
                                           FontWeight="Normal" 
                                           FontSize="11"
                                           TextAlignment="Right"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding Note, StringFormat=Note: {0}}" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                           FontSize="12" 
                           Foreground="#888" 
                           Margin="8,2,8,0"
                           TextWrapping="Wrap"
                           TextTrimming="None"
                           Visibility="{Binding Note, Converter={StaticResource StringToVisibilityConverter}}"/>    
            </Grid>
        </Border>
    </Grid>
</UserControl> 