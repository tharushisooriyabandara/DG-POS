<Page x:Class="POS_UI.TablesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:POS_UI"
      xmlns:converters="clr-namespace:POS_UI.Converters"
      xmlns:controls="clr-namespace:POS_UI.View.Controls"
      xmlns:vm="clr-namespace:POS_UI.ViewModels"
      xmlns:models="clr-namespace:POS_UI.Models"
      Title="Tables">
    <Page.Resources>
        <converters:StringToColorConverter x:Key="StringToColorConverter"/>
        <converters:StringToForegroundConverter x:Key="StringToForegroundConverter"/>
        <converters:TableStatusVisibilityConverter x:Key="TableStatusVisibilityConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:TrimConverter x:Key="TrimConverter"/>
        <converters:SeatCountConverter x:Key="SeatCountConverter"/>
        <converters:CurrencyFormatConverter x:Key="CurrencyFormatConverter"/>
        <converters:ColorHexStringToBrushConverter x:Key="ColorHexStringToBrushConverter"/>
        <converters:PackIconKindConverter x:Key="PackIconKindConverter"/>
        <converters:CountryBasedDateTimeConverter x:Key="CountryBasedDateTimeConverter"/>
        <converters:OrderTypeToBadgeBrushConverter x:Key="OrderTypeToBadgeBrushConverter"/>

        <DataTemplate x:Key="TablesSidebarOrderRowTemplate" DataType="{x:Type vm:TablesSidebarOrderRow}">
            <!-- No DropShadowEffect: Effect bitmap-caches content and makes text look soft in a narrow ScrollViewer (session list looked blurred vs. crisp border). -->
            <Border Margin="2,0,10,10" Background="White" CornerRadius="8" Padding="12,10"
                    BorderBrush="#E0E0E0" BorderThickness="1"
                    SnapsToDevicePixels="True" UseLayoutRounding="True">
                <Grid HorizontalAlignment="Stretch"
                      TextOptions.TextFormattingMode="Display"
                      TextOptions.TextRenderingMode="ClearType">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Margin="0,0,12,0" VerticalAlignment="Top" Background="#E3F2FD"
                            SnapsToDevicePixels="True">
                        <Image Source="{Binding PlatformLogo}" Width="38" Height="38"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="Fant"/>
                    </Border>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Stretch">
                        <TextBlock FontWeight="Bold" FontSize="17" Foreground="#111827" Text="{Binding DisplayOrderId}" TextAlignment="Left"/>
                        <TextBlock FontSize="13" Foreground="#757575" Margin="0,3,0,0" TextAlignment="Left" TextWrapping="Wrap"
                                   Text="{Binding LineDateTime, Converter={StaticResource CountryBasedDateTimeConverter}}"/>
                        <TextBlock FontSize="13" Foreground="#374151" Margin="0,4,0,0" TextAlignment="Left" TextWrapping="Wrap"
                                   Visibility="{Binding ShowCustomerName, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Text="{Binding CustomerName, StringFormat=Customer: {0}}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
                            <TextBlock FontWeight="Bold" FontSize="16" TextAlignment="Left" VerticalAlignment="Center"
                                       Text="{Binding Amount, Converter={StaticResource CurrencyFormatConverter}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#374151"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PaymentStatusDisplay}" Value="PAID">
                                                <Setter Property="Foreground" Value="Black"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PaymentStatusDisplay}" Value="UNPAID">
                                                <Setter Property="Foreground" Value="#C62828"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>             
                            </TextBlock>
                            <TextBlock FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0" TextAlignment="Left"
                                       Text="{Binding PaymentStatusDisplay}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#374151"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PaymentStatusDisplay}" Value="PAID">
                                                <Setter Property="Foreground" Value="Black"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PaymentStatusDisplay}" Value="UNPAID">
                                                <Setter Property="Foreground" Value="#C62828"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock FontSize="13" FontWeight="Bold" VerticalAlignment="Center" TextAlignment="Left"
                                       Text="{Binding OrderMethodDisplay}"
                                       Foreground="{Binding OrderMethodDisplay, Converter={StaticResource OrderTypeToBadgeBrushConverter}}"/>
                            <TextBlock FontSize="13" Foreground="#757575" VerticalAlignment="Center" Margin="8,0,0,0" TextAlignment="Left" TextWrapping="Wrap"
                                       Text="{Binding OrderStatusDisplay}"
                                       Visibility="{Binding ShowOrderStatusDisplay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                        <Button Margin="0,10,0,0" HorizontalAlignment="Left" Padding="12,6" MinWidth="88"
                                Command="{Binding DataContext.FloorPlanLayout.ViewSessionOrderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#2196F3" Foreground="White" BorderThickness="0"
                                Visibility="{Binding DataContext.FloorPlanLayout.ShowPerRowOrderViewButtons, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="View" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <materialDesign:PackIcon Kind="ArrowRight" Width="16" Height="16" Margin="4,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>
    <materialDesign:DialogHost x:Name="RootDialogHost" Identifier="RootDialogHost" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <local:Sidebar x:Name="SidebarControl" Grid.Column="0"/>
            <Grid Grid.Column="1" Background="#F8F8F8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="10,5,20,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#2196F3" Width="15" Height="60" CornerRadius="5"/>
                        <StackPanel Orientation="Vertical" Margin="10">
                            <TextBlock Text="Table View" FontSize="22" FontWeight="Bold" Margin="0,0,0,2"/>
                            <TextBlock Text="Manage Table Orders" FontSize="15"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{Binding RefreshTablesCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#2196F3"
                            Foreground="White"
                            Padding="16,8"
                            VerticalAlignment="Center"
                            ToolTip="Refresh table data">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Margin="10,0,20,16" MinHeight="400">
                    <controls:LoadingIndicator HorizontalAlignment="Center" VerticalAlignment="Center"
                                               ProgressRingSize="70"
                                               Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- Default wrap grid when floor plan layout is off -->
                    <ItemsControl ItemsSource="{Binding Tables}"
                                  Visibility="{Binding ShowDefaultTableGrid, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="12,10">
                                    <Button Width="95" Height="105" Padding="5" Margin="0,15,0,0" Background="White" BorderThickness="0" Cursor="Hand"
                                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Top"
                                            Command="{Binding DataContext.TableButtonClickCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel HorizontalAlignment="Stretch" Background="White">
                                            <TextBlock Text="{Binding Name}" Foreground="Black" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding SeatCount, Converter={StaticResource SeatCountConverter}}" FontSize="10" Margin="1" Foreground="Gray" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding DisplayAmount, Converter={StaticResource CurrencyFormatConverter}}"
                                                       FontSize="10" Margin="1" Foreground="Gray" HorizontalAlignment="Center"
                                                       Visibility="{Binding Status, Converter={StaticResource TableStatusVisibilityConverter}, ConverterParameter='Reserved,Served'}"/>
                                            <TextBlock Text="{Binding CustomerName, Converter={StaticResource TrimConverter}}"
                                                       TextAlignment="Center" HorizontalAlignment="Stretch"
                                                       FontSize="10" Margin="0,1,0,0" Foreground="Gray"
                                                       TextWrapping="Wrap" MaxHeight="40"
                                                       Visibility="{Binding Status, Converter={StaticResource TableStatusVisibilityConverter}, ConverterParameter='Reserved,Served'}"/>
                                        </StackPanel>
                                    </Button>
                                    <Border CornerRadius="8" Background="#FFC64A" Padding="8,2" HorizontalAlignment="Center" VerticalAlignment="Top"
                                            Visibility="{Binding Status,Converter={StaticResource TableStatusVisibilityConverter}, ConverterParameter=Served}">
                                        <TextBlock Text="Served" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="8" Background="#FFCDD2" Padding="8,2" HorizontalAlignment="Center" VerticalAlignment="Top"
                                            Visibility="{Binding Status,Converter={StaticResource TableStatusVisibilityConverter}, ConverterParameter=Drafted}">
                                        <TextBlock Text="Draft" Foreground="#D32F2F" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="8" Background="#2196F3" Padding="8,2" HorizontalAlignment="Center" VerticalAlignment="Top"
                                            Visibility="{Binding Status,Converter={StaticResource TableStatusVisibilityConverter}, ConverterParameter=Reserved}">
                                        <TextBlock Text="Reserved" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="8" Background="#4CAF50" Padding="8,2" HorizontalAlignment="Center" VerticalAlignment="Top"
                                            Visibility="{Binding Status,Converter={StaticResource TableStatusVisibilityConverter}, ConverterParameter=Available}">
                                        <TextBlock Text="Available" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    <Border CornerRadius="8" Background="#9E9E9E" Padding="8,2" HorizontalAlignment="Center" VerticalAlignment="Top"
                                            Visibility="{Binding Status,Converter={StaticResource TableStatusVisibilityConverter}, ConverterParameter=Unavailable}">
                                        <TextBlock Text="Unavailable" Foreground="#EEEEEE" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Floor plan + sidebar when enabled -->
                    <Grid Visibility="{Binding ShowFloorPlanLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" DataContext="{Binding FloorPlanLayout}" Margin="0,0,12,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ListBox Grid.Row="0" ItemsSource="{Binding FloorPlans}" SelectedValuePath="Id"
                                     SelectedValue="{Binding SelectedFloorPlanId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent" Margin="0,0,0,8"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="14,8"/>
                                        <Setter Property="Margin" Value="0,0,6,0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="TabBorder" CornerRadius="6" Padding="{TemplateBinding Padding}" Background="#EEEEEE" SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="TabBorder" Property="Background" Value="#1976D2"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="TabBorder" Property="Opacity" Value="0.92"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                          PanningMode="Both" MaxHeight="560" MaxWidth="{Binding FloorPlanScrollMaxWidth}">
                                <Grid Width="{Binding CanvasHostWidth}" Height="{Binding CanvasHostHeight}"
                                      HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <ItemsControl ItemsSource="{Binding FloorPlanDecorPlacements}" Panel.ZIndex="0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Background="#F9F9F9"
                                                        Width="{Binding DataContext.CanvasHostWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                        Height="{Binding DataContext.CanvasHostHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="{Binding Width}" Height="{Binding Height}" IsHitTestVisible="False"
                                                        Background="{Binding ColorHex, Converter={StaticResource ColorHexStringToBrushConverter}}"
                                                        CornerRadius="{Binding CornerRadiusValue}" SnapsToDevicePixels="True" Opacity="0.95">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Shape}" Value="{x:Static models:FloorPlanShapeType.Parallelogram}">
                                                                    <Setter Property="RenderTransform">
                                                                        <Setter.Value>
                                                                            <SkewTransform AngleX="-18" AngleY="0"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Shape}" Value="{x:Static models:FloorPlanShapeType.Diamond}">
                                                                    <Setter Property="RenderTransform">
                                                                        <Setter.Value>
                                                                            <RotateTransform Angle="45"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="2">
                                                        <materialDesign:PackIcon Kind="{Binding IconKindName, Converter={StaticResource PackIconKindConverter}}" Width="26" Height="26" Foreground="White" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding TableName}" FontSize="10" FontWeight="SemiBold" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="{Binding Width}" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl ItemsSource="{Binding PickItems}" Panel.ZIndex="1">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Background="Transparent"
                                                        Width="{Binding DataContext.CanvasHostWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                        Height="{Binding DataContext.CanvasHostHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding Placement.X}"/>
                                                <Setter Property="Canvas.Top" Value="{Binding Placement.Y}"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Width="{Binding Placement.Width}" Height="{Binding Placement.Height}"
                                                        Command="{Binding TapCommand}" Padding="0" Background="Transparent"
                                                        BorderThickness="0" Focusable="False" SnapsToDevicePixels="True">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Cursor" Value="Arrow"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelectable}" Value="True">
                                                                    <Setter Property="Cursor" Value="Hand"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Border CornerRadius="{Binding Placement.CornerRadiusValue}"
                                                            Background="{Binding Placement.ColorHex, Converter={StaticResource ColorHexStringToBrushConverter}}"
                                                            SnapsToDevicePixels="True">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                                <Setter Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="Black"/>
                                                                        <Setter Property="BorderThickness" Value="2"/>
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="0" Opacity="0.68"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Placement.Shape}" Value="{x:Static models:FloorPlanShapeType.Parallelogram}">
                                                                        <Setter Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <SkewTransform AngleX="-18" AngleY="0"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Placement.Shape}" Value="{x:Static models:FloorPlanShapeType.Diamond}">
                                                                        <Setter Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <RotateTransform Angle="45"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="2">
                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="12" Foreground="White"
                                                                       TextAlignment="Center" TextWrapping="Wrap" MaxWidth="{Binding Placement.Width}">
                                                                <TextBlock.Effect>
                                                                    <DropShadowEffect BlurRadius="2" ShadowDepth="0" Opacity="0.9" Color="Black"/>
                                                                </TextBlock.Effect>
                                                            </TextBlock>
                                                            <Rectangle Width="22" Height="16" Margin="0,6,0,0" HorizontalAlignment="Center"
                                                                       Fill="{Binding StatusSwatchHex, Converter={StaticResource ColorHexStringToBrushConverter}}"
                                                                       Stroke="#333333" StrokeThickness="1"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </ScrollViewer>

                            <Border Grid.Row="2" Background="#F9F9F9" CornerRadius="6" Padding="10,6" Margin="0,8,0,0">
                                <WrapPanel HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                        <Border Width="14" Height="14" CornerRadius="2" Background="#E0E0E0" BorderBrush="#999" BorderThickness="1" Margin="0,0,6,0"/>
                                        <TextBlock Text="Available" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                        <Border Width="14" Height="14" CornerRadius="2" Background="#9E9E9E" Margin="0,0,6,0"/>
                                        <TextBlock Text="Unavailable" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                        <Border Width="14" Height="14" CornerRadius="2" Background="#FBC02D" Margin="0,0,6,0"/>
                                        <TextBlock Text="Reserved (Ongoing table of this order)" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                        <Border Width="14" Height="14" CornerRadius="2" Background="#1976D2" Margin="0,0,6,0"/>
                                        <TextBlock Text="Reserved" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                        <Border Width="14" Height="14" CornerRadius="2" Background="#FF8C00" Margin="0,0,6,0"/>
                                        <TextBlock Text="Served" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </WrapPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Column="1" DataContext="{Binding FloorPlanLayout}" Background="White" CornerRadius="8" Padding="12" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel HorizontalAlignment="Stretch">
                                        <!-- Table details (heading left; content centered) -->
                                        <TextBlock Text="Table Details" FontSize="13" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,8" HorizontalAlignment="Left" TextAlignment="Left"/>
                                        <Border Width="96" Height="96" CornerRadius="48" Background="#E3F2FD" HorizontalAlignment="Center" Margin="0,0,0,12">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Opacity" Value="0.55"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSelectedTable}" Value="True">
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <materialDesign:PackIcon Kind="TableFurniture" Width="52" Height="52" Foreground="#1976D2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Select a table on the floor plan." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="14"
                                                   TextAlignment="Center" HorizontalAlignment="Center" Margin="4,0,4,8"
                                                   Visibility="{Binding HasSelectedTable, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"/>
                                        <StackPanel Visibility="{Binding HasSelectedTable, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Center" MaxWidth="280">
                                            <TextBlock Text="{Binding SelectedTableDisplayName, StringFormat='Table: {0}'}" FontSize="18" FontWeight="Bold" Foreground="#1a1a1a"
                                                       TextAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding SelectedSessionIdLabel}" FontSize="12" Foreground="#6B7280" Margin="0,6,0,0"
                                                       TextAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowSessionId}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- Same status chips as default Table View grid (tighter vertical spacing than grid overlay) -->
                                            <Grid HorizontalAlignment="Center" Margin="0,6,0,2" MinHeight="26">
                                                <Border CornerRadius="8" Background="#FFC64A" Padding="10,2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Visibility="{Binding SelectedTableForDetails.Status, Converter={StaticResource TableStatusVisibilityConverter}, ConverterParameter=Served}">
                                                    <TextBlock Text="Served" FontSize="13" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                                <Border CornerRadius="8" Background="#FFCDD2" Padding="10,2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Visibility="{Binding SelectedTableForDetails.Status, Converter={StaticResource TableStatusVisibilityConverter}, ConverterParameter=Drafted}">
                                                    <TextBlock Text="Draft" FontSize="13" Foreground="#D32F2F" FontWeight="Bold"/>
                                                </Border>
                                                <Border CornerRadius="8" Background="#2196F3" Padding="10,2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Visibility="{Binding SelectedTableForDetails.Status, Converter={StaticResource TableStatusVisibilityConverter}, ConverterParameter=Reserved}">
                                                    <TextBlock Text="Reserved" FontSize="13" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                                <Border CornerRadius="8" Background="#4CAF50" Padding="10,2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Visibility="{Binding SelectedTableForDetails.Status, Converter={StaticResource TableStatusVisibilityConverter}, ConverterParameter=Available}">
                                                    <TextBlock Text="Available" FontSize="13" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                                <Border CornerRadius="8" Background="#9E9E9E" Padding="10,2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Visibility="{Binding SelectedTableForDetails.Status, Converter={StaticResource TableStatusVisibilityConverter}, ConverterParameter=Unavailable}">
                                                    <TextBlock Text="Unavailable" FontSize="13" Foreground="#EEEEEE" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                                                <TextBlock Text="Seats: " FontSize="13" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                                <TextBlock FontSize="13" Foreground="#374151" VerticalAlignment="Center"
                                                           Text="{Binding SelectedTableForDetails.SeatCount, Converter={StaticResource SeatCountConverter}}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Border Height="1" Background="#E5E7EB" Margin="0,18,0,14"/>

                                        <!-- Order details -->
                                        <TextBlock Text="Order Details" FontSize="13" FontWeight="SemiBold" Foreground="#6B7280" Margin="2,0,10,8" HorizontalAlignment="Left"/>
                                        <StackPanel Visibility="{Binding HasSelectedTable, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}" Margin="2,0,10,0">
                                            <TextBlock Text="Select a table to see order details." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="13"
                                                       TextAlignment="Left" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                                        </StackPanel>
                                        <StackPanel Visibility="{Binding HasSelectedTable, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Stretch">
                                            <StackPanel Margin="2,0,10,10" Orientation="Horizontal" VerticalAlignment="Center"
                                                        Visibility="{Binding ShowSessionSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Session total" FontSize="13" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center" Margin="0,0,6,0"
                                                           Visibility="{Binding ShowSessionSummaryAmount, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <TextBlock FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                                                           Text="{Binding SessionSummaryTotal, Converter={StaticResource CurrencyFormatConverter}}"
                                                           Visibility="{Binding ShowSessionSummaryAmount, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#374151"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SessionSummaryPaymentStatus}" Value="PAID">
                                                                    <Setter Property="Foreground" Value="Black"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SessionSummaryPaymentStatus}" Value="UNPAID">
                                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0" TextAlignment="Left"
                                                           Text="{Binding SessionSummaryPaymentStatus}"
                                                           Visibility="{Binding ShowSessionSummaryPaymentLine, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#374151"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SessionSummaryPaymentStatus}" Value="PAID">
                                                                    <Setter Property="Foreground" Value="Black"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SessionSummaryPaymentStatus}" Value="UNPAID">
                                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <ItemsControl ItemsSource="{Binding OrderRows}"
                                                          ItemTemplate="{StaticResource TablesSidebarOrderRowTemplate}"
                                                          Visibility="{Binding HasOrderRows, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                                                        <Setter Property="UseLayoutRounding" Value="True"/>
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                            </ItemsControl>

                                            <ContentControl Content="{Binding StandaloneOrderRow}"
                                                            ContentTemplate="{StaticResource TablesSidebarOrderRowTemplate}"
                                                            Visibility="{Binding ShowStandaloneOrderPreview, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                            <TextBlock Text="No active order(s) for this table." TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="13"
                                                       TextAlignment="Left" HorizontalAlignment="Left" Margin="2,4,10,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding HasOrderRows}" Value="False"/>
                                                                    <Condition Binding="{Binding ShowStandaloneOrderPreview}" Value="False"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                                <Button Grid.Row="1" Margin="0,12,0,0" HorizontalAlignment="Stretch" Content="View order"
                                        Style="{StaticResource MaterialDesignRaisedButton}" Background="#2196F3" Foreground="White"
                                        Command="{Binding ViewPrimaryOrderCommand}"
                                        Visibility="{Binding ShowSingleViewOrderButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</Page>
