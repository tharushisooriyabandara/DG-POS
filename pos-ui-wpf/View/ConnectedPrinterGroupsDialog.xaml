<UserControl x:Class="POS_UI.View.ConnectedPrinterGroupsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="500" Height="400"
             Background="#FAFAFA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{Binding GroupName, StringFormat='Connected Printers - {0}'}" 
                       FontWeight="Bold" 
                       FontSize="18"/>
            <Button DockPanel.Dock="Right" 
                    Width="32" 
                    Height="32" 
                    Background="Transparent" 
                    Style="{StaticResource MaterialDesignToolButton}" 
                    HorizontalAlignment="Right" 
                    BorderBrush="Transparent" 
                    Click="CloseButton_Click" 
                    ToolTip="Close">
                <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
            </Button>
        </DockPanel>
        
        <!-- Printers List -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Table Header -->
            <Border Grid.Row="0" Background="#F5F6FA" CornerRadius="8,8,0,0" Padding="15,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Device Name" FontWeight="Bold" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Status" FontWeight="Bold" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Actions" FontWeight="Bold" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            
            <!-- Printers List -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding ConnectedPrinters}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="48" VerticalAlignment="Center" Background="White" Margin="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="{Binding DeviceName}" 
                                           FontWeight="SemiBold" 
                                           FontSize="15" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Left"
                                           Margin="15,0,0,0"
                                           Foreground="#374151"/>

                                <Border Grid.Column="1" 
                                        Background="{Binding StatusColor}" 
                                        CornerRadius="4" 
                                        Padding="8,2" 
                                        HorizontalAlignment="Left" 
                                        VerticalAlignment="Center"
                                        Margin="15,0,0,0">
                                    <TextBlock Text="{Binding Status}" 
                                               Foreground="White" 
                                               FontWeight="Bold" 
                                               FontSize="13"/>
                                </Border>
                                
                                <ToggleButton Grid.Column="2"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="15,0,0,0"
                                              Width="50"
                                              Height="28"
                                              Checked="ToggleButton_Checked"
                                              Unchecked="ToggleButton_Unchecked"
                                              Tag="{Binding}">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="14"
                                                                Width="50"
                                                                Height="28">
                                                            <Grid>
                                                                <Ellipse x:Name="Thumb"
                                                                         Width="24"
                                                                         Height="24"
                                                                         Margin="2"
                                                                         HorizontalAlignment="Left"
                                                                         VerticalAlignment="Center"
                                                                         Fill="White"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Background" Value="#4CAF50"/>
                                                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
        
        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Close" 
                    Width="100" 
                    Height="36" 
                    Background="#1976D2" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
