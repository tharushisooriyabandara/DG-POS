                                            </Border>
                                            <Border Background="#FFF8F8F8"  Grid.Column="3" Grid.Row="1" CornerRadius="8" Padding="10,12" Margin="8" BorderBrush="#E0E0E0" BorderThickness="1" Height="100">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="140"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="DineIn Revenue" VerticalAlignment="Center" FontSize="18"/>
                                                    <TextBlock Grid.Column="1" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} {1:F2}">
                                                                <Binding Path="Currency"/>
                                                                <Binding Path="TotalDineInAmount"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                            <Border Background="#FFF8F8F8" Grid.Column="1" Grid.Row="2" CornerRadius="8" Padding="10,12" Margin="8" BorderBrush="#E0E0E0" BorderThickness="1" Height="100">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="140"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Delivery Revenue" VerticalAlignment="Center" FontSize="18"  Style="{StaticResource TwoLineMetricLabel}"/>
                                                    <TextBlock Grid.Column="1" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} {1:F2}">
                                                                <Binding Path="Currency"/>
                                                                <Binding Path="TotalDeliveryAmount"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                            <Border Background="#FFF8F8F8"  Grid.Column="3" Grid.Row="2" CornerRadius="8" Padding="10,12" Margin="8" BorderBrush="#E0E0E0" BorderThickness="1" Height="100">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="140"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Takeaway Revenue" VerticalAlignment="Center" FontSize="18"  Style="{StaticResource TwoLineMetricLabel}"/>
                                                    <TextBlock Grid.Column="1" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} {1:F2}">
                                                                <Binding Path="Currency"/>
                                                                <Binding Path="TotalTakeawayAmount"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </ScrollViewer>

                                    <!-- Placeholder for table/list below cards (optional) -->
                                    <Grid Grid.Row="1" Grid.ColumnSpan="2"/>
                                </Grid>
                            </TabItem>

                            <!-- All Orders Tab -->
                            <TabItem Header="All Orders">
                                <TabItem.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="All Orders" FontWeight="Bold" FontSize="20"/>
                                    </DataTemplate>
                                </TabItem.HeaderTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Loading Indicator -->
                                    <controls:LoadingIndicator Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="1000"
                                                  HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center" 
                                                  ProgressRingSize="70"
                                                  Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Filters Bar for All Orders -->
                                    <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="0" Margin="8,8,8,0" HorizontalAlignment="Right">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="16"/>
                                                <DatePicker SelectedDate="{Binding FromDate}" FontSize="16" VerticalAlignment="Center"
                                                          IsDropDownOpen="False" DisplayDateEnd="{x:Static sys:DateTime.Today}"
                                                          PreviewMouseLeftButtonDown="DatePicker_FocusOpen"
                                                          PreviewTouchDown="DatePicker_FocusOpen"
                                                          Loaded="DatePicker_Loaded"
                                                          Language="{converters:CountryToLanguageExtension}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="16"/>
                                                <DatePicker SelectedDate="{Binding ToDate}" FontSize="16" VerticalAlignment="Center"
                                                          IsDropDownOpen="False" DisplayDateEnd="{x:Static sys:DateTime.Today}"
                                                          PreviewMouseLeftButtonDown="DatePicker_FocusOpen"
                                                          PreviewTouchDown="DatePicker_FocusOpen"
                                                          Loaded="DatePicker_Loaded"
                                                          Language="{converters:CountryToLanguageExtension}"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="Show" Command="{Binding ShowDashboardStatsCommand}" VerticalAlignment="Center"
                                                    Background="#1976D2" Foreground="White" Padding="14,8" Margin="0,0,12,0" Width="90"/>
                                            <Button Grid.Column="3" Content="Clear" Command="{Binding ClearDatesCommand}" VerticalAlignment="Center"
                                                    Background="#EEEEEE" Foreground="#333" Padding="14,8" Width="90"/>
                                        </Grid>
                                    </Border>

                                    <!-- All Orders Summary Cards -->
                                    <ScrollViewer Grid.Row="1" Margin="8" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled"
                                                  Visibility="{Binding IsLoading, Converter={StaticResource InvertBooleanToVisibilityConverter}}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Row 1 -->
                                            <Border Grid.Column="0" Grid.Row="0" CornerRadius="8" Padding="12" Margin="8" BorderBrush="#E0E0E0" BorderThickness="1" Height="125" Background="#FFF8F8F8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Total Orders" VerticalAlignment="Center" FontSize="18"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AllTotalOrders}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <Border Grid.Column="1" Grid.Row="0" CornerRadius="8" Padding="12" Margin="8" BorderBrush="#E0E0E0" BorderThickness="1" Height="125" Background="#FFF8F8F8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Completed Orders" VerticalAlignment="Center" FontSize="18"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AllCompletedOrders}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <Border Grid.Column="2" Grid.Row="0" CornerRadius="8" Padding="12" Margin="8" BorderBrush="#E0E0E0" BorderThickness="1" Height="125" Background="#FFF8F8F8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Accepted Orders" VerticalAlignment="Center" FontSize="18"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AllAcceptedOrders}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>

                                            <!-- Row 2 -->
                                            <Border Grid.Column="0" Grid.Row="1" CornerRadius="8" Padding="12" Margin="8" BorderBrush="#E0E0E0" BorderThickness="1" Height="125" Background="#FFF8F8F8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Cancelled Orders" VerticalAlignment="Center" FontSize="18"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AllCancelledOrders}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <Border Grid.Column="1" Grid.Row="1" CornerRadius="8" Padding="12" Margin="8" BorderBrush="#E0E0E0" BorderThickness="1" Height="125" Background="#FFF8F8F8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Declined Orders" VerticalAlignment="Center" FontSize="18"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AllDeclinedOrders}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <Border Grid.Column="2" Grid.Row="1" CornerRadius="8" Padding="12" Margin="8" BorderBrush="#E0E0E0" BorderThickness="1" Height="125" Background="#FFF8F8F8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Ready For Pickup" VerticalAlignment="Center" FontSize="18"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding AllReadyOrders}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>

                                            <!-- Row 3 -->
                                            <Border Grid.Column="0" Grid.Row="2" CornerRadius="8" Padding="12" Margin="8" BorderBrush="#E0E0E0" BorderThickness="1" Height="125" Background="#FFF8F8F8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="140"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Best Selling Platform" VerticalAlignment="Center" FontSize="18"/>
                                                    <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <Image Source="{Binding AllBestSellingPlatformUrl, FallbackValue={x:Null}, TargetNullValue={x:Null}}" 
                                                               Width="80" Height="40" 
                                                               Stretch="Uniform" 
                                                               RenderOptions.BitmapScalingMode="HighQuality"
                                                               Visibility="{Binding AllBestSellingPlatformUrl, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                                        <TextBlock Text="{Binding AllBestSellingPlatform}" 
                                                                   FontSize="18" FontWeight="Bold" 
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Visibility="{Binding AllBestSellingPlatformUrl, Converter={StaticResource InvertBooleanToVisibilityConverter}}"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                            <Border Grid.Column="1" Grid.Row="2" CornerRadius="8" Padding="12" Margin="8" BorderBrush="#E0E0E0" BorderThickness="1" Height="125" Background="#FFF8F8F8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="140"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Total Revenue" VerticalAlignment="Center" FontSize="18"/>
                                                    <TextBlock Grid.Column="1" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} {1:F2}">
                                                                <Binding Path="Currency"/>
                                                                <Binding Path="AllTotalRevenue"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </ScrollViewer>

                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </Grid>

            <!-- Loading Overlay for X-Report Printing -->
           <!-- <Grid Grid.ColumnSpan="2" 
                  Visibility="{Binding IsPrintingXReport, Converter={StaticResource BooleanToVisibilityConverter}}" 
                  Background="#80BDBDBD" Panel.ZIndex="9999">
                <controls:LoadingIndicator HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" 
                                           ProgressRingSize="70"/>
            </Grid> -->
        </Grid>
    </materialDesign:DialogHost>
</Page>
