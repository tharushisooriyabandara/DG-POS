# Toast API (required)
TOAST_CLIENT_ID=your_toast_client_id
TOAST_CLIENT_SECRET=your_toast_client_secret
TOAST_RESTAURANT_ID=your_restaurant_guid

# PostgreSQL (required)
TOAST_DB_PASSWORD=your_db_password

# Optional – defaults shown
TOAST_DB_NAME=toast_data
TOAST_DB_USER=postgres
TOAST_DB_HOST=localhost
TOAST_DB_PORT=5432
